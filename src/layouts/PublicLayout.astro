---
import "@/styles/public-system.css";
import ChannelNavigation from "@/components/public/ChannelNavigation.astro";
import PublicBackLink from "@/components/public/PublicBackLink.astro";
import PublicHeaderSearch from "@/components/public/PublicHeaderSearch.astro";
import type { PublicSiteShell } from "@/lib/db/public";

interface Props {
  site: PublicSiteShell;
  title: string;
  description?: string;
  canonical?: string | null;
  robots?: string | undefined;
  ogImage?: string | null;
  ogImageAlt?: string | null;
  ogImageWidth?: number | null;
  ogImageHeight?: number | null;
  ogType?: "website" | "article" | "product";
  activeChannel?: string | null;
  backHref?: string | null;
  showChannelNavigation?: boolean;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>> | null;
}

const {
  site,
  title,
  description = site.siteDescription,
  canonical = Astro.url.href,
  robots = "index,follow,max-image-preview:large",
  ogImage = site.logoUrl,
  ogImageAlt = ogImage ? site.siteName : null,
  ogImageWidth = null,
  ogImageHeight = null,
  ogType = "website",
  activeChannel = null,
  backHref = null,
  showChannelNavigation = true,
  structuredData = null,
} = Astro.props;

const pageTitle = title === site.siteName ? title : `${title} · ${site.siteName}`;
const socialUrl = canonical ?? Astro.url.href;
const showAdultGate = site.adultGateEnabled;
const ga4Id = site.ga4Id;
const metaPixelId = site.metaPixelId;
const structuredDataJson = structuredData
  ? JSON.stringify(structuredData).replaceAll("<", "\\u003c")
  : null;
const hasBack = Boolean(backHref);
const headerSearchAction = activeChannel
  ? `/${encodeURIComponent(activeChannel)}/search`
  : null;
const headerSearchValue = headerSearchAction && Astro.url.pathname.endsWith("/search")
  ? Astro.url.searchParams.get("q") ?? ""
  : "";
const currentYear = new Date().getUTCFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="robots" content={robots} />
    {canonical && <link rel="canonical" href={canonical} />}
    {site.faviconUrl && <link rel="icon" href={site.faviconUrl} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={socialUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    {ogImage && ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {ogImage && ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {ogImage && ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}
    <title>{pageTitle}</title>
    {structuredDataJson && <script is:inline type="application/ld+json" set:html={structuredDataJson}></script>}

    {showAdultGate && (
      <script is:inline>
        (() => {
          const confirmed = document.cookie
            .split(';')
            .some((item) => item.trim() === 'site_adult_confirmed=1');
          if (confirmed) document.documentElement.classList.add('adult-confirmed');
        })();
      </script>
    )}

    {(ga4Id || metaPixelId) && (
      <script is:inline define:vars={{ ga4Id, metaPixelId }}>
        (() => {
          let started = false;
          let timer = 0;
          const events = ['pointerdown', 'keydown', 'scroll'];

          const start = () => {
            if (started) return;
            started = true;
            if (timer) window.clearTimeout(timer);
            events.forEach((eventName) => window.removeEventListener(eventName, start));

            if (ga4Id) {
              window.dataLayer = window.dataLayer || [];
              window.gtag = window.gtag || function(){ window.dataLayer.push(arguments); };
              window.gtag('js', new Date());
              window.gtag('config', ga4Id);
              const script = document.createElement('script');
              script.async = true;
              script.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(ga4Id)}`;
              document.head.appendChild(script);
            }

            if (metaPixelId) {
              !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
              n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
              n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
              t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}
              (window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
              fbq('init', metaPixelId);
              fbq('track', 'PageView');
            }
          };

          events.forEach((eventName) => window.addEventListener(eventName, start, { once: true, passive: true }));
          window.addEventListener('load', () => {
            timer = window.setTimeout(start, 5000);
          }, { once: true });
        })();
      </script>
    )}
  </head>
  <body class="public-body">
    {metaPixelId && (
      <noscript>
        <img
          height="1"
          width="1"
          style="display:none"
          src={`https://www.facebook.com/tr?id=${encodeURIComponent(metaPixelId)}&ev=PageView&noscript=1`}
          alt=""
        />
      </noscript>
    )}

    <header class="public-header" data-public-header data-search-open="false">
      <div class="public-container public-header-shell">
        <div class="public-header-default" data-header-default>
          <div class="public-header-leading">
            {hasBack ? (
              <PublicBackLink href={backHref ?? "/"} />
            ) : (
              <details class="public-menu" data-public-menu>
                <summary class="public-menu-trigger" aria-label="Open site menu">
                  <span aria-hidden="true"></span>
                  <span aria-hidden="true"></span>
                  <span aria-hidden="true"></span>
                </summary>
                <nav class="public-menu-panel" aria-label="Site links">
                  {site.channels.map((channel) => (
                    <a href={`/${encodeURIComponent(channel.slug)}`}>{channel.name}</a>
                  ))}
                  <a href="/privacy">Privacy</a>
                  <a href="/disclaimer">Disclaimer</a>
                </nav>
              </details>
            )}
          </div>

          <a class="public-brand public-brand-centered" href="/" aria-label={`${site.siteName} home`}>
            {site.logoUrl ? (
              <img class="public-brand-logo" src={site.logoUrl} alt="" decoding="async" />
            ) : (
              <span class="public-brand-name">{site.siteName}</span>
            )}
          </a>

          <nav class="public-header-desktop-nav" aria-label="Primary navigation">
            {site.channels.map((channel) => (
              <a
                href={`/${encodeURIComponent(channel.slug)}`}
                aria-current={activeChannel === channel.slug ? "page" : undefined}
              >
                {channel.name}
              </a>
            ))}
            <a href="/privacy">Privacy</a>
            <a href="/disclaimer">Disclaimer</a>
          </nav>

          <div class="public-header-trailing">
            {headerSearchAction ? (
              <>
                <div class="public-header-search-desktop">
                  <PublicHeaderSearch
                    action={headerSearchAction}
                    ariaLabel={`Search ${site.siteName}`}
                    value={headerSearchValue}
                    variant="inline"
                  />
                </div>
                <button
                  class="public-header-search-trigger public-header-search-trigger-mobile"
                  type="button"
                  aria-label="Open search"
                  aria-expanded="false"
                  data-header-search-open
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="1.7" />
                    <path d="m16 16 4 4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.7" />
                  </svg>
                </button>
              </>
            ) : (
              <span class="public-header-balance" aria-hidden="true"></span>
            )}
          </div>
        </div>

        {headerSearchAction && (
          <div class="public-header-search-layer" data-header-search-layer aria-hidden="true" inert>
            <PublicHeaderSearch
              action={headerSearchAction}
              ariaLabel={`Search ${site.siteName}`}
              value={headerSearchValue}
              variant="overlay"
            />
          </div>
        )}
      </div>
    </header>

    <main class="public-container public-main">
      <slot />
    </main>

    {showChannelNavigation && <ChannelNavigation channels={site.channels} activeChannel={activeChannel} />}

    <footer class="public-footer">
      <div class="public-container public-footer-inner">
        <div class="public-footer-brand">
          <strong>{site.siteName}</strong>
          {site.siteDescription && <p>{site.siteDescription}</p>}
        </div>

        <nav class="public-footer-links" aria-label="Footer links">
          {site.channels.map((channel) => (
            <a href={`/${encodeURIComponent(channel.slug)}`}>{channel.name}</a>
          ))}
          <a href="/privacy">Privacy</a>
          <a href="/disclaimer">Disclaimer</a>
        </nav>

        <p class="public-footer-meta">© {currentYear} {site.siteName}. All rights reserved.</p>
      </div>
    </footer>

    <script>import "@/scripts/public-interactions";</script>

    {showAdultGate && (
      <div class="adult-gate" data-adult-gate role="dialog" aria-modal="true" aria-labelledby="adult-gate-title">
        <div class="adult-gate-card">
          <div class="eyebrow">Age confirmation</div>
          <h2 id="adult-gate-title">Adults only</h2>
          <p>You must be at least 18 years old, or the legal age in your location, to enter this site.</p>
          <div class="adult-gate-actions">
            <button class="public-button" type="button" data-adult-accept>I am 18 or older</button>
            <button class="public-button secondary" type="button" data-adult-exit>Leave</button>
          </div>
        </div>
      </div>
    )}
  </body>
</html>

<style is:global>
  .adult-confirmed .adult-gate { display: none; }

  .public-body {
    --public-font-brand: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --public-font-display: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --public-font-ui: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-family: var(--public-font-ui);
    font-synthesis: none;
    letter-spacing: 0;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .public-body button,
  .public-body input,
  .public-body textarea,
  .public-body select,
  .public-body summary {
    font: inherit;
  }

  .public-header-desktop-nav,
  .public-header-search-desktop {
    display: none;
  }

  @media (min-width: 768px) {
    .public-header-default {
      display: flex;
      align-items: center;
      gap: clamp(.65rem, 1.45vw, 1.15rem);
    }

    .public-header-leading {
      display: none;
    }

    .public-header-default .public-brand-centered {
      max-width: min(20rem, 24vw);
      flex: 0 1 auto;
      justify-self: auto;
    }

    .public-header-default .public-brand-logo {
      object-position: left center;
    }

    .public-header-default .public-brand-name {
      max-width: min(20rem, 24vw);
      text-align: left;
    }

    .public-header-desktop-nav {
      display: flex;
      min-width: 0;
      flex: 1 1 auto;
      align-items: center;
      justify-content: flex-start;
      gap: .15rem;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .public-header-desktop-nav::-webkit-scrollbar {
      display: none;
    }

    .public-header-desktop-nav a {
      flex: 0 0 auto;
      border-radius: .4rem;
      padding: .55rem .65rem;
      color: var(--text-2);
      font-size: .78rem;
      font-weight: 650;
      line-height: 1;
      white-space: nowrap;
    }

    .public-header-desktop-nav a:hover,
    .public-header-desktop-nav a[aria-current="page"] {
      color: var(--text-1);
      background: var(--surface-2);
    }

    .public-header-desktop-nav a[aria-current="page"] {
      font-weight: 780;
    }

    .public-header-trailing {
      min-width: 11.5rem;
      flex: 0 1 clamp(11.5rem, 23vw, 22.5rem);
      margin-left: auto;
    }

    .public-header-search-desktop {
      display: block;
      width: 100%;
    }

    .public-header-search-trigger-mobile,
    .public-header-search-layer {
      display: none !important;
    }

    .public-header[data-search-open="true"] .public-header-default {
      opacity: 1;
      pointer-events: auto;
      filter: none;
      transform: none;
    }
  }
</style>
