---
import "@/styles/public-base.css";
import "@/styles/public.css";
import ChannelNavigation from "@/components/public/ChannelNavigation.astro";
import type { PublicSiteShell } from "@/lib/db/public";

interface Props {
  site: PublicSiteShell;
  title: string;
  description?: string;
  canonical?: string | null;
  robots?: string | undefined;
  ogImage?: string | null;
  activeChannel?: string | null;
}

const {
  site,
  title,
  description = site.siteDescription,
  canonical = Astro.url.href,
  robots = "index,follow,max-image-preview:large",
  ogImage = site.logoUrl,
  activeChannel = null,
} = Astro.props;

const pageTitle = title === site.siteName ? title : `${title} · ${site.siteName}`;
const socialUrl = canonical ?? Astro.url.href;
const showAdultGate = site.adultGateEnabled;
const ga4Id = site.ga4Id;
const metaPixelId = site.metaPixelId;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content={robots} />
    {canonical && <link rel="canonical" href={canonical} />}
    {site.faviconUrl && <link rel="icon" href={site.faviconUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={socialUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <title>{pageTitle}</title>

    {showAdultGate && (
      <script is:inline>
        (() => {
          const confirmed = document.cookie
            .split(';')
            .some((item) => item.trim() === 'site_adult_confirmed=1');
          if (confirmed) document.documentElement.classList.add('adult-confirmed');
        })();
      </script>
    )}

    {ga4Id && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(ga4Id)}`}></script>}
    {ga4Id && (
      <script is:inline define:vars={{ ga4Id }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ window.dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', ga4Id);
      </script>
    )}

    {metaPixelId && (
      <script is:inline define:vars={{ metaPixelId }}>
        !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
        n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}
        (window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', metaPixelId);
        fbq('track', 'PageView');
      </script>
    )}
  </head>
  <body class="public-body">
    {metaPixelId && (
      <noscript>
        <img
          height="1"
          width="1"
          style="display:none"
          src={`https://www.facebook.com/tr?id=${encodeURIComponent(metaPixelId)}&ev=PageView&noscript=1`}
          alt=""
        />
      </noscript>
    )}

    <header class="public-header">
      <div class="public-container public-header-inner">
        <a class="public-brand" href="/" aria-label={`${site.siteName} home`}>
          {site.logoUrl && <img class="public-brand-logo" src={site.logoUrl} alt="" />}
          <span class="public-brand-name">{site.siteName}</span>
        </a>

        <details class="public-menu">
          <summary class="public-menu-trigger" aria-label="Open site menu">
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </summary>
          <div class="public-menu-panel">
            <a href="/privacy">Privacy</a>
            <a href="/disclaimer">Disclaimer</a>
          </div>
        </details>
      </div>
    </header>

    <main class="public-container public-main">
      <slot />
    </main>

    <ChannelNavigation channels={site.channels} activeChannel={activeChannel} />

    {showAdultGate && (
      <div class="adult-gate" data-adult-gate role="dialog" aria-modal="true" aria-labelledby="adult-gate-title">
        <div class="adult-gate-card">
          <div class="eyebrow">Age confirmation</div>
          <h2 id="adult-gate-title">Adults only</h2>
          <p>You must be at least 18 years old, or the legal age in your location, to enter this site.</p>
          <div class="adult-gate-actions">
            <button class="public-button" type="button" data-adult-accept>I am 18 or older</button>
            <button class="public-button secondary" type="button" data-adult-exit>Leave</button>
          </div>
        </div>
      </div>
    )}

    {showAdultGate && (
      <script is:inline>
        (() => {
          const gate = document.querySelector('[data-adult-gate]');
          const accept = document.querySelector('[data-adult-accept]');
          const exit = document.querySelector('[data-adult-exit]');
          if (!gate || !accept || !exit) return;
          if (!document.documentElement.classList.contains('adult-confirmed')) {
            document.documentElement.style.overflow = 'hidden';
          }
          accept.addEventListener('click', () => {
            const secure = location.protocol === 'https:' ? '; Secure' : '';
            document.cookie = `site_adult_confirmed=1; Max-Age=31536000; Path=/; SameSite=Lax${secure}`;
            document.documentElement.classList.add('adult-confirmed');
            gate.remove();
            document.documentElement.style.overflow = '';
          });
          exit.addEventListener('click', () => {
            if (history.length > 1) history.back();
            else location.replace('about:blank');
          });
        })();
      </script>
    )}
  </body>
</html>

<style is:global>
  .adult-confirmed .adult-gate { display: none; }

  .public-body {
    --public-font-display: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
    --public-font-ui: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-family: var(--public-font-ui);
    font-synthesis: none;
    letter-spacing: -.012em;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .public-body button,
  .public-body input,
  .public-body textarea,
  .public-body select,
  .public-body summary {
    font: inherit;
  }

  .public-brand-name,
  .public-section-heading h1,
  .public-section-heading h2,
  .visual-card-title,
  .product-detail-header h1,
  .product-body h1,
  .product-body h2,
  .public-empty h1,
  .public-empty h2,
  .adult-gate-card h2,
  .empty-icon {
    font-family: var(--public-font-display);
    font-variant-ligatures: common-ligatures contextual;
  }

  .public-brand-name {
    font-size: clamp(1.25rem, 4.3vw, 1.7rem);
    font-weight: 700;
    line-height: .92;
    letter-spacing: -.045em;
  }

  .public-section-heading h1,
  .public-section-heading h2,
  .product-detail-header h1,
  .public-empty h1,
  .public-empty h2,
  .adult-gate-card h2 {
    font-weight: 600;
    letter-spacing: -.04em;
  }

  .visual-card-title {
    font-weight: 600;
    letter-spacing: -.025em;
  }

  .public-search-form input,
  .public-button,
  .filter-button,
  .public-back-link,
  .public-nav-label,
  .eyebrow,
  .visual-tag,
  .visual-card-featured,
  .public-menu-panel a {
    font-family: var(--public-font-ui);
  }

  .public-button,
  .filter-button,
  .public-back-link,
  .public-nav-label,
  .eyebrow,
  .visual-card-featured {
    letter-spacing: .025em;
  }

  .public-search-form input {
    font-weight: 500;
  }

  .public-nav-label {
    font-weight: 700;
  }
</style>
