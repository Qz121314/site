---
import "@/styles/global.css";
import "@/styles/admin-workflow.css";
import { loadAdminChannels } from "@/lib/db/site";

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const channels = await loadAdminChannels();

const globalItems = [
  { href: "/admin", label: "概览", icon: "⌂" },
  { href: "/admin/settings", label: "站点设置", icon: "⚙" },
  { href: "/admin/channels", label: "分区管理", icon: "▦" },
  { href: "/admin/images", label: "图片库", icon: "◫" },
] as const;

const channelItems = [
  { segment: "products/new", label: "产品信息录入", icon: "＋", primary: true },
  { segment: "products", label: "产品列表管理", icon: "≡", primary: false },
  { segment: "filters", label: "分类筛选", icon: "⌁", primary: false },
  { segment: "ads", label: "Hero 广告", icon: "▣", primary: false },
  { segment: "conversions", label: "转化池", icon: "↗", primary: false },
] as const;

const isActive = (href: string) =>
  href === "/admin" ? pathname === href : pathname === href || pathname.startsWith(`${href}/`);

function isChannelItemActive(base: string, segment: string): boolean {
  const href = `${base}/${segment}`;
  if (segment === "products/new") return pathname === href;
  if (segment === "products") {
    return pathname === href || (pathname.startsWith(`${href}/`) && pathname !== `${href}/new`);
  }
  return pathname === href || pathname.startsWith(`${href}/`);
}

const statusLabels = {
  draft: "草稿",
  published: "已发布",
  disabled: "已停用",
} as const;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="color-scheme" content="dark" />
    <title>{title} · 管理后台</title>
  </head>
  <body class="admin-body">
    <div class="admin-frame">
      <aside class="admin-sidebar">
        <a class="admin-sidebar-brand" href="/admin" aria-label="管理后台首页">
          <span class="brand-mark" aria-hidden="true">◆</span>
          <span class="admin-sidebar-brand-text">管理后台</span>
        </a>

        <nav class="admin-sidebar-nav" aria-label="后台导航">
          <div class="admin-nav-section">
            <div class="admin-nav-section-label">全局管理</div>
            {globalItems.map(({ href, label, icon }) => (
              <a
                class="admin-sidebar-link"
                href={href}
                aria-current={isActive(href) ? "page" : undefined}
                title={label}
              >
                <span class="admin-sidebar-icon" aria-hidden="true">{icon}</span>
                <span class="admin-sidebar-label">{label}</span>
              </a>
            ))}
          </div>

          <div class="admin-nav-section admin-channel-section">
            <div class="admin-nav-section-label">分区内容</div>
            {channels.length === 0 ? (
              <a class="admin-empty-channels" href="/admin/channels" title="新增分区">
                <span class="admin-sidebar-icon" aria-hidden="true">＋</span>
                <span class="admin-sidebar-label">尚未创建分区</span>
              </a>
            ) : channels.map((channel) => {
              const base = `/admin/channels/${encodeURIComponent(channel.id)}`;
              const channelActive = pathname === base || pathname.startsWith(`${base}/`);

              return (
                <details class="admin-channel-group" open={channelActive}>
                  <summary class="admin-channel-summary" title={channel.name}>
                    <span class="admin-sidebar-icon admin-channel-glyph" aria-hidden="true">◇</span>
                    <span class="admin-sidebar-label admin-channel-name">{channel.name}</span>
                    <span class:list={["admin-channel-status", `is-${channel.status}`]} aria-hidden="true"></span>
                    <span class="admin-channel-state-label">{statusLabels[channel.status]}</span>
                    <span class="admin-channel-chevron" aria-hidden="true">›</span>
                  </summary>
                  <div class="admin-channel-subnav">
                    {channelItems.map(({ segment, label, icon, primary }) => {
                      const href = `${base}/${segment}`;
                      const active = isChannelItemActive(base, segment);
                      return (
                        <a
                          class:list={[
                            "admin-sidebar-link",
                            "admin-sidebar-sublink",
                            primary && "is-primary-action",
                          ]}
                          href={href}
                          aria-current={active ? "page" : undefined}
                          title={`${channel.name} · ${label}`}
                        >
                          <span class="admin-sidebar-icon" aria-hidden="true">{icon}</span>
                          <span class="admin-sidebar-label">{label}</span>
                        </a>
                      );
                    })}
                  </div>
                </details>
              );
            })}
          </div>
        </nav>

        <div class="admin-sidebar-footer">
          <a class="admin-sidebar-link" href="/" target="_blank" rel="noreferrer" title="查看前台">
            <span class="admin-sidebar-icon" aria-hidden="true">↗</span>
            <span class="admin-sidebar-label">查看前台</span>
          </a>
          <form action="/api/admin/logout" method="post">
            <button class="admin-sidebar-link admin-sidebar-button" type="submit" title="退出登录">
              <span class="admin-sidebar-icon" aria-hidden="true">×</span>
              <span class="admin-sidebar-label">退出登录</span>
            </button>
          </form>
        </div>
      </aside>

      <main class="admin-content">
        <header class="admin-page-header">
          <h1 class="admin-page-title">{title}</h1>
          <div class="admin-page-actions"><slot name="actions" /></div>
        </header>
        <div class="admin-page-body">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
