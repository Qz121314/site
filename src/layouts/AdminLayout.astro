---
import "@/styles/global.css";
import "@/styles/admin-workflow.css";
import "@/styles/admin-layout-v2.css";
import "@/styles/admin-collections.css";
import "@/styles/admin-collection-workspace.css";
import "@/styles/admin-popover.css";
import "@/styles/admin-premium.css";
import AdminIcon from "@/components/admin/AdminIcon.astro";
import { loadAdminChannels } from "@/lib/db/site";

interface Props {
  title: string;
  workspace?: "default" | "wide";
}

const { title, workspace = "default" } = Astro.props;
const pathname = Astro.url.pathname;
const partialRequest = Astro.request.headers.get("X-Admin-Partial") === "1";
const channels = partialRequest ? [] : await loadAdminChannels();
Astro.response.headers.set("Cache-Control", "private, no-store");

const globalItems = [
  { href: "/admin/settings", label: "站点设置", icon: "settings" },
  { href: "/admin/channels", label: "分区管理", icon: "channels" },
  { href: "/admin/images", label: "图片库", icon: "images" },
] as const;

const channelItems = [
  { segment: "products", label: "产品管理", icon: "products" },
  { segment: "filters", label: "分类筛选", icon: "filters" },
  { segment: "ads", label: "Hero 广告", icon: "ads" },
  { segment: "conversions", label: "转化池", icon: "conversions" },
] as const;

function isGlobalItemActive(href: string): boolean {
  if (href === "/admin/channels") {
    return pathname === href || /^\/admin\/channels\/[^/]+\/?$/u.test(pathname);
  }
  return pathname === href || pathname.startsWith(`${href}/`);
}

function isChannelItemActive(base: string, segment: string): boolean {
  const href = `${base}/${segment}`;
  return pathname === href || pathname.startsWith(`${href}/`);
}

const statusLabels = {
  draft: "草稿",
  published: "已发布",
  disabled: "已停用",
} as const;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="color-scheme" content="light" />
    <title>{title} · 管理后台</title>
  </head>
  <body class="admin-body">
    <div class="admin-route-progress" data-admin-route-progress hidden aria-hidden="true"></div>
    <div class="admin-frame">
      {!partialRequest && (
        <aside class="admin-sidebar">
          <a class="admin-sidebar-brand" href="/admin/channels" aria-label="进入分区管理">
            <span class="brand-mark" aria-hidden="true"><AdminIcon name="diamond" /></span>
            <span class="admin-sidebar-brand-text">管理后台</span>
          </a>

          <nav class="admin-sidebar-nav" aria-label="后台导航">
            <div class="admin-nav-section">
              <div class="admin-nav-section-label">全局管理</div>
              {globalItems.map(({ href, label, icon }) => (
                <a
                  class="admin-sidebar-link"
                  href={href}
                  aria-current={isGlobalItemActive(href) ? "page" : undefined}
                  title={label}
                >
                  <span class="admin-sidebar-icon" aria-hidden="true"><AdminIcon name={icon} /></span>
                  <span class="admin-sidebar-label">{label}</span>
                </a>
              ))}
            </div>

            <div class="admin-nav-section admin-channel-section">
              <div class="admin-nav-section-label">分区内容</div>
              {channels.length === 0 ? (
                <a class="admin-empty-channels" href="/admin/channels" title="新增分区">
                  <span class="admin-sidebar-icon" aria-hidden="true"><AdminIcon name="plus" /></span>
                  <span class="admin-sidebar-label">尚未创建分区</span>
                </a>
              ) : channels.map((channel) => {
                const base = `/admin/channels/${encodeURIComponent(channel.id)}`;
                const channelActive = pathname === base || pathname.startsWith(`${base}/`);
                const channelGlyph = channel.icon || channel.name.trim().slice(0, 1).toUpperCase() || "◇";

                return (
                  <details class="admin-channel-group" open={channelActive}>
                    <summary class="admin-channel-summary" title={channel.name}>
                      <span class="admin-sidebar-icon admin-channel-glyph" aria-hidden="true">{channelGlyph}</span>
                      <span class="admin-sidebar-label admin-channel-name">{channel.name}</span>
                      <span class:list={["admin-channel-status", `is-${channel.status}`]} aria-hidden="true"></span>
                      <span class="admin-channel-state-label">{statusLabels[channel.status]}</span>
                      <span class="admin-channel-chevron" aria-hidden="true"><AdminIcon name="chevron" /></span>
                    </summary>
                    <div class="admin-channel-subnav">
                      {channelItems.map(({ segment, label, icon }) => {
                        const href = `${base}/${segment}`;
                        const active = isChannelItemActive(base, segment);
                        return (
                          <a
                            class:list={["admin-sidebar-link", "admin-sidebar-sublink"]}
                            href={href}
                            aria-current={active ? "page" : undefined}
                            title={`${channel.name} · ${label}`}
                          >
                            <span class="admin-sidebar-icon" aria-hidden="true"><AdminIcon name={icon} /></span>
                            <span class="admin-sidebar-label">{label}</span>
                          </a>
                        );
                      })}
                    </div>
                  </details>
                );
              })}
            </div>
          </nav>

          <div class="admin-sidebar-footer">
            <a class="admin-sidebar-link" href="/" target="_blank" rel="noreferrer" title="查看前台">
              <span class="admin-sidebar-icon" aria-hidden="true"><AdminIcon name="external" /></span>
              <span class="admin-sidebar-label">查看前台</span>
            </a>
            <form action="/api/admin/logout" method="post">
              <button class="admin-sidebar-link admin-sidebar-button" type="submit" title="退出登录">
                <span class="admin-sidebar-icon" aria-hidden="true"><AdminIcon name="logout" /></span>
                <span class="admin-sidebar-label">退出登录</span>
              </button>
            </form>
          </div>
        </aside>
      )}

      <main class="admin-content">
        <header class="admin-page-header">
          <div class:list={["admin-page-header-inner", workspace === "wide" && "is-wide"]}>
            <h1 class="admin-page-title">{title}</h1>
            <div class="admin-page-actions"><slot name="actions" /></div>
          </div>
        </header>
        <div class="admin-page-body">
          <div class:list={["admin-page-body-inner", workspace === "wide" && "is-wide"]}>
            <slot />
          </div>
        </div>
      </main>
    </div>

    {!partialRequest && (
      <script>
        import "@/scripts/admin-router";
        import "@/scripts/admin-form-ui";
        import "@/scripts/admin-popover";
        import "@/scripts/admin-collection-workspace";
        import "@/scripts/admin-upload-guard";
      </script>
    )}
  </body>
</html>
