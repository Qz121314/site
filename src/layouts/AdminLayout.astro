---
import "@/styles/global.css";
import { loadAdminChannels } from "@/lib/db/site";

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const channels = await loadAdminChannels();

const globalItems = [
  { href: "/admin", label: "概览", shortLabel: "概" },
  { href: "/admin/settings", label: "站点设置", shortLabel: "站" },
  { href: "/admin/channels", label: "分区管理", shortLabel: "区" },
] as const;

const channelItems = [
  { segment: "", label: "分区设置", shortLabel: "设" },
  { segment: "filters", label: "分类筛选", shortLabel: "筛" },
  { segment: "categories", label: "分类管理", shortLabel: "类" },
  { segment: "products", label: "产品管理", shortLabel: "产" },
  { segment: "ads", label: "Hero 广告", shortLabel: "广" },
  { segment: "conversions", label: "转化池", shortLabel: "转" },
] as const;

const isActive = (href: string) =>
  href === "/admin" ? pathname === href : pathname === href || pathname.startsWith(`${href}/`);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="color-scheme" content="dark" />
    <title>{title} · 管理后台</title>
  </head>
  <body class="admin-body">
    <div class="admin-frame">
      <aside class="admin-sidebar">
        <a class="admin-sidebar-brand" href="/admin" aria-label="管理后台首页">
          <span class="brand-mark">S</span>
          <span class="admin-sidebar-brand-text">管理后台</span>
        </a>

        <nav class="admin-sidebar-nav" aria-label="后台导航">
          <div class="admin-nav-section">
            <div class="admin-nav-section-label">全局管理</div>
            {globalItems.map(({ href, label, shortLabel }) => (
              <a
                class="admin-sidebar-link"
                href={href}
                aria-current={isActive(href) ? "page" : undefined}
                title={label}
              >
                <span class="admin-sidebar-icon" aria-hidden="true">{shortLabel}</span>
                <span class="admin-sidebar-label">{label}</span>
              </a>
            ))}
          </div>

          <div class="admin-nav-section admin-channel-section">
            <div class="admin-nav-section-label">分区内容</div>
            {channels.length === 0 ? (
              <a class="admin-empty-channels" href="/admin/channels" title="新增分区">
                <span class="admin-sidebar-icon" aria-hidden="true">＋</span>
                <span class="admin-sidebar-label">尚未创建分区</span>
              </a>
            ) : channels.map((channel) => {
              const base = `/admin/channels/${encodeURIComponent(channel.id)}`;
              const channelActive = pathname === base || pathname.startsWith(`${base}/`);
              const channelMark = channel.icon.trim() || channel.name.trim().slice(0, 1) || "区";

              return (
                <details class="admin-channel-group" open={channelActive}>
                  <summary class:list={["admin-channel-summary", channelActive && "is-active"]} title={channel.name}>
                    <span class="admin-sidebar-icon" aria-hidden="true">{channelMark}</span>
                    <span class="admin-sidebar-label admin-channel-name">{channel.name}</span>
                    <span class:list={["admin-channel-status", `is-${channel.status}`]} aria-label={channel.status}></span>
                    <span class="admin-channel-chevron" aria-hidden="true">›</span>
                  </summary>
                  <div class="admin-channel-subnav">
                    {channelItems.map(({ segment, label, shortLabel }) => {
                      const href = segment ? `${base}/${segment}` : base;
                      return (
                        <a
                          class="admin-sidebar-link admin-sidebar-sublink"
                          href={href}
                          aria-current={pathname === href || pathname.startsWith(`${href}/`) ? "page" : undefined}
                          title={`${channel.name} · ${label}`}
                        >
                          <span class="admin-sidebar-icon" aria-hidden="true">{shortLabel}</span>
                          <span class="admin-sidebar-label">{label}</span>
                        </a>
                      );
                    })}
                  </div>
                </details>
              );
            })}
          </div>

          <div class="admin-nav-section admin-global-assets">
            <div class="admin-nav-section-label">全站资源</div>
            <a
              class="admin-sidebar-link"
              href="/admin/images"
              aria-current={isActive("/admin/images") ? "page" : undefined}
              title="图片库"
            >
              <span class="admin-sidebar-icon" aria-hidden="true">图</span>
              <span class="admin-sidebar-label">图片库</span>
            </a>
          </div>
        </nav>

        <div class="admin-sidebar-footer">
          <a class="admin-sidebar-link" href="/" target="_blank" rel="noreferrer" title="查看前台">
            <span class="admin-sidebar-icon" aria-hidden="true">前</span>
            <span class="admin-sidebar-label">查看前台</span>
          </a>
          <form action="/api/admin/logout" method="post">
            <button class="admin-sidebar-link admin-sidebar-button" type="submit" title="退出登录">
              <span class="admin-sidebar-icon" aria-hidden="true">退</span>
              <span class="admin-sidebar-label">退出登录</span>
            </button>
          </form>
        </div>
      </aside>

      <main class="admin-content">
        <header class="admin-page-header">
          <h1 class="admin-page-title">{title}</h1>
          <div class="admin-page-actions"><slot name="actions" /></div>
        </header>
        <div class="admin-page-body">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
