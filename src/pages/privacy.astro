---
import PublicLayout from "@/layouts/PublicLayout.astro";
import { loadPublicSiteShell } from "@/lib/db/public";

export const prerender = false;
const site = await loadPublicSiteShell();
const canonical = new URL("/privacy", Astro.url.origin).href;
---

<PublicLayout site={site} title="Privacy Policy" description={`Privacy policy for ${site.siteName}.`} canonical={canonical}>
  <section class="public-section">
    <div class="public-section-heading">
      <div>
        <div class="eyebrow">Information</div>
        <h1>Privacy Policy</h1>
      </div>
    </div>
    <div class="policy-card">{site.privacyContent || "No privacy policy has been published yet."}</div>
  </section>
</PublicLayout>
