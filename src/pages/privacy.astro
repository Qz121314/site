---
import PublicLayout from "@/layouts/PublicLayout.astro";
import { loadPublicSiteShell } from "@/lib/db/public";

export const prerender = false;
const site = await loadPublicSiteShell({ includeLegalContent: true });
const hasContent = site.privacyContent.trim().length > 0;
const canonical = hasContent ? new URL("/privacy", Astro.url.origin).href : null;
---

<PublicLayout
  site={site}
  title="Privacy Policy"
  description={`Privacy policy for ${site.siteName}.`}
  canonical={canonical}
  robots={hasContent ? undefined : "noindex,follow"}
  backHref="/"
>
  <section class="public-section">
    <div class="public-section-heading">
      <div>
        <div class="eyebrow">Information</div>
        <h1>Privacy Policy</h1>
      </div>
    </div>
    <div class="policy-card">{site.privacyContent || "No privacy policy has been published yet."}</div>
  </section>
</PublicLayout>
