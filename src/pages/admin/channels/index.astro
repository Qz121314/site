---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { loadAdminChannels } from "@/lib/db/site";

export const prerender = false;
const channels = await loadAdminChannels();
const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");

const savedMessages: Record<string, string> = {
  created: "分区已创建，左侧菜单已同步更新。",
  deleted: "分区已删除。",
};

const errorMessages: Record<string, string> = {
  name: "分区名称不能为空，且不能超过 80 个字符。",
  slug: "Slug 只能使用小写字母、数字和连字符。",
  icon: "图标内容过长，请使用一个简短字符或 Emoji。",
  sort: "排序必须是 -999999 到 999999 之间的整数。",
  status: "分区状态无效。",
  duplicate: "该 Slug 已被其他分区使用。",
  default: "默认分区不能删除，请先在站点设置中更换默认分区。",
  "in-use": "该分区仍有分类、产品、广告池或转化池，不能删除。",
  "not-found": "找不到要删除的分区。",
  database: "数据库操作失败，请稍后重试。",
};

const statusLabel = {
  draft: "草稿",
  published: "已发布",
  disabled: "已停用",
} as const;
---

<AdminLayout title="分区管理">
  {saved && savedMessages[saved] && <p class="notice" role="status">{savedMessages[saved]}</p>}
  {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

  <section class="admin-card">
    <div class="admin-section-bar">
      <h2>新增分区</h2>
      <span class="admin-section-note">保存后立即出现在左侧菜单</span>
    </div>
    <form class="admin-card-body admin-form-grid" action="/api/admin/channels/create" method="post">
      <div class="admin-field admin-span-3">
        <label for="channel-name">名称</label>
        <input id="channel-name" name="name" maxlength="80" required autocomplete="off" />
      </div>
      <div class="admin-field admin-span-3">
        <label for="channel-slug">Slug</label>
        <input id="channel-slug" name="slug" maxlength="64" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" required autocomplete="off" placeholder="example-channel" />
      </div>
      <div class="admin-field admin-span-1">
        <label for="channel-icon">图标</label>
        <input id="channel-icon" name="icon" maxlength="12" autocomplete="off" placeholder="A" />
      </div>
      <div class="admin-field admin-span-1">
        <label for="channel-sort">排序</label>
        <input id="channel-sort" name="sortOrder" type="number" min="-999999" max="999999" step="1" value="0" />
      </div>
      <div class="admin-field admin-span-2">
        <label for="channel-status">状态</label>
        <select id="channel-status" name="status">
          <option value="draft" selected>草稿</option>
          <option value="published">已发布</option>
          <option value="disabled">已停用</option>
        </select>
      </div>
      <div class="admin-form-actions admin-span-2">
        <button class="button" type="submit">新增分区</button>
      </div>
    </form>
  </section>

  <section class="admin-card">
    <div class="admin-toolbar">
      <h2>分区列表</h2>
      <span class="admin-section-note">共 {channels.length} 个</span>
    </div>
    {channels.length === 0 ? (
      <div class="admin-empty">尚未创建分区。</div>
    ) : (
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>图标</th>
              <th class="cell-grow">名称</th>
              <th>Slug</th>
              <th>排序</th>
              <th>状态</th>
              <th style="text-align:right">操作</th>
            </tr>
          </thead>
          <tbody>
            {channels.map((channel) => (
              <tr>
                <td>{channel.icon || "—"}</td>
                <td class="cell-grow"><strong>{channel.name}</strong></td>
                <td>/{channel.slug}</td>
                <td>{channel.sortOrder}</td>
                <td>{statusLabel[channel.status]}</td>
                <td>
                  <div class="admin-table-actions">
                    <a class="button secondary" href={`/admin/channels/${encodeURIComponent(channel.id)}`}>管理</a>
                    <form action={`/api/admin/channels/${encodeURIComponent(channel.id)}/delete`} method="post" onsubmit="return confirm('确定删除该分区？此操作不可撤销。')">
                      <button class="button danger" type="submit">删除</button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>
</AdminLayout>
