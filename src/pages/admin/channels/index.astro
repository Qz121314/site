---
import AdminDialog from "@/components/admin/AdminDialog.astro";
import AdminLayout from "@/layouts/AdminLayout.astro";
import { loadAdminChannels } from "@/lib/db/site";

export const prerender = false;
const channels = await loadAdminChannels();
const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");

const savedMessages: Record<string, string> = {
  created: "分区已创建，可以进入内容运营。",
  deleted: "分区已删除。",
};

const errorMessages: Record<string, string> = {
  name: "分区名称不能为空，且不能超过 80 个字符。",
  icon: "图标内容过长，请使用一个简短字符或 Emoji。",
  sort: "排序必须是 -999999 到 999999 之间的整数。",
  status: "分区状态无效。",
  default: "默认分区不能删除，请先在站点设置中更换默认分区。",
  "in-use": "该分区仍有分类、产品、广告池或转化池，不能删除。",
  "not-found": "找不到要删除的分区。",
  database: "数据库操作失败，请稍后重试。",
};

const statusLabel = {
  draft: "草稿",
  published: "已发布",
  disabled: "已停用",
} as const;
---

<AdminLayout title="分区管理">
  <button slot="actions" class="button" type="button" data-dialog-open="channel-create-dialog">新增分区</button>

  {saved && savedMessages[saved] && <p class="notice" role="status">{savedMessages[saved]}</p>}
  {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

  <AdminDialog id="channel-create-dialog" title="新增分区" size="medium">
    <form class="channel-create-form" action="/api/admin/channels/create" method="post">
      <div class="admin-field channel-name-field">
        <label for="channel-name">名称</label>
        <input id="channel-name" name="name" maxlength="80" required autocomplete="off" autofocus />
      </div>
      <div class="admin-field">
        <label for="channel-icon">前台图标</label>
        <input id="channel-icon" name="icon" maxlength="12" autocomplete="off" placeholder="◇" />
      </div>
      <div class="admin-field">
        <label for="channel-sort">排序</label>
        <input id="channel-sort" name="sortOrder" type="number" min="-999999" max="999999" step="1" value="0" />
      </div>
      <div class="admin-field">
        <label for="channel-status">状态</label>
        <select id="channel-status" name="status">
          <option value="draft" selected>草稿</option>
          <option value="published">已发布</option>
          <option value="disabled">已停用</option>
        </select>
      </div>
      <div class="dialog-actions">
        <button class="button secondary" type="button" data-dialog-close>取消</button>
        <button class="button" type="submit">创建分区</button>
      </div>
    </form>
  </AdminDialog>

  <section class="admin-card admin-collection-panel">
    <div class="admin-toolbar">
      <h2>分区</h2>
      <span class="admin-section-note">{channels.length} 个</span>
    </div>
    {channels.length === 0 ? (
      <div class="admin-collection-empty channel-empty">
        <strong>尚未创建分区</strong>
        <span>分区用于隔离产品、筛选、广告池和转化池。</span>
        <button class="button" type="button" data-dialog-open="channel-create-dialog">新增分区</button>
      </div>
    ) : (
      <div class="admin-entity-grid channel-grid">
        {channels.map((channel) => (
          <article class="admin-entity-card channel-card">
            <div class="admin-card-heading">
              <span class="admin-card-icon" aria-hidden="true">{channel.icon || "◇"}</span>
              <div class="admin-card-heading-text">
                <strong class="admin-entity-title" title={channel.name}>{channel.name}</strong>
                <span class="admin-entity-subtitle">/{channel.slug}</span>
              </div>
              <span class:list={["channel-state", `is-${channel.status}`]}>{statusLabel[channel.status]}</span>
            </div>
            <div class="admin-entity-actions">
              <a class="button" href={`/admin/channels/${encodeURIComponent(channel.id)}/products/new`}>运营</a>
              <a class="button secondary" href={`/admin/channels/${encodeURIComponent(channel.id)}`}>设置</a>
              <form action={`/api/admin/channels/${encodeURIComponent(channel.id)}/delete`} method="post" onsubmit="return confirm('确定删除该分区？此操作不可撤销。')">
                <button class="button danger" type="submit">删除</button>
              </form>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>
</AdminLayout>

<style>
  .channel-create-form { display: grid; grid-template-columns: minmax(0, 1fr) 8rem; gap: .6rem; align-items: end; }
  .channel-name-field { grid-column: 1 / -1; }
  .dialog-actions { grid-column: 1 / -1; display: flex; justify-content: flex-end; gap: .4rem; padding-top: .15rem; }
  .channel-card .admin-card-heading { min-height: 4rem; }
  .channel-state { margin-left: auto; border-radius: 999px; padding: .18rem .45rem; font-size: .65rem; white-space: nowrap; }
  .channel-state.is-published { color: #166534; background: #f0fdf4; }
  .channel-state.is-draft { color: #92400e; background: #fffbeb; }
  .channel-state.is-disabled { color: #991b1b; background: #fff1f2; }
  .channel-empty { display: grid; min-height: 14rem; place-items: center; align-content: center; gap: .55rem; }
  .channel-empty span { color: #64748b; }
  @media (max-width: 639px) {
    .channel-create-form { grid-template-columns: 1fr; }
    .channel-name-field, .dialog-actions { grid-column: auto; }
    .dialog-actions { display: grid; grid-template-columns: 1fr 1fr; }
  }
</style>
