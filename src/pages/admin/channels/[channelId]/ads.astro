---
import AdminLayout from "@/layouts/AdminLayout.astro";
import DirectImageUpload from "@/components/admin/DirectImageUpload.astro";
import { loadAdminAdPools } from "@/lib/db/ads";
import { loadAdminChannel } from "@/lib/db/site";

export const prerender = false;

const channelId = Astro.params.channelId ?? "";
const [channel, pools] = channelId
  ? await Promise.all([loadAdminChannel(channelId), loadAdminAdPools(channelId)])
  : [null, []];

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");
const focusedPool = Astro.url.searchParams.get("pool");

const savedMessages: Record<string, string> = {
  "pool-created": "Hero 广告池已创建。",
  "pool-updated": "Hero 广告池已更新。",
  "pool-deleted": "Hero 广告池及其中广告已删除。",
  bound: "当前分区已绑定该 Hero 广告池。",
  unbound: "当前分区已取消 Hero 广告池绑定。",
  "ad-created": "Hero 广告已新增。",
  "ad-updated": "Hero 广告已更新。",
  "ad-deleted": "Hero 广告已删除，R2 图片文件由图片库统一清理。",
};

const errorMessages: Record<string, string> = {
  name: "广告池名称不能为空，且不能超过 80 个字符。",
  image: "广告图片不存在，请重新上传。",
  url: "目标链接必须是有效的 HTTP 或 HTTPS 地址。",
  open: "打开方式无效。",
  sort: "排序必须是 -999999 到 999999 之间的整数。",
  status: "状态无效。",
  duplicate: "当前分区已经存在同名广告池。",
  "in-use": "该广告池正在被当前分区使用，请先取消绑定。",
  "not-found": "找不到该分区、广告池或广告。",
  database: "数据库操作失败，请稍后重试。",
};
---

<AdminLayout title={channel ? `${channel.name} · Hero 广告` : "分区不存在"}>
  {channel ? (
    <>
      {saved && savedMessages[saved] && <p class="notice" role="status">{savedMessages[saved]}</p>}
      {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

      <section class="admin-card ad-pool-create-card">
        <div class="admin-section-bar"><h2>新增广告池</h2></div>
        <form class="admin-card-body ad-pool-create-form" action={`/api/admin/channels/${encodeURIComponent(channelId)}/ads/pools/create`} method="post">
          <div class="admin-field">
            <label for="ad-pool-name">广告池名称</label>
            <input id="ad-pool-name" name="name" maxlength="80" required />
          </div>
          <div class="admin-field">
            <label for="ad-pool-status">状态</label>
            <select id="ad-pool-status" name="status">
              <option value="enabled" selected>启用</option>
              <option value="disabled">停用</option>
            </select>
          </div>
          <div class="admin-form-actions"><button class="button" type="submit">新增广告池</button></div>
        </form>
      </section>

      {pools.length === 0 ? (
        <section class="admin-card"><div class="admin-collection-empty">当前分区尚未创建 Hero 广告池。</div></section>
      ) : pools.map((pool) => {
        const createFormId = `ad-create-${pool.id}`;
        return (
          <details class:list={["admin-card", "ad-pool-card", pool.isBound && "is-bound"]} open={pool.isBound || focusedPool === pool.id}>
            <summary class="ad-pool-summary">
              <div>
                <strong>{pool.name}</strong>
                <span>{pool.advertisements.length} 条广告</span>
              </div>
              <div class="pool-badges">
                {pool.isBound && <span class="badge ok">当前使用</span>}
                <span class:list={["badge", pool.status === "enabled" ? "ok" : "warn"]}>{pool.status === "enabled" ? "启用" : "停用"}</span>
              </div>
            </summary>

            <div class="pool-body">
              <div class="pool-settings-row">
                <form class="pool-settings-form" action={`/api/admin/channels/${encodeURIComponent(channelId)}/ads/pools/${encodeURIComponent(pool.id)}/update`} method="post">
                  <div class="admin-field">
                    <label for={`pool-name-${pool.id}`}>广告池名称</label>
                    <input id={`pool-name-${pool.id}`} name="name" maxlength="80" required value={pool.name} />
                  </div>
                  <div class="admin-field">
                    <label for={`pool-status-${pool.id}`}>状态</label>
                    <select id={`pool-status-${pool.id}`} name="status">
                      <option value="enabled" selected={pool.status === "enabled"}>启用</option>
                      <option value="disabled" selected={pool.status === "disabled"}>停用</option>
                    </select>
                  </div>
                  <button class="button secondary" type="submit">保存</button>
                </form>

                <div class="pool-actions">
                  {pool.isBound ? (
                    <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/ads/unbind`} method="post">
                      <button class="button secondary" type="submit">取消绑定</button>
                    </form>
                  ) : (
                    <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/ads/pools/${encodeURIComponent(pool.id)}/bind`} method="post">
                      <button class="button" type="submit">设为当前 Hero</button>
                    </form>
                  )}
                  <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/ads/pools/${encodeURIComponent(pool.id)}/delete`} method="post" onsubmit="return confirm('确定删除整个广告池及其中所有广告？')">
                    <button class="button danger" type="submit" disabled={pool.isBound}>删除广告池</button>
                  </form>
                </div>
              </div>

              <section class="pool-ad-create">
                <div class="admin-section-bar compact-bar"><h3>新增广告</h3></div>
                <form id={createFormId} class="ad-create-form" action={`/api/admin/channels/${encodeURIComponent(channelId)}/ads/pools/${encodeURIComponent(pool.id)}/items/create`} method="post">
                  <DirectImageUpload id={`new-ad-image-${pool.id}`} name="imageAssetId" label="广告图片" form={createFormId} required compact />
                  <div class="admin-field ad-url-field">
                    <label for={`new-ad-url-${pool.id}`}>目标链接</label>
                    <input id={`new-ad-url-${pool.id}`} name="targetUrl" type="url" maxlength="2000" required placeholder="https://example.com/offer" />
                  </div>
                  <div class="admin-field">
                    <label for={`new-ad-open-${pool.id}`}>打开方式</label>
                    <select id={`new-ad-open-${pool.id}`} name="openMode">
                      <option value="same" selected>当前窗口</option>
                      <option value="new">新窗口</option>
                    </select>
                  </div>
                  <div class="admin-field">
                    <label for={`new-ad-sort-${pool.id}`}>排序</label>
                    <input id={`new-ad-sort-${pool.id}`} name="sortOrder" type="number" min="-999999" max="999999" step="1" value={pool.advertisements.length * 10} />
                  </div>
                  <div class="admin-field">
                    <label for={`new-ad-status-${pool.id}`}>状态</label>
                    <select id={`new-ad-status-${pool.id}`} name="status">
                      <option value="enabled" selected>启用</option>
                      <option value="disabled">停用</option>
                    </select>
                  </div>
                  <button class="button" type="submit">新增广告</button>
                </form>
              </section>

              {pool.advertisements.length > 0 ? (
                <div class="ad-list">
                  {pool.advertisements.map((ad) => {
                    const formId = `ad-edit-${ad.id}`;
                    return (
                      <article class="admin-entity-card ad-item">
                        <div class="ad-image-upload">
                          <DirectImageUpload id={`ad-image-${ad.id}`} form={formId} name="imageAssetId" label="广告图片" value={ad.imageAssetId} required compact />
                        </div>
                        <div class="ad-item-fields">
                          <div class="admin-field ad-url-field">
                            <label for={`ad-url-${ad.id}`}>目标链接</label>
                            <input id={`ad-url-${ad.id}`} form={formId} name="targetUrl" type="url" maxlength="2000" required value={ad.targetUrl} />
                          </div>
                          <div class="ad-compact-fields">
                            <div class="admin-field">
                              <label for={`ad-open-${ad.id}`}>打开</label>
                              <select id={`ad-open-${ad.id}`} form={formId} name="openMode">
                                <option value="same" selected={ad.openMode === "same"}>当前窗口</option>
                                <option value="new" selected={ad.openMode === "new"}>新窗口</option>
                              </select>
                            </div>
                            <div class="admin-field">
                              <label for={`ad-sort-${ad.id}`}>排序</label>
                              <input id={`ad-sort-${ad.id}`} form={formId} name="sortOrder" type="number" min="-999999" max="999999" step="1" value={ad.sortOrder} />
                            </div>
                            <div class="admin-field">
                              <label for={`ad-status-${ad.id}`}>状态</label>
                              <select id={`ad-status-${ad.id}`} form={formId} name="status">
                                <option value="enabled" selected={ad.status === "enabled"}>启用</option>
                                <option value="disabled" selected={ad.status === "disabled"}>停用</option>
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="admin-entity-actions ad-item-actions">
                          <form id={formId} action={`/api/admin/channels/${encodeURIComponent(channelId)}/ads/pools/${encodeURIComponent(pool.id)}/items/${encodeURIComponent(ad.id)}/update`} method="post">
                            <button class="button secondary" type="submit">保存</button>
                          </form>
                          <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/ads/pools/${encodeURIComponent(pool.id)}/items/${encodeURIComponent(ad.id)}/delete`} method="post" onsubmit="return confirm('确定删除这条 Hero 广告？')">
                            <button class="button danger" type="submit">删除</button>
                          </form>
                        </div>
                      </article>
                    );
                  })}
                </div>
              ) : (
                <div class="admin-collection-empty pool-empty">该广告池尚未添加广告。</div>
              )}
            </div>
          </details>
        );
      })}
    </>
  ) : (
    <section class="admin-card"><div class="admin-collection-empty">找不到该分区。</div></section>
  )}
</AdminLayout>

<style>
  .ad-pool-create-card { width: 100%; }
  .ad-pool-create-form { display: grid; grid-template-columns: minmax(15rem, 1fr) 8rem auto; gap: .5rem; align-items: end; }
  .ad-pool-card { overflow: hidden; }
  .ad-pool-card.is-bound { border-color: #93c5fd; }
  .ad-pool-summary { display: flex; min-height: 3rem; align-items: center; justify-content: space-between; gap: .75rem; padding: .55rem .7rem; cursor: pointer; list-style: none; background: #fbfdff; }
  .ad-pool-summary::-webkit-details-marker { display: none; }
  .ad-pool-summary > div:first-child { display: grid; gap: .1rem; }
  .ad-pool-summary strong { font-size: .86rem; }
  .ad-pool-summary span { color: #64748b; font-size: .68rem; }
  .pool-badges { display: flex; gap: .3rem; }
  .pool-body { border-top: 1px solid var(--admin-border); }
  .pool-settings-row { display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: end; gap: .65rem; padding: .6rem; border-bottom: 1px solid var(--admin-border); }
  .pool-settings-form { display: grid; grid-template-columns: minmax(13rem, 1fr) 7rem auto; gap: .4rem; align-items: end; min-width: 0; }
  .pool-actions { display: flex; flex-wrap: wrap; gap: .35rem; justify-content: flex-end; }
  .compact-bar { min-height: 2.3rem; }
  .compact-bar h3 { margin: 0; font-size: .82rem; }
  .ad-create-form { display: grid; grid-template-columns: minmax(12rem, .9fr) minmax(15rem, 1.4fr) 7rem 5rem 6rem auto; gap: .4rem; align-items: end; padding: .6rem; }
  .ad-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr)); gap: .6rem; padding: .6rem; border-top: 1px solid var(--admin-border); }
  .ad-item { align-content: start; padding-top: .6rem; }
  .ad-image-upload, .ad-item-fields { padding: 0 .6rem; }
  .ad-item-fields { display: grid; gap: .4rem; min-width: 0; }
  .ad-compact-fields { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .4rem; }
  .ad-item-actions { grid-template-columns: repeat(2, minmax(0, 1fr)); margin-top: .1rem; }
  .pool-empty { min-height: 6rem; border-top: 1px solid var(--admin-border); }
  .button:disabled { opacity: .38; cursor: not-allowed; }
  @media (max-width: 1050px) { .ad-create-form { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 820px) { .pool-settings-row { grid-template-columns: 1fr; } .pool-actions { justify-content: flex-start; } }
  @media (max-width: 639px) { .ad-pool-create-form, .pool-settings-form, .ad-create-form, .ad-compact-fields { grid-template-columns: 1fr; } .ad-list { grid-template-columns: 1fr; } }
</style>
