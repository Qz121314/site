---
import AdminLayout from "@/layouts/AdminLayout.astro";
import DirectImageUpload from "@/components/admin/DirectImageUpload.astro";
import { loadAdminChannel } from "@/lib/db/site";
import { loadAdminProductOptions } from "@/lib/db/products";

export const prerender = false;

const channelId = Astro.params.channelId ?? "";
const [channel, options] = channelId
  ? await Promise.all([loadAdminChannel(channelId), loadAdminProductOptions(channelId)])
  : [null, { categories: [], conversionGroups: [] }];

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");
const formId = "product-entry-form";

const errorMessages: Record<string, string> = {
  title: "产品标题不能为空，且不能超过 160 个字符。",
  slug: "Slug 只能使用小写字母、数字和连字符。",
  "category-name": "分类名称不能超过 80 个字符。",
  category: "所选分类无效或不属于当前分区。",
  "category-unavailable": "分类目录状态无效。",
  conversion: "所选转化组无效或不属于当前分区。",
  "conversion-required": "发布产品必须绑定转化组。",
  "conversion-unavailable": "发布产品时，转化组必须启用且至少包含一个启用资源。",
  image: "封面或图库图片不存在，请重新上传。",
  gallery: "产品图库最多 30 张，且图片选择必须有效。",
  tags: "标签最多 20 个，每个标签不能超过 40 个字符。",
  body: "正文不能超过 30000 个字符。",
  cta: "CTA 文案不能为空，且不能超过 80 个字符。",
  sort: "排序必须是 -999999 到 999999 之间的整数。",
  status: "产品状态无效。",
  duplicate: "当前分区内已经存在相同 Slug。",
  "not-found": "找不到当前分区。",
  database: "数据库保存失败，请稍后重试。",
};
---

<AdminLayout title={channel ? `${channel.name} · 产品信息录入` : "分区不存在"}>
  {channel ? (
    <>
      {saved === "created" && <p class="notice" role="status">产品已保存，可以继续录入下一个产品。</p>}
      {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

      <form
        id={formId}
        class="product-entry"
        action={`/api/admin/channels/${encodeURIComponent(channelId)}/products/create`}
        method="post"
      >
        <section class="admin-card">
          <div class="admin-section-bar">
            <div>
              <h2>基础信息</h2>
              <span class="admin-section-note">一次完成产品、分类目录、图片和转化配置</span>
            </div>
            <a class="button secondary" href={`/admin/channels/${encodeURIComponent(channelId)}/products`}>查看产品列表</a>
          </div>

          <div class="admin-card-body admin-form-grid">
            <div class="admin-field admin-span-5">
              <label for="product-title">产品名称</label>
              <input id="product-title" name="title" maxlength="160" required autocomplete="off" placeholder="Product title" data-product-title />
            </div>

            <div class="admin-field admin-span-3">
              <label for="product-slug">Slug</label>
              <input id="product-slug" name="slug" maxlength="96" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" required autocomplete="off" placeholder="product-slug" data-product-slug />
              <small>输入标题后自动生成，可手动修改。</small>
            </div>

            <div class="admin-field admin-span-2">
              <label for="product-status">发布状态</label>
              <select id="product-status" name="status">
                <option value="draft" selected>草稿</option>
                <option value="published">发布</option>
                <option value="disabled">停用</option>
              </select>
            </div>

            <div class="admin-field admin-span-2">
              <label for="product-sort">排序</label>
              <input id="product-sort" name="sortOrder" type="number" min="-999999" max="999999" step="1" value="0" />
            </div>

            <input type="hidden" name="categoryId" value="" />
            <div class="admin-field admin-span-4">
              <label for="product-category-name">产品分类</label>
              <input
                id="product-category-name"
                name="categoryName"
                maxlength="80"
                list="product-category-options"
                autocomplete="off"
                placeholder="选择已有分类或直接输入新分类"
              />
              <datalist id="product-category-options">
                {options.categories.map((category) => <option value={category.name}></option>)}
              </datalist>
              <small>不存在的分类会随产品自动创建；相同名称会复用现有分类目录。</small>
            </div>

            <div class="admin-field admin-span-4">
              <label for="product-conversion">转化组</label>
              <select id="product-conversion" name="conversionGroupId">
                <option value="">暂不绑定</option>
                {options.conversionGroups.map((group) => (
                  <option value={group.id}>
                    {group.name} · {group.status === "enabled" ? "启用" : "停用"} · {group.enabledResourceCount} 可用资源
                  </option>
                ))}
              </select>
              <small>发布状态必须绑定已启用且包含有效资源的转化组。</small>
            </div>

            <div class="admin-field admin-span-2">
              <label for="product-cta">CTA 文案</label>
              <input id="product-cta" name="ctaLabel" maxlength="80" required value="View Details" />
            </div>

            <div class="admin-field admin-span-2 compact-check-field">
              <label>推荐</label>
              <label class="compact-check"><input type="checkbox" name="featured" value="1" /> 置顶推荐</label>
            </div>

            <div class="admin-field admin-span-12">
              <label for="product-tags">产品标签</label>
              <input id="product-tags" name="tags" maxlength="1000" placeholder="tag-one, tag-two；最多 20 个" />
            </div>
          </div>
        </section>

        <section class="admin-card">
          <div class="admin-section-bar">
            <div>
              <h2>产品图片</h2>
              <span class="admin-section-note">图片在当前页面直接上传到 R2，无需先进入图片库</span>
            </div>
          </div>
          <div class="admin-card-body product-image-grid">
            <DirectImageUpload
              name="coverAssetId"
              label="产品封面"
              form={formId}
              help="用于目录卡片和详情页首图；新分类会自动使用首个产品封面作为目录图。"
            />
            <DirectImageUpload
              name="galleryAssetIds"
              label="产品图库"
              form={formId}
              multiple
              maxFiles={30}
              help="支持一次选择多张；移除只取消本产品绑定，未使用文件由图片库统一清理。"
            />
          </div>
        </section>

        <section class="admin-card">
          <div class="admin-section-bar">
            <h2>产品正文</h2>
            <span class="admin-section-note">支持标题、列表、粗体、斜体和 HTTPS 链接</span>
          </div>
          <div class="admin-card-body">
            <div class="admin-field">
              <label for="product-body">正文内容</label>
              <textarea id="product-body" name="bodySource" maxlength="30000" rows="14" placeholder="输入产品正文内容"></textarea>
            </div>
          </div>
        </section>

        <div class="product-entry-actions">
          <button class="button secondary" type="submit" name="submitAction" value="continue">保存并继续录入</button>
          <button class="button" type="submit" name="submitAction" value="save">保存产品</button>
        </div>
      </form>
    </>
  ) : (
    <section class="admin-card"><div class="admin-empty">找不到该分区。<a class="button secondary" href="/admin/channels">返回分区管理</a></div></section>
  )}
</AdminLayout>

<script is:inline>
  (() => {
    const title = document.querySelector('[data-product-title]');
    const slug = document.querySelector('[data-product-slug]');
    if (!title || !slug) return;
    let slugEdited = false;
    slug.addEventListener('input', () => { slugEdited = Boolean(slug.value); });
    title.addEventListener('input', () => {
      if (slugEdited) return;
      slug.value = title.value
        .normalize('NFKD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '')
        .slice(0, 96)
        .replace(/-+$/g, '');
    });
  })();
</script>

<style>
  .product-entry { display: grid; gap: .55rem; }
  .product-image-grid { display: grid; grid-template-columns: minmax(0, .8fr) minmax(0, 1.2fr); gap: .8rem; }
  .compact-check-field { justify-content: flex-end; }
  .compact-check { display: flex; min-height: 2.05rem; align-items: center; gap: .35rem; padding: 0 .45rem; border: 1px solid #302d36; border-radius: .3rem; background: #0d0c10; }
  .compact-check input { width: .95rem; height: .95rem; margin: 0; }
  textarea { min-height: 14rem; resize: vertical; }
  .product-entry-actions { position: sticky; z-index: 10; bottom: .5rem; display: flex; justify-content: flex-end; gap: .4rem; padding: .55rem; border: 1px solid var(--line); border-radius: .42rem; background: rgba(18,17,23,.94); backdrop-filter: blur(16px); }
  @media (max-width: 767px) {
    .product-image-grid { grid-template-columns: 1fr; }
    .product-entry-actions { bottom: .25rem; }
    .product-entry-actions .button { flex: 1; }
  }
</style>
