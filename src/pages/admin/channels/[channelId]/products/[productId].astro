---
import AdminLayout from "@/layouts/AdminLayout.astro";
import ProductEditorFields from "@/components/admin/ProductEditorFields.astro";
import { loadAdminProductImages } from "@/lib/db/product-images";
import { loadAdminProduct, loadAdminProductOptions } from "@/lib/db/products";
import { loadAdminChannel } from "@/lib/db/site";

export const prerender = false;

const channelId = Astro.params.channelId ?? "";
const productId = Astro.params.productId ?? "";
const [channel, product, options, gallery] = channelId && productId
  ? await Promise.all([
      loadAdminChannel(channelId),
      loadAdminProduct(channelId, productId),
      loadAdminProductOptions(channelId),
      loadAdminProductImages(channelId, productId),
    ])
  : [null, null, { categories: [], filters: [], conversionGroups: [] }, []];

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");
const formId = product ? `product-edit-${product.id}` : "product-edit";

const savedMessages: Record<string, string> = {
  created: "产品已新增。",
  updated: "产品已保存。",
};

const errorMessages: Record<string, string> = {
  title: "产品标题不能为空，且不能超过 160 个字符。",
  "category-name": "分类名称不能超过 80 个字符。",
  category: "所选分类无效或不属于当前分区。",
  "category-unavailable": "分类目录状态无效。",
  filters: "分类筛选选择无效。",
  "filter-category": "选择分类筛选前必须填写产品分类。",
  conversion: "所选转化组无效或不属于当前分区。",
  "conversion-required": "发布产品必须绑定转化组。",
  "conversion-unavailable": "发布产品时，转化组必须启用且至少包含一个启用资源。",
  image: "发布产品前至少需要保留一张有效图片。",
  gallery: "产品图片最多 30 张。",
  tags: "标签最多 20 个，每个标签不能超过 40 个字符。",
  body: "正文不能超过 30000 个字符。",
  cta: "CTA 文案不能为空，且不能超过 80 个字符。",
  sort: "排序必须是 -999999 到 999999 之间的整数。",
  status: "产品状态无效。",
  "not-found": "找不到该分区或产品。",
  database: "数据库保存失败，请稍后重试。",
};
---

<AdminLayout title={channel && product ? `${channel.name} · 编辑产品` : "产品不存在"}>
  {channel && product && (
    <div slot="actions" class="admin-page-action-group">
      {product.status === "published" && (
        <a class="button secondary" href={`/${encodeURIComponent(channel.slug)}/product/${encodeURIComponent(product.slug)}`} target="_blank" rel="noreferrer">前台</a>
      )}
      <a class="button secondary" href={`/admin/channels/${encodeURIComponent(channelId)}/products`}>产品列表</a>
      <a class="button secondary" href={`/admin/channels/${encodeURIComponent(channelId)}/products/new`}>录入新产品</a>
      <button class="button" type="submit" form={formId}>保存</button>
    </div>
  )}

  {channel && product ? (
    <>
      {saved && savedMessages[saved] && <p class="notice" role="status">{savedMessages[saved]}</p>}
      {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

      <form
        id={formId}
        class="product-entry"
        action={`/api/admin/channels/${encodeURIComponent(channelId)}/products/${encodeURIComponent(product.id)}/update`}
        method="post"
        data-admin-dirty-form
      >
        <ProductEditorFields
          formId={formId}
          channelId={channelId}
          options={options}
          product={product}
          gallery={gallery.map((image) => ({
            id: image.imageAssetId,
            previewUrl: image.previewUrl,
            name: image.originalName,
            meta: `${image.width}×${image.height}`,
          }))}
        />
      </form>
    </>
  ) : (
    <section class="admin-card"><div class="admin-collection-empty">找不到该产品。</div></section>
  )}
</AdminLayout>
