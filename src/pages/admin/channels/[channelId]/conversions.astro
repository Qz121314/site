---
import AdminCollectionWorkspace from "@/components/admin/AdminCollectionWorkspace.astro";
import AdminDialog from "@/components/admin/AdminDialog.astro";
import AdminLayout from "@/layouts/AdminLayout.astro";
import { loadAdminChannel } from "@/lib/db/site";
import { loadAdminConversionGroups } from "@/lib/db/conversions";

export const prerender = false;

const channelId = Astro.params.channelId ?? "";
const [channel, groups] = channelId
  ? await Promise.all([loadAdminChannel(channelId), loadAdminConversionGroups(channelId)])
  : [null, []];

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");
const requestedGroupId = Astro.url.searchParams.get("group");
const selectedGroupId = groups.some((group) => group.id === requestedGroupId)
  ? requestedGroupId
  : groups[0]?.id ?? null;

const savedMessages: Record<string, string> = {
  "group-created": "转化分组已新增。",
  "group-updated": "转化分组已更新。",
  "group-deleted": "转化分组已删除。",
  "resource-created": "CTA 已新增。",
  "resource-updated": "CTA 已更新。",
  "resource-deleted": "CTA 已删除。",
};

const errorMessages: Record<string, string> = {
  "group-name": "分组名称不能为空，且不能超过 80 个字符。",
  "group-status": "分组状态无效。",
  "group-duplicate": "当前分区内已经存在同名转化分组。",
  "group-in-use": "仍有产品绑定该转化分组，不能删除。",
  "resource-type": "CTA 类型无效。",
  "resource-value": "号码格式无效，或链接不是完整的 HTTP、HTTPS、mailto 地址。",
  "resource-sort": "排序值无效。",
  "resource-status": "CTA 状态无效。",
  "not-found": "找不到该分区、转化分组或 CTA。",
  database: "数据库操作失败，请稍后重试。",
};

const groupCreateAction = `/api/admin/channels/${encodeURIComponent(channelId)}/conversions/create`;
---

<AdminLayout title={channel ? `${channel.name} · 转化池` : "分区不存在"}>
  {channel ? (
    <div class="admin-stack">
      {saved && savedMessages[saved] && <p class="notice" role="status">{savedMessages[saved]}</p>}
      {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

      <AdminCollectionWorkspace
        searchId="conversion-group-search"
        searchPlaceholder="搜索分组"
        createDialogId="conversion-group-create-dialog"
        createLabel="新增分组"
        listLabel="转化分组列表"
        selectionParam="group"
      >
        <Fragment slot="items">
          {groups.map((group) => {
            const updateAction = `/api/admin/channels/${encodeURIComponent(channelId)}/conversions/${encodeURIComponent(group.id)}/update`;
            const deleteAction = `/api/admin/channels/${encodeURIComponent(channelId)}/conversions/${encodeURIComponent(group.id)}/delete`;
            return (
              <div
                class:list={["admin-collection-row", group.id === selectedGroupId && "is-active"]}
                role="listitem"
                data-collection-item={group.id}
                data-search-text={group.name}
              >
                <button class="admin-collection-select" type="button" data-collection-select aria-current={group.id === selectedGroupId ? "true" : "false"}>
                  <strong>{group.name}</strong>
                </button>
                <div class="admin-collection-row-actions">
                  <button
                    class="button secondary"
                    type="button"
                    data-dialog-open="conversion-group-edit-dialog"
                    data-record-dialog="conversion-group-edit-dialog"
                    data-record-title={`编辑分组 · ${group.name}`}
                    data-record-action={updateAction}
                    data-record-name={group.name}
                    data-record-status={group.status}
                  >编辑</button>
                  <form action={deleteAction} method="post" onsubmit="return confirm('确定删除该转化分组及其中全部 CTA？')">
                    <button
                      class="button danger"
                      type="submit"
                      disabled={group.productCount > 0}
                      title={group.productCount > 0 ? "仍有产品绑定该分组，不能删除" : undefined}
                    >删除</button>
                  </form>
                </div>
              </div>
            );
          })}
        </Fragment>

        {groups.length === 0 ? (
          <section class="admin-card admin-record-empty">尚未创建转化分组。</section>
        ) : groups.map((group) => {
          const createResourceAction = `/api/admin/channels/${encodeURIComponent(channelId)}/conversions/${encodeURIComponent(group.id)}/resources/create`;
          return (
            <section
              class="admin-card admin-collection-panel"
              data-collection-panel={group.id}
              hidden={group.id !== selectedGroupId}
            >
              <header class="admin-collection-panel-header">
                <div class="admin-collection-panel-title"><h2>{group.name}</h2></div>
                <div class="admin-collection-panel-actions">
                  <button
                    class="button"
                    type="button"
                    data-dialog-open="conversion-resource-create-dialog"
                    data-record-dialog="conversion-resource-create-dialog"
                    data-record-title={`添加 CTA · ${group.name}`}
                    data-record-action={createResourceAction}
                    data-record-sort-order={String(group.resources.length * 10)}
                    data-record-status="enabled"
                    data-record-type="sms"
                  >添加 CTA</button>
                </div>
              </header>

              {group.resources.length === 0 ? (
                <div class="admin-record-empty">该分组尚未添加 CTA。</div>
              ) : (
                <div class="admin-record-list">
                  {group.resources.map((resource) => {
                    const updateAction = `/api/admin/channels/${encodeURIComponent(channelId)}/conversions/${encodeURIComponent(group.id)}/resources/${encodeURIComponent(resource.id)}/update`;
                    const deleteAction = `/api/admin/channels/${encodeURIComponent(channelId)}/conversions/${encodeURIComponent(group.id)}/resources/${encodeURIComponent(resource.id)}/delete`;
                    const typeLabel = resource.type === "sms" ? "号码" : "链接";
                    return (
                      <article class="admin-record-row">
                        <div class="admin-record-main">
                          <strong title={resource.value}>{resource.value}</strong>
                          <span class="admin-record-meta">{typeLabel}{resource.status === "disabled" ? " · 已停用" : ""}</span>
                        </div>
                        <div class="admin-record-actions">
                          <button
                            class="button secondary"
                            type="button"
                            data-dialog-open="conversion-resource-edit-dialog"
                            data-record-dialog="conversion-resource-edit-dialog"
                            data-record-title={`编辑 CTA · ${group.name}`}
                            data-record-action={updateAction}
                            data-record-type={resource.type}
                            data-record-value={resource.value}
                            data-record-sort-order={String(resource.sortOrder)}
                            data-record-status={resource.status}
                          >编辑</button>
                          <form action={deleteAction} method="post" onsubmit="return confirm('确定删除该 CTA？')">
                            <button class="button danger" type="submit">删除</button>
                          </form>
                        </div>
                      </article>
                    );
                  })}
                </div>
              )}
            </section>
          );
        })}
      </AdminCollectionWorkspace>

      <AdminDialog id="conversion-group-create-dialog" title="新增转化分组" size="small">
        <form class="admin-dialog-form" action={groupCreateAction} method="post">
          <div class="admin-field">
            <label for="conversion-group-create-name">分组名称</label>
            <input id="conversion-group-create-name" name="name" maxlength="80" required autocomplete="off" autofocus />
          </div>
          <div class="admin-field">
            <label for="conversion-group-create-status">状态</label>
            <select id="conversion-group-create-status" name="status">
              <option value="enabled" selected>启用</option>
              <option value="disabled">停用</option>
            </select>
          </div>
          <div class="admin-dialog-actions">
            <button class="button secondary" type="button" data-dialog-close>取消</button>
            <button class="button" type="submit">保存</button>
          </div>
        </form>
      </AdminDialog>

      <AdminDialog id="conversion-group-edit-dialog" title="编辑转化分组" size="small">
        <form class="admin-dialog-form" method="post" data-record-form>
          <div class="admin-field">
            <label for="conversion-group-edit-name">分组名称</label>
            <input id="conversion-group-edit-name" name="name" maxlength="80" required autocomplete="off" autofocus />
          </div>
          <div class="admin-field">
            <label for="conversion-group-edit-status">状态</label>
            <select id="conversion-group-edit-status" name="status">
              <option value="enabled">启用</option>
              <option value="disabled">停用</option>
            </select>
          </div>
          <div class="admin-dialog-actions">
            <button class="button secondary" type="button" data-dialog-close>取消</button>
            <button class="button" type="submit">保存</button>
          </div>
        </form>
      </AdminDialog>

      <AdminDialog id="conversion-resource-create-dialog" title="添加 CTA" size="medium">
        <form class="admin-dialog-form" method="post" data-record-form>
          <div class="admin-dialog-form-grid">
            <div class="admin-field">
              <label for="conversion-resource-create-type">类型</label>
              <select id="conversion-resource-create-type" name="type">
                <option value="sms">号码</option>
                <option value="link">链接</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="conversion-resource-create-status">状态</label>
              <select id="conversion-resource-create-status" name="status">
                <option value="enabled">启用</option>
                <option value="disabled">停用</option>
              </select>
            </div>
            <div class="admin-field is-wide">
              <label for="conversion-resource-create-value">号码或链接</label>
              <input id="conversion-resource-create-value" name="value" maxlength="2048" required autocomplete="off" autofocus />
            </div>
          </div>
          <input type="hidden" name="sortOrder" value="0" />
          <div class="admin-dialog-actions">
            <button class="button secondary" type="button" data-dialog-close>取消</button>
            <button class="button" type="submit">保存</button>
          </div>
        </form>
      </AdminDialog>

      <AdminDialog id="conversion-resource-edit-dialog" title="编辑 CTA" size="medium">
        <form class="admin-dialog-form" method="post" data-record-form>
          <div class="admin-dialog-form-grid">
            <div class="admin-field">
              <label for="conversion-resource-edit-type">类型</label>
              <select id="conversion-resource-edit-type" name="type">
                <option value="sms">号码</option>
                <option value="link">链接</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="conversion-resource-edit-status">状态</label>
              <select id="conversion-resource-edit-status" name="status">
                <option value="enabled">启用</option>
                <option value="disabled">停用</option>
              </select>
            </div>
            <div class="admin-field is-wide">
              <label for="conversion-resource-edit-value">号码或链接</label>
              <input id="conversion-resource-edit-value" name="value" maxlength="2048" required autocomplete="off" autofocus />
            </div>
          </div>
          <input type="hidden" name="sortOrder" value="0" />
          <div class="admin-dialog-actions">
            <button class="button secondary" type="button" data-dialog-close>取消</button>
            <button class="button" type="submit">保存</button>
          </div>
        </form>
      </AdminDialog>
    </div>
  ) : (
    <section class="admin-card"><div class="admin-record-empty">找不到该分区。</div></section>
  )}
</AdminLayout>
