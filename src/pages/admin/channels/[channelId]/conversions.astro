---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { loadAdminChannel } from "@/lib/db/site";
import { loadAdminConversionGroups } from "@/lib/db/conversions";

export const prerender = false;

const channelId = Astro.params.channelId ?? "";
const [channel, groups] = channelId
  ? await Promise.all([loadAdminChannel(channelId), loadAdminConversionGroups(channelId)])
  : [null, []];

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");
const openGroupId = Astro.url.searchParams.get("group");

const savedMessages: Record<string, string> = {
  "group-created": "转化组已新增。",
  "group-updated": "转化组已更新。",
  "group-deleted": "转化组及其资源已删除。",
  "resource-created": "联系方式已新增。",
  "resource-updated": "联系方式已更新。",
  "resource-deleted": "联系方式已删除。",
};

const errorMessages: Record<string, string> = {
  "group-name": "转化组名称不能为空，且不能超过 80 个字符。",
  "group-status": "转化组状态无效。",
  "group-duplicate": "当前分区内已经存在同名转化组。",
  "group-in-use": "仍有产品绑定该转化组，不能删除。",
  "resource-type": "联系方式类型无效。",
  "resource-value": "短信请填写电话号码；链接请填写完整的 HTTP、HTTPS 或 mailto 地址。",
  "resource-sort": "排序必须是 -999999 到 999999 之间的整数。",
  "resource-status": "联系方式状态无效。",
  "not-found": "找不到该分区、转化组或联系方式。",
  database: "数据库操作失败，请稍后重试。",
};
---

<AdminLayout title={channel ? `${channel.name} · 转化池` : "分区不存在"}>
  {channel ? (
    <>
      {saved && savedMessages[saved] && <p class="notice" role="status">{savedMessages[saved]}</p>}
      {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

      <section class="admin-card conversion-create-card">
        <div class="admin-section-bar"><h2>新增转化组</h2></div>
        <form class="admin-card-body conversion-create-form" action={`/api/admin/channels/${encodeURIComponent(channelId)}/conversions/create`} method="post">
          <div class="admin-field conversion-name-field">
            <label for="conversion-group-name">名称</label>
            <input id="conversion-group-name" name="name" maxlength="80" required autocomplete="off" />
          </div>
          <div class="admin-field">
            <label for="conversion-group-status">状态</label>
            <select id="conversion-group-status" name="status">
              <option value="enabled" selected>启用</option>
              <option value="disabled">停用</option>
            </select>
          </div>
          <div class="admin-form-actions"><button class="button" type="submit">新增转化组</button></div>
        </form>
      </section>

      {groups.length === 0 ? (
        <section class="admin-card"><div class="admin-collection-empty">尚未创建转化组。</div></section>
      ) : (
        <section class="conversion-list">
          {groups.map((group) => {
            const groupFormId = `conversion-group-${group.id}`;
            return (
              <section class="admin-card conversion-group">
                <form id={groupFormId} action={`/api/admin/channels/${encodeURIComponent(channelId)}/conversions/${encodeURIComponent(group.id)}/update`} method="post"></form>
                <div class="group-editor">
                  <div class="admin-field group-name">
                    <label for={`group-name-${group.id}`}>组名</label>
                    <input id={`group-name-${group.id}`} form={groupFormId} name="name" maxlength="80" required value={group.name} />
                  </div>
                  <div class="admin-field">
                    <label for={`group-status-${group.id}`}>状态</label>
                    <select id={`group-status-${group.id}`} form={groupFormId} name="status">
                      <option value="enabled" selected={group.status === "enabled"}>启用</option>
                      <option value="disabled" selected={group.status === "disabled"}>停用</option>
                    </select>
                  </div>
                  <div class="group-stat"><span>可用</span><strong>{group.enabledResourceCount}/{group.resourceCount}</strong></div>
                  <div class="group-stat"><span>产品</span><strong>{group.productCount}</strong></div>
                  <div class="group-actions">
                    <button class="button secondary" type="submit" form={groupFormId}>保存</button>
                    <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/conversions/${encodeURIComponent(group.id)}/delete`} method="post" onsubmit="return confirm('确定删除该转化组及其全部联系方式？')">
                      <button class="button danger" type="submit" disabled={group.productCount > 0}>删除</button>
                    </form>
                  </div>
                </div>

                <details class="resource-panel" open={openGroupId === group.id || group.resources.length === 0}>
                  <summary><strong>联系方式</strong><span>{group.resources.length} 个</span></summary>
                  <form class="resource-create-form" action={`/api/admin/channels/${encodeURIComponent(channelId)}/conversions/${encodeURIComponent(group.id)}/resources/create`} method="post">
                    <div class="admin-field">
                      <label for={`new-resource-type-${group.id}`}>类型</label>
                      <select id={`new-resource-type-${group.id}`} name="type">
                        <option value="sms">短信</option>
                        <option value="link">链接</option>
                      </select>
                    </div>
                    <div class="admin-field resource-value-field">
                      <label for={`new-resource-value-${group.id}`}>号码或链接</label>
                      <input id={`new-resource-value-${group.id}`} name="value" maxlength="2048" required autocomplete="off" placeholder="号码或 https://..." />
                    </div>
                    <div class="admin-field">
                      <label for={`new-resource-sort-${group.id}`}>排序</label>
                      <input id={`new-resource-sort-${group.id}`} name="sortOrder" type="number" min="-999999" max="999999" step="1" value="0" />
                    </div>
                    <div class="admin-field">
                      <label for={`new-resource-status-${group.id}`}>状态</label>
                      <select id={`new-resource-status-${group.id}`} name="status">
                        <option value="enabled" selected>启用</option>
                        <option value="disabled">停用</option>
                      </select>
                    </div>
                    <div class="admin-form-actions"><button class="button" type="submit">新增</button></div>
                  </form>

                  {group.resources.length === 0 ? (
                    <div class="admin-collection-empty resource-empty">尚无联系方式。</div>
                  ) : (
                    <div class="resource-grid">
                      {group.resources.map((resource) => {
                        const resourceFormId = `conversion-resource-${resource.id}`;
                        return (
                          <article class="admin-entity-card resource-card">
                            <form id={resourceFormId} class="admin-inline-card-form" action={`/api/admin/channels/${encodeURIComponent(channelId)}/conversions/${encodeURIComponent(group.id)}/resources/${encodeURIComponent(resource.id)}/update`} method="post">
                              <div class="admin-field">
                                <label for={`resource-value-${resource.id}`}>号码或链接</label>
                                <input id={`resource-value-${resource.id}`} name="value" maxlength="2048" required value={resource.value} />
                              </div>
                              <div class="resource-card-fields">
                                <div class="admin-field">
                                  <label for={`resource-type-${resource.id}`}>类型</label>
                                  <select id={`resource-type-${resource.id}`} name="type">
                                    <option value="sms" selected={resource.type === "sms"}>短信</option>
                                    <option value="link" selected={resource.type === "link"}>链接</option>
                                  </select>
                                </div>
                                <div class="admin-field">
                                  <label for={`resource-sort-${resource.id}`}>排序</label>
                                  <input id={`resource-sort-${resource.id}`} name="sortOrder" type="number" min="-999999" max="999999" step="1" value={resource.sortOrder} />
                                </div>
                                <div class="admin-field">
                                  <label for={`resource-status-${resource.id}`}>状态</label>
                                  <select id={`resource-status-${resource.id}`} name="status">
                                    <option value="enabled" selected={resource.status === "enabled"}>启用</option>
                                    <option value="disabled" selected={resource.status === "disabled"}>停用</option>
                                  </select>
                                </div>
                              </div>
                            </form>
                            <div class="admin-entity-actions">
                              <button class="button secondary" type="submit" form={resourceFormId}>保存</button>
                              <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/conversions/${encodeURIComponent(group.id)}/resources/${encodeURIComponent(resource.id)}/delete`} method="post" onsubmit="return confirm('确定删除该联系方式？')">
                                <button class="button danger" type="submit">删除</button>
                              </form>
                            </div>
                          </article>
                        );
                      })}
                    </div>
                  )}
                </details>
              </section>
            );
          })}
        </section>
      )}
    </>
  ) : <section class="admin-card"><div class="admin-collection-empty">找不到该分区。</div></section>}
</AdminLayout>

<style>
  .conversion-create-card { width: 100%; }
  .conversion-create-form { display: grid; grid-template-columns: minmax(15rem, 1fr) 8rem auto; align-items: end; gap: .55rem; }
  .conversion-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(30rem, 1fr)); gap: .7rem; }
  .conversion-group { overflow: hidden; }
  .group-editor { display: grid; grid-template-columns: minmax(12rem,1fr) 7rem 3.5rem 3.5rem auto; align-items: end; gap: .45rem; padding: .6rem; }
  .group-stat { display: grid; min-height: 2.15rem; align-content: center; gap: .05rem; }
  .group-stat span, .resource-panel summary span { color: var(--muted); font-size: .67rem; }
  .group-stat strong { font-size: .78rem; }
  .group-actions { display: flex; gap: .3rem; justify-content: flex-end; }
  .resource-panel { border-top: 1px solid var(--admin-border); }
  .resource-panel > summary { display: flex; min-height: 2.45rem; align-items: center; justify-content: space-between; padding: .45rem .65rem; cursor: pointer; background: #fbfdff; }
  .resource-create-form { display: grid; grid-template-columns: 6rem minmax(12rem, 1fr) 5rem 6rem auto; align-items: end; gap: .4rem; padding: .6rem; border-top: 1px solid var(--admin-border); border-bottom: 1px solid var(--admin-border); }
  .resource-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr)); gap: .5rem; padding: .6rem; }
  .resource-card-fields { display: grid; grid-template-columns: 6rem 5rem 6rem; gap: .35rem; }
  .resource-empty { min-height: 5rem; }
  @media (max-width: 1100px) { .conversion-list { grid-template-columns: 1fr; } }
  @media (max-width: 820px) {
    .conversion-create-form { grid-template-columns: 1fr 8rem auto; }
    .group-editor { grid-template-columns: minmax(0, 1fr) 8rem repeat(2, 4rem); }
    .group-actions { grid-column: 1 / -1; justify-content: flex-start; }
    .resource-create-form { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .resource-value-field { grid-column: 1 / -1; }
  }
  @media (max-width: 639px) { .conversion-create-form, .group-editor, .resource-create-form, .resource-card-fields { grid-template-columns: 1fr; } .group-actions, .resource-value-field { grid-column: auto; } .conversion-list { display: block; } .conversion-group + .conversion-group { margin-top: .7rem; } }
</style>
