---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { loadAdminProductThumbnails } from "@/lib/db/product-thumbnails";
import { loadAdminChannel } from "@/lib/db/site";
import { loadAdminProductOptions, loadAdminProducts } from "@/lib/db/products";
import { buildPublicImageUrl } from "@/lib/images/url";

export const prerender = false;

const channelId = Astro.params.channelId ?? "";
const query = (Astro.url.searchParams.get("q") ?? "").slice(0, 100);
const status = Astro.url.searchParams.get("status") ?? "";
const categoryId = Astro.url.searchParams.get("category") ?? "";
const pageValue = Number(Astro.url.searchParams.get("page") ?? "1");

const [channel, options, productPage] = channelId
  ? await Promise.all([
      loadAdminChannel(channelId),
      loadAdminProductOptions(channelId),
      loadAdminProducts(channelId, {
        query,
        status,
        categoryId,
        page: Number.isSafeInteger(pageValue) ? pageValue : 1,
      }),
    ])
  : [null, { categories: [], filters: [], conversionGroups: [] }, { products: [], total: 0, page: 1, pageCount: 1, pageSize: 50 }];

const thumbnailData = await loadAdminProductThumbnails(productPage.products.map((product) => product.id));
const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");

const savedMessages: Record<string, string> = { deleted: "产品已删除。" };
const errorMessages: Record<string, string> = {
  "not-found": "找不到该分区或产品。",
  database: "数据库操作失败，请稍后重试。",
};

const statusLabels = {
  draft: "草稿",
  published: "已发布",
  disabled: "已停用",
} as const;

function pageHref(page: number): string {
  const params = new URLSearchParams();
  if (query) params.set("q", query);
  if (status) params.set("status", status);
  if (categoryId) params.set("category", categoryId);
  if (page > 1) params.set("page", String(page));
  const suffix = params.toString();
  return `/admin/channels/${encodeURIComponent(channelId)}/products${suffix ? `?${suffix}` : ""}`;
}
---

<AdminLayout title={channel ? `${channel.name} · 产品列表管理` : "分区不存在"}>
  {channel && <a slot="actions" class="button" href={`/admin/channels/${encodeURIComponent(channelId)}/products/new`}>录入新产品</a>}

  {channel ? (
    <>
      {saved && savedMessages[saved] && <p class="notice" role="status">{savedMessages[saved]}</p>}
      {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

      <section class="admin-card admin-filter-panel">
        <form class="admin-filter-form" method="get">
          <div class="admin-field admin-search-field">
            <label for="product-search">搜索</label>
            <input id="product-search" name="q" value={query} maxlength="100" autocomplete="off" placeholder="产品名称或标签" />
          </div>
          <div class="admin-field">
            <label for="product-status-filter">状态</label>
            <select id="product-status-filter" name="status">
              <option value="">全部状态</option>
              <option value="draft" selected={status === "draft"}>草稿</option>
              <option value="published" selected={status === "published"}>发布</option>
              <option value="disabled" selected={status === "disabled"}>停用</option>
            </select>
          </div>
          <div class="admin-field">
            <label for="product-category-filter">分类</label>
            <select id="product-category-filter" name="category">
              <option value="">全部分类</option>
              {options.categories.map((category) => (
                <option value={category.id} selected={categoryId === category.id}>{category.name}</option>
              ))}
            </select>
          </div>
          <div class="admin-filter-actions">
            <button class="button" type="submit">筛选</button>
            <a class="button secondary" href={`/admin/channels/${encodeURIComponent(channelId)}/products`}>重置</a>
          </div>
        </form>
      </section>

      <section class="admin-card admin-collection-panel">
        <div class="admin-toolbar">
          <h2>产品</h2>
          <span class="admin-section-note">{productPage.total} 个</span>
        </div>

        {productPage.products.length === 0 ? (
          <div class="admin-collection-empty">没有符合条件的产品。</div>
        ) : (
          <div class="admin-entity-grid">
            {productPage.products.map((product) => {
              const objectKey = thumbnailData.objectKeyByProductId.get(product.id) ?? "";
              const thumbnailUrl = buildPublicImageUrl(thumbnailData.r2PublicBaseUrl, objectKey)
                ?? (product.coverAssetId ? `/api/admin/images/${encodeURIComponent(product.coverAssetId)}/content` : null);
              return (
                <article class="admin-entity-card product-card">
                  <a class="admin-entity-media" href={`/admin/channels/${encodeURIComponent(channelId)}/products/${encodeURIComponent(product.id)}`} aria-label={`编辑 ${product.title}`}>
                    {thumbnailUrl ? (
                      <img src={thumbnailUrl} alt="" loading="lazy" decoding="async" />
                    ) : (
                      <span class="admin-entity-placeholder">暂无图片</span>
                    )}
                    <span class:list={["admin-entity-badge", `is-${product.status}`]}>{statusLabels[product.status]}</span>
                  </a>
                  <div class="admin-entity-body">
                    <strong class="admin-entity-title" title={product.title}>{product.title}</strong>
                  </div>
                  <div class="admin-entity-actions">
                    {product.status === "published" && (
                      <a class="button secondary" href={`/${encodeURIComponent(channel.slug)}/product/${encodeURIComponent(product.slug)}`} target="_blank" rel="noreferrer">前台</a>
                    )}
                    <a class="button secondary" href={`/admin/channels/${encodeURIComponent(channelId)}/products/${encodeURIComponent(product.id)}`}>编辑</a>
                    <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/products/${encodeURIComponent(product.id)}/delete`} method="post" onsubmit="return confirm('确定删除该产品？')">
                      <button class="button danger" type="submit">删除</button>
                    </form>
                  </div>
                </article>
              );
            })}
          </div>
        )}

        {productPage.pageCount > 1 && (
          <nav class="admin-pagination" aria-label="产品分页">
            <a class:list={["button secondary", productPage.page <= 1 && "is-disabled"]} href={productPage.page > 1 ? pageHref(productPage.page - 1) : undefined}>上一页</a>
            <span>{productPage.page} / {productPage.pageCount}</span>
            <a class:list={["button secondary", productPage.page >= productPage.pageCount && "is-disabled"]} href={productPage.page < productPage.pageCount ? pageHref(productPage.page + 1) : undefined}>下一页</a>
          </nav>
        )}
      </section>
    </>
  ) : (
    <section class="admin-card"><div class="admin-collection-empty">找不到该分区。</div></section>
  )}
</AdminLayout>
