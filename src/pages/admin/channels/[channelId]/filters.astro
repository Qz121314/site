---
import AdminDialog from "@/components/admin/AdminDialog.astro";
import AdminLayout from "@/layouts/AdminLayout.astro";
import { loadAdminCategoryFilters, loadAdminChannel } from "@/lib/db/site";

export const prerender = false;

const channelId = Astro.params.channelId ?? "";
const [channel, filters] = channelId
  ? await Promise.all([loadAdminChannel(channelId), loadAdminCategoryFilters(channelId)])
  : [null, []];

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");

const savedMessages: Record<string, string> = {
  created: "分类筛选已新增。",
  updated: "分类筛选已保存。",
  deleted: "分类筛选已删除。",
};

const errorMessages: Record<string, string> = {
  name: "名称不能为空，且不能超过 60 个字符。",
  sort: "排序必须是 -999999 到 999999 之间的整数。",
  status: "状态无效。",
  "not-found": "找不到该分区或分类筛选。",
  database: "数据库操作失败，请稍后重试。",
};
---

<AdminLayout title={channel ? `${channel.name} · 分类筛选` : "分区不存在"}>
  {channel && (
    <div slot="actions" class="admin-page-action-group">
      <button class="button" type="button" data-dialog-open="filter-create-dialog">新增筛选项</button>
      <a class="button secondary" href={`/admin/channels/${encodeURIComponent(channelId)}/products`}>产品管理</a>
    </div>
  )}

  {channel ? (
    <>
      {saved && savedMessages[saved] && <p class="notice" role="status">{savedMessages[saved]}</p>}
      {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

      <AdminDialog id="filter-create-dialog" title="新增分类筛选" size="small">
        <form class="filter-create-form" action={`/api/admin/channels/${encodeURIComponent(channelId)}/filters/create`} method="post">
          <div class="admin-field filter-name-field">
            <label for="filter-name">名称</label>
            <input id="filter-name" name="name" maxlength="60" required autocomplete="off" autofocus />
          </div>
          <div class="admin-field">
            <label for="filter-sort">排序</label>
            <input id="filter-sort" name="sortOrder" type="number" min="-999999" max="999999" step="1" value="0" />
          </div>
          <div class="admin-field">
            <label for="filter-status">状态</label>
            <select id="filter-status" name="status">
              <option value="enabled" selected>启用</option>
              <option value="disabled">停用</option>
            </select>
          </div>
          <div class="dialog-actions">
            <button class="button secondary" type="button" data-dialog-close>取消</button>
            <button class="button" type="submit">创建筛选项</button>
          </div>
        </form>
      </AdminDialog>

      <section class="admin-card admin-collection-panel">
        <div class="admin-toolbar">
          <h2>筛选项</h2>
          <span class="admin-section-note">{filters.length} 个</span>
        </div>

        {filters.length === 0 ? (
          <div class="admin-collection-empty filter-empty">
            <strong>尚未创建分类筛选</strong>
            <span>筛选项用于给分类建立前台快速过滤入口。</span>
            <button class="button" type="button" data-dialog-open="filter-create-dialog">新增筛选项</button>
          </div>
        ) : (
          <div class="admin-entity-grid filter-grid">
            {filters.map((filter) => {
              const formId = `filter-form-${filter.id}`;
              return (
                <article class="admin-entity-card filter-card">
                  <form id={formId} class="admin-inline-card-form" action={`/api/admin/channels/${encodeURIComponent(channelId)}/filters/${encodeURIComponent(filter.id)}/update`} method="post">
                    <div class="admin-field">
                      <label for={`filter-name-${filter.id}`}>名称</label>
                      <input id={`filter-name-${filter.id}`} name="name" maxlength="60" required value={filter.name} />
                    </div>
                    <div class="admin-inline-card-fields">
                      <div class="admin-field filter-count-field">
                        <label>绑定分类</label>
                        <div class="filter-count">{filter.categoryCount}</div>
                      </div>
                      <div class="admin-field">
                        <label for={`filter-sort-${filter.id}`}>排序</label>
                        <input id={`filter-sort-${filter.id}`} name="sortOrder" type="number" min="-999999" max="999999" step="1" value={filter.sortOrder} />
                      </div>
                      <div class="admin-field">
                        <label for={`filter-status-${filter.id}`}>状态</label>
                        <select id={`filter-status-${filter.id}`} name="status">
                          <option value="enabled" selected={filter.status === "enabled"}>启用</option>
                          <option value="disabled" selected={filter.status === "disabled"}>停用</option>
                        </select>
                      </div>
                    </div>
                  </form>
                  <div class="admin-entity-actions">
                    <button class="button secondary" type="submit" form={formId}>保存</button>
                    <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/filters/${encodeURIComponent(filter.id)}/delete`} method="post" onsubmit="return confirm('确定删除该筛选？')">
                      <button class="button danger" type="submit">删除</button>
                    </form>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </section>
    </>
  ) : (
    <section class="admin-card"><div class="admin-collection-empty">找不到该分区。</div></section>
  )}
</AdminLayout>

<style>
  .filter-create-form { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem; align-items: end; }
  .filter-name-field, .dialog-actions { grid-column: 1 / -1; }
  .dialog-actions { display: flex; justify-content: flex-end; gap: .35rem; padding-top: .1rem; }
  .filter-count-field { align-self: stretch; }
  .filter-count { display: flex; min-height: 2.15rem; align-items: center; color: #475569; font-size: .8rem; font-weight: 700; }
  .filter-empty { display: grid; min-height: 5rem; place-items: center; align-content: center; gap: .4rem; }
  .filter-empty span { color: #64748b; }
  @media (max-width: 639px) {
    .filter-create-form { grid-template-columns: 1fr; }
    .filter-name-field, .dialog-actions { grid-column: auto; }
    .dialog-actions { display: grid; grid-template-columns: 1fr 1fr; }
  }
</style>