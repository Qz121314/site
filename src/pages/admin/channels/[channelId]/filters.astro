---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { loadAdminCategories } from "@/lib/db/categories";
import { loadAdminCategoryFilters, loadAdminChannel } from "@/lib/db/site";

export const prerender = false;

const channelId = Astro.params.channelId ?? "";
const [channel, filters, categories] = channelId
  ? await Promise.all([
      loadAdminChannel(channelId),
      loadAdminCategoryFilters(channelId),
      loadAdminCategories(channelId),
    ])
  : [null, [], []];

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");
const unboundCount = categories.filter((category) => category.filterIds.length === 0).length;

const savedMessages: Record<string, string> = {
  created: "分类筛选已新增。",
  updated: "设置已保存。",
  deleted: "记录已删除。",
};

const errorMessages: Record<string, string> = {
  name: "名称不能为空，且不能超过允许长度。",
  slug: "Slug 只能使用小写字母、数字和连字符。",
  image: "分类目录图片记录无效。",
  sort: "排序必须是 -999999 到 999999 之间的整数。",
  status: "状态无效。",
  filters: "筛选选择无效，或包含其他分区的筛选项。",
  duplicate: "当前分区内已经存在相同 Slug。",
  "not-found": "找不到该分区、筛选或分类目录。",
  "in-use": "分类目录下仍有产品，不能删除。",
  database: "数据库操作失败，请稍后重试。",
};
---

<AdminLayout title={channel ? `${channel.name} · 分类筛选` : "分区不存在"}>
  {channel ? (
    <>
      {saved && savedMessages[saved] && <p class="notice" role="status">{savedMessages[saved]}</p>}
      {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

      <section class="filter-overview">
        <div class="admin-card filter-metric"><span>筛选项</span><strong>{filters.length}</strong></div>
        <div class="admin-card filter-metric"><span>分类目录</span><strong>{categories.length}</strong></div>
        <div class:list={["admin-card", "filter-metric", unboundCount > 0 && "needs-attention"]}><span>未绑定目录</span><strong>{unboundCount}</strong></div>
      </section>

      <section class="admin-card">
        <div class="admin-section-bar">
          <div>
            <h2>筛选项设置</h2>
            <span class="admin-section-note">提前定义前台筛选按钮；All 由系统自动生成</span>
          </div>
        </div>
        <form class="admin-card-body admin-form-grid" action={`/api/admin/channels/${encodeURIComponent(channelId)}/filters/create`} method="post">
          <div class="admin-field admin-span-4">
            <label for="filter-name">筛选名称</label>
            <input id="filter-name" name="name" maxlength="60" required autocomplete="off" placeholder="例如：New York" />
          </div>
          <div class="admin-field admin-span-3">
            <label for="filter-slug">Slug</label>
            <input id="filter-slug" name="slug" maxlength="64" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" required autocomplete="off" placeholder="new-york" />
          </div>
          <div class="admin-field admin-span-2">
            <label for="filter-sort">排序</label>
            <input id="filter-sort" name="sortOrder" type="number" min="-999999" max="999999" step="1" value="0" />
          </div>
          <div class="admin-field admin-span-1">
            <label for="filter-status">状态</label>
            <select id="filter-status" name="status">
              <option value="enabled" selected>启用</option>
              <option value="disabled">停用</option>
            </select>
          </div>
          <div class="admin-form-actions admin-span-2">
            <button class="button" type="submit">新增筛选</button>
          </div>
        </form>

        {filters.length === 0 ? (
          <div class="admin-empty">尚未创建筛选项。没有筛选时，前台不会显示筛选按钮区域。</div>
        ) : (
          <div class="admin-table-wrap">
            <table class="admin-table filter-table">
              <thead>
                <tr>
                  <th class="cell-grow">名称</th>
                  <th>Slug</th>
                  <th>关联目录</th>
                  <th>排序</th>
                  <th>状态</th>
                  <th style="text-align:right">操作</th>
                </tr>
              </thead>
              <tbody>
                {filters.map((filter) => {
                  const formId = `filter-form-${filter.id}`;
                  return (
                    <tr>
                      <td class="cell-grow"><input class="table-input" form={formId} name="name" maxlength="60" required value={filter.name} aria-label="筛选名称" /></td>
                      <td><input class="table-input table-slug" form={formId} name="slug" maxlength="64" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" required value={filter.slug} aria-label="筛选 Slug" /></td>
                      <td>{filter.categoryCount}</td>
                      <td><input class="table-input table-number" form={formId} name="sortOrder" type="number" min="-999999" max="999999" step="1" value={filter.sortOrder} aria-label="排序" /></td>
                      <td>
                        <select class="table-input table-status" form={formId} name="status" aria-label="状态">
                          <option value="enabled" selected={filter.status === "enabled"}>启用</option>
                          <option value="disabled" selected={filter.status === "disabled"}>停用</option>
                        </select>
                      </td>
                      <td>
                        <div class="admin-table-actions">
                          <form id={formId} action={`/api/admin/channels/${encodeURIComponent(channelId)}/filters/${encodeURIComponent(filter.id)}/update`} method="post">
                            <button class="button secondary" type="submit">保存</button>
                          </form>
                          <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/filters/${encodeURIComponent(filter.id)}/delete`} method="post" onsubmit="return confirm('确定删除该筛选？分类目录不会删除，但绑定关系会被移除。')">
                            <button class="button danger" type="submit">删除</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </section>

      <section class="admin-card">
        <div class="admin-toolbar">
          <div>
            <h2>分类目录绑定</h2>
            <span class="admin-section-note">分类由产品录入自动生成；这里仅整理目录并绑定筛选项</span>
          </div>
          <a class="button" href={`/admin/channels/${encodeURIComponent(channelId)}/products/new`}>录入产品</a>
        </div>

        {categories.length === 0 ? (
          <div class="admin-empty">
            尚未生成分类目录。录入产品并填写分类后，目录会自动出现在这里。
          </div>
        ) : (
          <div class="admin-table-wrap">
            <table class="admin-table category-binding-table">
              <thead>
                <tr>
                  <th class="cell-grow">分类目录</th>
                  <th>产品</th>
                  <th>绑定筛选</th>
                  <th>目录图</th>
                  <th>排序</th>
                  <th>状态</th>
                  <th style="text-align:right">操作</th>
                </tr>
              </thead>
              <tbody>
                {categories.map((category) => {
                  const formId = `category-form-${category.id}`;
                  const selectedFilters = new Set(category.filterIds);
                  return (
                    <tr class:list={[category.filterIds.length === 0 && "is-unbound"]}>
                      <td class="cell-grow category-name-cell">
                        <input class="table-input" form={formId} name="name" maxlength="80" required value={category.name} aria-label="分类名称" />
                        <input class="table-input table-slug" form={formId} name="slug" maxlength="64" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" required value={category.slug} aria-label="分类 Slug" />
                        <input type="hidden" form={formId} name="imageAssetId" value={category.imageAssetId ?? ""} />
                      </td>
                      <td>{category.productCount}</td>
                      <td>
                        {filters.length > 0 ? (
                          <details class:list={["filter-picker", category.filterIds.length === 0 && "needs-binding"]}>
                            <summary>{category.filterIds.length > 0 ? `已选 ${category.filterIds.length}` : "未绑定"}</summary>
                            <div class="filter-options">
                              {filters.map((filter) => (
                                <label title={filter.status === "disabled" ? "该筛选当前已停用" : undefined}>
                                  <input form={formId} type="checkbox" name="filterIds" value={filter.id} checked={selectedFilters.has(filter.id)} />
                                  <span>{filter.name}</span>
                                  {filter.status === "disabled" && <small>停</small>}
                                </label>
                              ))}
                            </div>
                          </details>
                        ) : <span class="state-warning">先创建筛选</span>}
                      </td>
                      <td>{category.imageAssetId ? "自动/已设置" : <span class="table-muted">无</span>}</td>
                      <td><input class="table-input table-number" form={formId} name="sortOrder" type="number" min="-999999" max="999999" step="1" value={category.sortOrder} aria-label="排序" /></td>
                      <td>
                        <select class="table-input table-status" form={formId} name="status" aria-label="状态">
                          <option value="draft" selected={category.status === "draft"}>草稿</option>
                          <option value="published" selected={category.status === "published"}>发布</option>
                          <option value="disabled" selected={category.status === "disabled"}>停用</option>
                        </select>
                      </td>
                      <td>
                        <div class="admin-table-actions">
                          <form id={formId} action={`/api/admin/channels/${encodeURIComponent(channelId)}/categories/${encodeURIComponent(category.id)}/update`} method="post">
                            <button class="button secondary" type="submit">保存绑定</button>
                          </form>
                          <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/categories/${encodeURIComponent(category.id)}/delete`} method="post" onsubmit="return confirm('确定删除这个空分类目录？')">
                            <button class="button danger" type="submit" disabled={category.productCount > 0} title={category.productCount > 0 ? "目录下仍有产品，不能删除" : "删除空目录"}>删除</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </section>
    </>
  ) : (
    <section class="admin-card"><div class="admin-empty">找不到该分区。<a class="button secondary" href="/admin/channels">返回分区管理</a></div></section>
  )}
</AdminLayout>

<style>
  .filter-overview { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .55rem; margin-bottom: .55rem; }
  .filter-metric { display: flex; align-items: center; justify-content: space-between; padding: .6rem .7rem; }
  .filter-metric span { color: #918b97; font-size: .72rem; }
  .filter-metric strong { font-size: 1.2rem; }
  .filter-metric.needs-attention { border-color: rgba(231,189,121,.35); }
  .filter-metric.needs-attention strong { color: #e7bd79; }
  .table-input { width: 100%; min-width: 7rem; height: 1.75rem; border: 1px solid transparent; border-radius: .25rem; padding: .2rem .38rem; color: var(--text); background: transparent; outline: none; }
  .table-input:hover { border-color: #302d36; background: #0d0c10; }
  .table-input:focus { border-color: #9d7942; background: #0d0c10; }
  .table-slug { min-width: 9rem; }
  .table-number { width: 5rem; min-width: 5rem; }
  .table-status { width: 5rem; min-width: 5rem; }
  .category-name-cell { min-width: 14rem; }
  .category-name-cell .table-slug { margin-top: .18rem; color: #827c88; font-size: .68rem; }
  .filter-picker { min-width: 7rem; border: 1px solid transparent; border-radius: .3rem; background: transparent; }
  .filter-picker > summary { display: flex; min-height: 1.75rem; align-items: center; padding: .2rem .38rem; cursor: pointer; list-style: none; white-space: nowrap; }
  .filter-picker > summary::-webkit-details-marker { display: none; }
  .filter-picker:hover,
  .filter-picker[open] { border-color: #302d36; background: #0d0c10; }
  .filter-picker[open] { min-width: 15rem; }
  .filter-picker.needs-binding > summary,
  .state-warning { color: #e7bd79; }
  .filter-options { display: flex; max-width: 28rem; flex-wrap: wrap; gap: .25rem .5rem; padding: .4rem .5rem; border-top: 1px solid #302d36; }
  .filter-options label { display: inline-flex; align-items: center; gap: .25rem; white-space: nowrap; }
  .filter-options input { width: .9rem; height: .9rem; margin: 0; }
  .filter-options small { color: #e7bd79; font-size: .62rem; }
  .is-unbound { background: rgba(142,91,47,.055); }
  .table-muted { color: #817b87; }
  .button:disabled { opacity: .38; cursor: not-allowed; }
  @media (max-width: 767px) {
    .filter-overview { grid-template-columns: 1fr; }
  }
</style>
