---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { loadAdminCategoryFilters, loadAdminChannel } from "@/lib/db/site";

export const prerender = false;

const channelId = Astro.params.channelId ?? "";
const [channel, filters] = channelId
  ? await Promise.all([loadAdminChannel(channelId), loadAdminCategoryFilters(channelId)])
  : [null, []];

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");

const savedMessages: Record<string, string> = {
  created: "分类筛选已新增。",
  updated: "分类筛选已更新。",
  deleted: "分类筛选已删除，原有分类关联已同步移除。",
};

const errorMessages: Record<string, string> = {
  name: "筛选名称不能为空，且不能超过 60 个字符。",
  slug: "Slug 只能使用小写字母、数字和连字符。",
  sort: "排序必须是 -999999 到 999999 之间的整数。",
  status: "筛选状态无效。",
  duplicate: "当前分区内已经存在相同 Slug。",
  "not-found": "找不到该分区或分类筛选。",
  database: "数据库操作失败，请稍后重试。",
};
---

<AdminLayout title={channel ? `${channel.name} · 分类筛选` : "分区不存在"}>
  {channel ? (
    <>
      {saved && savedMessages[saved] && <p class="notice" role="status">{savedMessages[saved]}</p>}
      {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

      <section class="admin-card">
        <div class="admin-section-bar">
          <h2>新增筛选</h2>
          <span class="admin-section-note">前台自动生成 All，此处只录入实际筛选按钮</span>
        </div>
        <form class="admin-card-body admin-form-grid" action={`/api/admin/channels/${encodeURIComponent(channelId)}/filters/create`} method="post">
          <div class="admin-field admin-span-4">
            <label for="filter-name">名称</label>
            <input id="filter-name" name="name" maxlength="60" required autocomplete="off" placeholder="例如：Popular" />
          </div>
          <div class="admin-field admin-span-3">
            <label for="filter-slug">Slug</label>
            <input id="filter-slug" name="slug" maxlength="64" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" required autocomplete="off" placeholder="popular" />
          </div>
          <div class="admin-field admin-span-2">
            <label for="filter-sort">排序</label>
            <input id="filter-sort" name="sortOrder" type="number" min="-999999" max="999999" step="1" value="0" />
          </div>
          <div class="admin-field admin-span-1">
            <label for="filter-status">状态</label>
            <select id="filter-status" name="status">
              <option value="enabled" selected>启用</option>
              <option value="disabled">停用</option>
            </select>
          </div>
          <div class="admin-form-actions admin-span-2">
            <button class="button" type="submit">新增</button>
          </div>
        </form>
      </section>

      <section class="admin-card">
        <div class="admin-toolbar">
          <h2>筛选列表</h2>
          <span class="admin-section-note">共 {filters.length} 个；分类绑定在“分类管理”中操作</span>
        </div>

        {filters.length === 0 ? (
          <div class="admin-empty">当前分区尚未创建分类筛选。没有筛选时，前台不显示筛选按钮区域。</div>
        ) : (
          <div class="admin-table-wrap">
            <table class="admin-table filter-table">
              <thead>
                <tr>
                  <th class="cell-grow">名称</th>
                  <th>Slug</th>
                  <th>排序</th>
                  <th>状态</th>
                  <th>关联分类</th>
                  <th style="text-align:right">操作</th>
                </tr>
              </thead>
              <tbody>
                {filters.map((filter) => {
                  const formId = `filter-form-${filter.id}`;
                  return (
                    <tr>
                      <td class="cell-grow">
                        <input class="table-input" form={formId} name="name" maxlength="60" required value={filter.name} aria-label="筛选名称" />
                      </td>
                      <td>
                        <input class="table-input table-slug" form={formId} name="slug" maxlength="64" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" required value={filter.slug} aria-label="筛选 Slug" />
                      </td>
                      <td>
                        <input class="table-input table-number" form={formId} name="sortOrder" type="number" min="-999999" max="999999" step="1" value={filter.sortOrder} aria-label="排序" />
                      </td>
                      <td>
                        <select class="table-input table-status" form={formId} name="status" aria-label="状态">
                          <option value="enabled" selected={filter.status === "enabled"}>启用</option>
                          <option value="disabled" selected={filter.status === "disabled"}>停用</option>
                        </select>
                      </td>
                      <td>{filter.categoryCount}</td>
                      <td>
                        <div class="admin-table-actions">
                          <form id={formId} action={`/api/admin/channels/${encodeURIComponent(channelId)}/filters/${encodeURIComponent(filter.id)}/update`} method="post">
                            <button class="button secondary" type="submit">保存</button>
                          </form>
                          <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/filters/${encodeURIComponent(filter.id)}/delete`} method="post" onsubmit="return confirm('确定删除该分类筛选？分类本身不会删除，但关联关系会被移除。')">
                            <button class="button danger" type="submit">删除</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </section>
    </>
  ) : (
    <section class="admin-card">
      <div class="admin-empty">
        找不到该分区。<a class="button secondary" href="/admin/channels">返回分区管理</a>
      </div>
    </section>
  )}
</AdminLayout>

<style>
  .filter-table .table-input {
    width: 100%;
    min-width: 7rem;
    height: 1.75rem;
    border: 1px solid transparent;
    border-radius: .25rem;
    padding: .2rem .38rem;
    color: var(--text);
    background: transparent;
    outline: none;
  }

  .filter-table .table-input:hover { border-color: #302d36; background: #0d0c10; }
  .filter-table .table-input:focus { border-color: #9d7942; background: #0d0c10; }
  .filter-table .table-slug { min-width: 9rem; }
  .filter-table .table-number { width: 5rem; min-width: 5rem; }
  .filter-table .table-status { width: 5rem; min-width: 5rem; }
</style>
