---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { loadAdminCategories } from "@/lib/db/categories";
import { loadAdminCategoryFilters, loadAdminChannel } from "@/lib/db/site";

export const prerender = false;

const channelId = Astro.params.channelId ?? "";
const [channel, filters, categories] = channelId
  ? await Promise.all([
      loadAdminChannel(channelId),
      loadAdminCategoryFilters(channelId),
      loadAdminCategories(channelId),
    ])
  : [null, [], []];

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");

const savedMessages: Record<string, string> = {
  created: "分类已新增。",
  updated: "分类及筛选关联已更新。",
  deleted: "分类已删除。",
};

const errorMessages: Record<string, string> = {
  name: "分类名称不能为空，且不能超过 80 个字符。",
  slug: "Slug 只能使用小写字母、数字和连字符。",
  sort: "排序必须是 -999999 到 999999 之间的整数。",
  status: "分类状态无效。",
  filters: "筛选选择无效，或包含其他分区的筛选项。",
  duplicate: "当前分区内已经存在相同 Slug。",
  "not-found": "找不到该分区或分类。",
  "in-use": "该分类下仍有产品，必须先移动或删除产品。",
  database: "数据库操作失败，请稍后重试。",
};
---

<AdminLayout title={channel ? `${channel.name} · 分类管理` : "分区不存在"}>
  {channel ? (
    <>
      {saved && savedMessages[saved] && <p class="notice" role="status">{savedMessages[saved]}</p>}
      {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}

      <section class="admin-card">
        <div class="admin-section-bar">
          <h2>新增分类</h2>
          <span class="admin-section-note">图片稍后从图片库选择；一个分类可绑定多个筛选</span>
        </div>
        <form class="admin-card-body admin-form-grid" action={`/api/admin/channels/${encodeURIComponent(channelId)}/categories/create`} method="post">
          <div class="admin-field admin-span-3">
            <label for="category-name">名称</label>
            <input id="category-name" name="name" maxlength="80" required autocomplete="off" placeholder="例如：New York" />
          </div>
          <div class="admin-field admin-span-3">
            <label for="category-slug">Slug</label>
            <input id="category-slug" name="slug" maxlength="64" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" required autocomplete="off" placeholder="new-york" />
          </div>
          <div class="admin-field admin-span-2">
            <label>分类筛选</label>
            {filters.length > 0 ? (
              <details class="filter-picker">
                <summary>选择筛选</summary>
                <div class="filter-options">
                  {filters.map((filter) => (
                    <label title={filter.status === "disabled" ? "该筛选当前已停用" : undefined}>
                      <input type="checkbox" name="filterIds" value={filter.id} />
                      <span>{filter.name}</span>
                      {filter.status === "disabled" && <small>停</small>}
                    </label>
                  ))}
                </div>
              </details>
            ) : (
              <span class="empty-control">未创建筛选</span>
            )}
          </div>
          <div class="admin-field admin-span-1">
            <label for="category-sort">排序</label>
            <input id="category-sort" name="sortOrder" type="number" min="-999999" max="999999" step="1" value="0" />
          </div>
          <div class="admin-field admin-span-1">
            <label for="category-status">状态</label>
            <select id="category-status" name="status">
              <option value="draft" selected>草稿</option>
              <option value="published">发布</option>
              <option value="disabled">停用</option>
            </select>
          </div>
          <div class="admin-form-actions admin-span-2">
            <button class="button" type="submit">新增</button>
          </div>
        </form>
      </section>

      <section class="admin-card">
        <div class="admin-toolbar">
          <h2>分类列表</h2>
          <span class="admin-section-note">共 {categories.length} 个；删除前必须清空该分类下的产品</span>
        </div>

        {categories.length === 0 ? (
          <div class="admin-empty">当前分区尚未创建分类。没有分类时，前台直接显示该分区的产品目录。</div>
        ) : (
          <div class="admin-table-wrap">
            <table class="admin-table category-table">
              <thead>
                <tr>
                  <th class="cell-grow">名称</th>
                  <th>Slug</th>
                  <th>筛选</th>
                  <th>图片</th>
                  <th>产品</th>
                  <th>排序</th>
                  <th>状态</th>
                  <th style="text-align:right">操作</th>
                </tr>
              </thead>
              <tbody>
                {categories.map((category) => {
                  const formId = `category-form-${category.id}`;
                  const selectedFilters = new Set(category.filterIds);
                  return (
                    <tr>
                      <td class="cell-grow">
                        <input class="table-input" form={formId} name="name" maxlength="80" required value={category.name} aria-label="分类名称" />
                      </td>
                      <td>
                        <input class="table-input table-slug" form={formId} name="slug" maxlength="64" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" required value={category.slug} aria-label="分类 Slug" />
                      </td>
                      <td>
                        {filters.length > 0 ? (
                          <details class="filter-picker table-filter-picker">
                            <summary>已选 {category.filterIds.length}</summary>
                            <div class="filter-options">
                              {filters.map((filter) => (
                                <label title={filter.status === "disabled" ? "该筛选当前已停用" : undefined}>
                                  <input form={formId} type="checkbox" name="filterIds" value={filter.id} checked={selectedFilters.has(filter.id)} />
                                  <span>{filter.name}</span>
                                  {filter.status === "disabled" && <small>停</small>}
                                </label>
                              ))}
                            </div>
                          </details>
                        ) : (
                          <span class="table-muted">无筛选</span>
                        )}
                      </td>
                      <td><span class:list={["asset-state", category.imageAssetId && "is-set"]}>{category.imageAssetId ? "已绑定" : "未设置"}</span></td>
                      <td>{category.productCount}</td>
                      <td>
                        <input class="table-input table-number" form={formId} name="sortOrder" type="number" min="-999999" max="999999" step="1" value={category.sortOrder} aria-label="排序" />
                      </td>
                      <td>
                        <select class="table-input table-status" form={formId} name="status" aria-label="状态">
                          <option value="draft" selected={category.status === "draft"}>草稿</option>
                          <option value="published" selected={category.status === "published"}>发布</option>
                          <option value="disabled" selected={category.status === "disabled"}>停用</option>
                        </select>
                      </td>
                      <td>
                        <div class="admin-table-actions">
                          <form id={formId} action={`/api/admin/channels/${encodeURIComponent(channelId)}/categories/${encodeURIComponent(category.id)}/update`} method="post">
                            <button class="button secondary" type="submit">保存</button>
                          </form>
                          <form action={`/api/admin/channels/${encodeURIComponent(channelId)}/categories/${encodeURIComponent(category.id)}/delete`} method="post" onsubmit="return confirm('确定删除该分类？筛选关联会同步移除，分类图片文件不会被删除。')">
                            <button class="button danger" type="submit" disabled={category.productCount > 0} title={category.productCount > 0 ? "分类下仍有产品，不能删除" : "删除分类"}>删除</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </section>
    </>
  ) : (
    <section class="admin-card">
      <div class="admin-empty">找不到该分区。<a class="button secondary" href="/admin/channels">返回分区管理</a></div>
    </section>
  )}
</AdminLayout>

<style>
  .category-table .table-input {
    width: 100%;
    min-width: 7rem;
    height: 1.75rem;
    border: 1px solid transparent;
    border-radius: .25rem;
    padding: .2rem .38rem;
    color: var(--text);
    background: transparent;
    outline: none;
  }

  .category-table .table-input:hover { border-color: #302d36; background: #0d0c10; }
  .category-table .table-input:focus { border-color: #9d7942; background: #0d0c10; }
  .category-table .table-slug { min-width: 9rem; }
  .category-table .table-number { width: 4.8rem; min-width: 4.8rem; }
  .category-table .table-status { width: 5rem; min-width: 5rem; }

  .filter-picker {
    min-width: 0;
    border: 1px solid #302d36;
    border-radius: .3rem;
    background: #0d0c10;
  }

  .filter-picker > summary {
    display: flex;
    min-height: 2.05rem;
    align-items: center;
    padding: .32rem .5rem;
    cursor: pointer;
    list-style: none;
    white-space: nowrap;
  }

  .filter-picker > summary::-webkit-details-marker { display: none; }
  .filter-picker[open] > summary { border-bottom: 1px solid #302d36; }
  .filter-options { display: flex; max-width: 28rem; flex-wrap: wrap; gap: .25rem .5rem; padding: .4rem .5rem; }
  .filter-options label { display: inline-flex; align-items: center; gap: .25rem; white-space: nowrap; }
  .filter-options input { width: .9rem; height: .9rem; margin: 0; }
  .filter-options small { color: #e7bd79; font-size: .62rem; }

  .table-filter-picker { min-width: 7rem; border-color: transparent; background: transparent; }
  .table-filter-picker > summary { min-height: 1.75rem; padding: .2rem .38rem; }
  .table-filter-picker:hover { border-color: #302d36; background: #0d0c10; }
  .table-filter-picker[open] { min-width: 16rem; border-color: #302d36; background: #0d0c10; }

  .empty-control {
    display: flex;
    min-height: 2.05rem;
    align-items: center;
    padding: .32rem .5rem;
    border: 1px solid #302d36;
    border-radius: .3rem;
    color: #77717e;
    background: #0d0c10;
  }

  .asset-state,
  .table-muted { color: #817b87; font-size: .7rem; }
  .asset-state.is-set { color: #65d99c; }
  .button:disabled { opacity: .38; cursor: not-allowed; }
</style>
