---
import AdminLayout from "@/layouts/AdminLayout.astro";
import {
  ADMIN_IMAGE_FILTERS,
  type AdminImageAsset,
  type AdminImageFilter,
  loadAdminImagePage,
} from "@/lib/db/images";
import { buildPublicImageUrl } from "@/lib/images/url";

export const prerender = false;

const query = (Astro.url.searchParams.get("q") ?? "").trim().slice(0, 24);
const rawFilter = Astro.url.searchParams.get("filter") ?? "all";
const filter: AdminImageFilter = ADMIN_IMAGE_FILTERS.includes(rawFilter as AdminImageFilter)
  ? (rawFilter as AdminImageFilter)
  : "all";
const requestedPage = Number(Astro.url.searchParams.get("page") ?? "1");
const library = await loadAdminImagePage({ query, filter, page: requestedPage });

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");
const count = Number(Astro.url.searchParams.get("count") ?? "0");
const pending = Number(Astro.url.searchParams.get("pending") ?? "0");
const retried = Number(Astro.url.searchParams.get("retried") ?? "0");
const imported = Number(Astro.url.searchParams.get("imported") ?? "0");
const skipped = Number(Astro.url.searchParams.get("skipped") ?? "0");
const partial = Astro.url.searchParams.get("partial") === "1";
const scanCursor = (Astro.url.searchParams.get("cursor") ?? "").trim().slice(0, 2048);
const safeCount = Number.isFinite(count) ? count : 0;
const safePending = Number.isFinite(pending) ? pending : 0;
const safeRetried = Number.isFinite(retried) ? retried : 0;

const savedMessage = saved === "deleted"
  ? "图片及对应 R2 对象已删除。"
  : saved === "delete-pending"
    ? "图片记录已删除；R2 对象暂时删除失败，已进入重试队列。"
    : saved === "bulk-deleted"
      ? `已批量删除 ${safeCount} 张未引用图片及其 R2 对象。`
      : saved === "bulk-delete-pending"
        ? `已移除 ${safeCount} 张图片记录，其中 ${safePending} 个 R2 对象进入重试队列。`
        : saved === "clean"
          ? `未引用图片清理完成，新删除 ${safeCount} 张，重试完成 ${safeRetried} 个 R2 对象。`
          : saved === "clean-pending"
            ? `清理已完成，新删除 ${safeCount} 张，重试完成 ${safeRetried} 个；仍有 ${safePending} 个 R2 对象等待重试。`
            : saved === "scanned"
              ? `R2 扫描完成，导入 ${Number.isFinite(imported) ? imported : 0} 张，跳过 ${Number.isFinite(skipped) ? skipped : 0} 个对象${partial ? "；仍有后续对象" : ""}。`
              : "";

const errorMessages: Record<string, string> = {
  "not-found": "找不到该图片记录。",
  "in-use": "所选图片仍被引用，不能删除。",
  "bulk-selection": "请选择 1 至 100 张未引用图片。",
  delete: "删除图片失败，请稍后重试。",
  cleanup: "批量清理失败，请稍后重试。",
  scan: "扫描 R2 失败，请稍后重试。",
};

function usageText(image: AdminImageAsset): string {
  const parts = [
    image.logoReferences > 0 ? "Logo" : "",
    image.faviconReferences > 0 ? "图标" : "",
    image.categoryReferences > 0 ? "分类" : "",
    image.productCoverReferences > 0 ? "封面" : "",
    image.productGalleryReferences > 0 ? "产品" : "",
    image.advertisementReferences > 0 ? "广告" : "",
  ].filter(Boolean);
  return parts.length > 0 ? parts.join(" · ") : "未引用";
}

function pageHref(page: number): string {
  const params = new URLSearchParams();
  if (query) params.set("q", query);
  if (filter !== "all") params.set("filter", filter);
  if (page > 1) params.set("page", String(page));
  const suffix = params.toString();
  return suffix ? `/admin/images?${suffix}` : "/admin/images";
}

const selectableCount = library.images.filter((image) => image.referenceCount === 0).length;
const unusedCount = selectableCount;
---

<AdminLayout title="图片库">
  <div slot="actions" class="admin-page-action-group">
    <form action="/api/admin/images/scan" method="post" onsubmit="return confirm('扫描 R2 并恢复由本系统上传、但数据库中缺失的图片记录？删除队列中的对象不会恢复。')">
      {scanCursor && <input type="hidden" name="cursor" value={scanCursor} />}
      <button class="button secondary" type="submit">{scanCursor ? "继续扫描" : "扫描 R2"}</button>
    </form>
    <form action="/api/admin/images/cleanup" method="post" onsubmit="return confirm('重试待删除的 R2 对象，并删除最多 100 张上传超过 24 小时且完全未引用的图片？')">
      <button class="button danger" type="submit">清理未引用</button>
    </form>
  </div>

  {savedMessage && <p class="notice" role="status">{savedMessage}</p>}
  {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}
  {!library.databaseReady && <p class="error" role="alert">图片资产数据库查询失败。请确认最新 D1 Migration 已应用。</p>}

  <section class="admin-card admin-filter-panel">
    <form class="admin-filter-form image-filter-form" method="get" action="/admin/images">
      <div class="admin-field admin-search-field">
        <label for="image-search">搜索</label>
        <input id="image-search" name="q" value={query} maxlength="24" autocomplete="off" placeholder="文件名或 Object Key" />
      </div>
      <div class="admin-field">
        <label for="image-reference-filter">引用</label>
        <select id="image-reference-filter" name="filter">
          <option value="all" selected={filter === "all"}>全部图片</option>
          <option value="used" selected={filter === "used"}>已引用</option>
          <option value="unused" selected={filter === "unused"}>未引用</option>
        </select>
      </div>
      <div class="admin-filter-actions">
        <button class="button" type="submit">筛选</button>
        {(query || filter !== "all") && <a class="button secondary" href="/admin/images">重置</a>}
      </div>
    </form>
  </section>

  <section class="admin-card admin-collection-panel">
    <div class="admin-toolbar library-toolbar">
      <div>
        <h2>R2 图片</h2>
        <span class="admin-section-note">{library.total} 张 · 本页未引用 {unusedCount} 张</span>
      </div>
      <div class="library-maintenance">
        <button id="select-unused-button" class="button secondary" type="button" disabled={selectableCount === 0}>选择未引用</button>
        <form id="image-bulk-form" action="/api/admin/images/bulk-delete" method="post" onsubmit="return confirm('确定删除已选择图片及其 R2 对象？')">
          <button id="bulk-delete-button" class="button danger" type="submit" disabled>删除已选</button>
        </form>
      </div>
    </div>

    {library.images.length === 0 ? (
      <div class="admin-collection-empty">没有符合条件的图片。</div>
    ) : (
      <div class="admin-entity-grid is-dense image-grid">
        {library.images.map((image) => {
          const previewUrl = buildPublicImageUrl(library.r2PublicBaseUrl, image.objectKey)
            ?? `/api/admin/images/${encodeURIComponent(image.id)}/content`;
          return (
            <article class="admin-entity-card image-card">
              {image.referenceCount === 0 && (
                <label class="image-select" title="选择用于批量删除">
                  <input
                    class="bulk-image-checkbox"
                    type="checkbox"
                    name="imageIds"
                    value={image.id}
                    form="image-bulk-form"
                    aria-label={`选择 ${image.originalName || image.objectKey}`}
                  />
                </label>
              )}
              <a class="admin-entity-media" href={previewUrl} target="_blank" rel="noreferrer" title={image.originalName || image.objectKey}>
                <img src={previewUrl} alt={image.originalName || image.objectKey} loading="lazy" decoding="async" />
                <span class:list={["admin-entity-badge", image.referenceCount > 0 ? "is-used" : "is-unused"]}>{usageText(image)}</span>
              </a>
              <div class="admin-entity-actions image-card-actions">
                <a class="button secondary" href={previewUrl} target="_blank" rel="noreferrer">查看</a>
                <form action={`/api/admin/images/${encodeURIComponent(image.id)}/delete`} method="post" onsubmit="return confirm('确定删除这张图片及其 R2 对象？')">
                  <button class="button danger" type="submit" disabled={image.referenceCount > 0} title={image.referenceCount > 0 ? "图片仍有引用" : "删除图片"}>删除</button>
                </form>
              </div>
            </article>
          );
        })}
      </div>
    )}

    {library.pageCount > 1 && (
      <nav class="admin-pagination" aria-label="图片分页">
        <a class:list={["button secondary", library.page <= 1 && "is-disabled"]} href={library.page > 1 ? pageHref(library.page - 1) : undefined}>上一页</a>
        <span>{library.page} / {library.pageCount}</span>
        <a class:list={["button secondary", library.page >= library.pageCount && "is-disabled"]} href={library.page < library.pageCount ? pageHref(library.page + 1) : undefined}>下一页</a>
      </nav>
    )}
  </section>
</AdminLayout>

<script is:inline>
  (() => {
    const checkboxes = Array.from(document.querySelectorAll('.bulk-image-checkbox'));
    const selectUnused = document.getElementById('select-unused-button');
    const bulkDelete = document.getElementById('bulk-delete-button');
    if (!bulkDelete) return;

    const refresh = () => {
      const selected = checkboxes.filter((checkbox) => checkbox.checked).length;
      bulkDelete.disabled = selected === 0;
      bulkDelete.textContent = selected > 0 ? `删除已选 (${selected})` : '删除已选';
    };

    checkboxes.forEach((checkbox) => checkbox.addEventListener('change', refresh));
    selectUnused?.addEventListener('click', () => {
      const shouldSelect = checkboxes.some((checkbox) => !checkbox.checked);
      checkboxes.forEach((checkbox) => { checkbox.checked = shouldSelect; });
      selectUnused.textContent = shouldSelect ? '取消选择' : '选择未引用';
      refresh();
    });
    refresh();
  })();
</script>

<style>
  .image-filter-form { grid-template-columns: minmax(15rem, 1fr) 10rem auto; }
  .library-toolbar { align-items: center; }
  .library-maintenance { display: flex; flex-wrap: wrap; align-items: center; justify-content: flex-end; gap: .35rem; }
  .image-select { position: absolute; z-index: 3; top: .45rem; left: .45rem; display: grid; width: 1.55rem; height: 1.55rem; place-items: center; border: 1px solid rgba(255,255,255,.8); border-radius: .4rem; background: rgba(255,255,255,.94); box-shadow: 0 2px 8px rgba(15,23,42,.12); }
  .image-select input { width: .95rem; height: .95rem; margin: 0; }
  .image-card-actions { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  @media (max-width: 639px) { .image-filter-form { grid-template-columns: 1fr; } .library-toolbar { align-items: flex-start; flex-direction: column; } .library-maintenance { justify-content: flex-start; } }
</style>
