---
import AdminLayout from "@/layouts/AdminLayout.astro";
import {
  ADMIN_IMAGE_FILTERS,
  type AdminImageAsset,
  type AdminImageFilter,
  loadAdminImagePage,
} from "@/lib/db/images";
import { buildPublicImageUrl } from "@/lib/images/url";

export const prerender = false;

const query = (Astro.url.searchParams.get("q") ?? "").trim().slice(0, 180);
const rawFilter = Astro.url.searchParams.get("filter") ?? "all";
const filter: AdminImageFilter = ADMIN_IMAGE_FILTERS.includes(rawFilter as AdminImageFilter)
  ? (rawFilter as AdminImageFilter)
  : "all";
const requestedPage = Number(Astro.url.searchParams.get("page") ?? "1");
const library = await loadAdminImagePage({ query, filter, page: requestedPage });

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");
const count = Number(Astro.url.searchParams.get("count") ?? "0");
const imported = Number(Astro.url.searchParams.get("imported") ?? "0");
const skipped = Number(Astro.url.searchParams.get("skipped") ?? "0");
const partial = Astro.url.searchParams.get("partial") === "1";

const savedMessage = saved === "uploaded"
  ? `图片上传完成${count > 0 ? `，成功 ${count} 张` : ""}。`
  : saved === "deleted"
    ? "图片及对应 R2 对象已删除。"
    : saved === "bulk-deleted"
      ? `已批量删除 ${Number.isFinite(count) ? count : 0} 张未引用图片。`
      : saved === "clean"
        ? `未引用图片清理完成，共删除 ${Number.isFinite(count) ? count : 0} 张。`
        : saved === "scanned"
          ? `R2 扫描完成，导入 ${Number.isFinite(imported) ? imported : 0} 张，跳过 ${Number.isFinite(skipped) ? skipped : 0} 个缺少受控元数据的对象${partial ? "；本次达到 10,000 个对象上限，请再次扫描" : ""}。`
          : "";

const errorMessages: Record<string, string> = {
  file: "请选择有效图片。",
  "too-large": "单张图片处理后不能超过 8 MB。",
  format: "仅支持 JPEG、PNG 和 WebP，且文件内容必须与格式一致。",
  read: "读取上传图片失败。",
  "invalid-form": "上传表单无效。",
  storage: "写入 R2 或 D1 失败，未完成的对象已回滚。",
  "not-found": "找不到该图片记录。",
  "in-use": "所选图片仍被站点、分类、产品或广告引用，不能删除。",
  "bulk-selection": "请选择 1 至 100 张未引用图片。",
  delete: "删除图片失败，请稍后重试。",
  cleanup: "批量清理失败，请稍后重试。",
  scan: "扫描 R2 失败，请稍后重试。",
};

function formatBytes(value: number): string {
  if (value < 1024) return `${value} B`;
  if (value < 1024 * 1024) return `${(value / 1024).toFixed(1)} KB`;
  return `${(value / (1024 * 1024)).toFixed(2)} MB`;
}

function formatCreatedAt(value: string): string {
  return value.replace("T", " ").replace("Z", "").slice(0, 16);
}

function usageText(image: AdminImageAsset): string {
  const parts = [
    image.logoReferences > 0 ? `Logo ${image.logoReferences}` : "",
    image.faviconReferences > 0 ? `图标 ${image.faviconReferences}` : "",
    image.categoryReferences > 0 ? `分类 ${image.categoryReferences}` : "",
    image.productCoverReferences > 0 ? `封面 ${image.productCoverReferences}` : "",
    image.productGalleryReferences > 0 ? `图库 ${image.productGalleryReferences}` : "",
    image.advertisementReferences > 0 ? `广告 ${image.advertisementReferences}` : "",
  ].filter(Boolean);
  return parts.length > 0 ? parts.join(" · ") : "未引用";
}

function pageHref(page: number): string {
  const params = new URLSearchParams();
  if (query) params.set("q", query);
  if (filter !== "all") params.set("filter", filter);
  if (page > 1) params.set("page", String(page));
  const suffix = params.toString();
  return suffix ? `/admin/images?${suffix}` : "/admin/images";
}

const selectableCount = library.images.filter((image) => image.referenceCount === 0).length;
---

<AdminLayout title="图片库">
  {savedMessage && <p class="notice" role="status">{savedMessage}</p>}
  {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}
  {!library.databaseReady && (
    <p class="error" role="alert">图片库数据库查询失败。请确认最新 D1 Migration 已应用。</p>
  )}

  <section class="admin-card upload-card">
    <div class="admin-section-bar">
      <div>
        <h2>上传图片</h2>
        <span class="admin-section-note">选择后先在本地预览；保存时压缩为 WebP，最长边不超过 1600px</span>
      </div>
      <span class="image-limit">单张上限 8 MB</span>
    </div>
    <form
      id="image-upload-form"
      class="admin-card-body upload-form"
      action="/api/admin/images/upload"
      method="post"
      enctype="multipart/form-data"
    >
      <label class="upload-drop" for="image-files">
        <strong>选择 JPEG、PNG 或 WebP</strong>
        <span>支持多选；透明背景会保留。未点击上传前不会写入 R2。</span>
        <input id="image-files" name="file" type="file" accept="image/jpeg,image/png,image/webp" multiple required />
      </label>
      <div class="upload-actions">
        <button id="image-upload-button" class="button" type="submit" disabled>压缩并上传</button>
        <button id="image-clear-button" class="button secondary" type="button" disabled>清空待上传</button>
        <span id="image-upload-status" class="admin-section-note" aria-live="polite">尚未选择图片</span>
      </div>
      <div id="image-upload-queue" class="upload-queue" hidden aria-label="待上传图片"></div>
    </form>
  </section>

  <section class="admin-card library-card">
    <div class="admin-toolbar library-toolbar">
      <div>
        <h2>资产列表</h2>
        <span class="admin-section-note">共 {library.total} 张；引用中的图片禁止删除</span>
      </div>
      <div class="library-maintenance">
        <button id="select-unused-button" class="button secondary" type="button" disabled={selectableCount === 0}>选择本页未引用</button>
        <form id="image-bulk-form" action="/api/admin/images/bulk-delete" method="post" onsubmit="return confirm('确定删除已选择图片及其 R2 对象？服务端会再次检查引用。')">
          <button id="bulk-delete-button" class="button danger" type="submit" disabled>删除已选</button>
        </form>
        <form action="/api/admin/images/scan" method="post" onsubmit="return confirm('扫描 R2 并导入由本系统上传、但数据库中缺失的图片记录？')">
          <button class="button secondary" type="submit">扫描 R2</button>
        </form>
        <form action="/api/admin/images/cleanup" method="post" onsubmit="return confirm('删除最多 100 张上传超过 24 小时且完全未引用的图片？此操作会同时删除 R2 对象。')">
          <button class="button danger" type="submit">清理未引用</button>
        </form>
      </div>
    </div>

    <form class="image-search" method="get" action="/admin/images">
      <input name="q" value={query} maxlength="180" autocomplete="off" placeholder="搜索原文件名或 R2 Object Key" />
      <select name="filter" aria-label="引用状态">
        <option value="all" selected={filter === "all"}>全部图片</option>
        <option value="used" selected={filter === "used"}>已引用</option>
        <option value="unused" selected={filter === "unused"}>未引用</option>
      </select>
      <button class="button secondary" type="submit">筛选</button>
      {(query || filter !== "all") && <a class="button secondary" href="/admin/images">重置</a>}
    </form>

    {library.images.length === 0 ? (
      <div class="admin-empty">没有符合条件的图片。可在上方选择图片上传，或扫描 R2 恢复受控资产记录。</div>
    ) : (
      <div class="image-grid">
        {library.images.map((image) => {
          const previewUrl = buildPublicImageUrl(library.r2PublicBaseUrl, image.objectKey)
            ?? `/api/admin/images/${encodeURIComponent(image.id)}/content`;
          return (
            <article class:list={["image-card", image.referenceCount === 0 && "is-selectable"]}>
              {image.referenceCount === 0 && (
                <label class="image-select" title="选择用于批量删除">
                  <input
                    class="bulk-image-checkbox"
                    type="checkbox"
                    name="imageIds"
                    value={image.id}
                    form="image-bulk-form"
                    aria-label={`选择 ${image.originalName || image.objectKey}`}
                  />
                </label>
              )}
              <a class="image-preview" href={previewUrl} target="_blank" rel="noreferrer" title="打开原图">
                <img src={previewUrl} alt={image.originalName || image.objectKey} loading="lazy" decoding="async" />
              </a>
              <div class="image-card-body">
                <strong title={image.originalName || image.objectKey}>{image.originalName || "未记录原文件名"}</strong>
                <code title={image.objectKey}>{image.objectKey}</code>
                <div class="image-meta">
                  <span>{image.width} × {image.height}</span>
                  <span>{formatBytes(image.sizeBytes)}</span>
                  <span>{image.mimeType.replace("image/", "").toUpperCase()}</span>
                </div>
                <div class:list={["image-usage", image.referenceCount > 0 && "is-used"]} title={usageText(image)}>
                  {usageText(image)}
                </div>
                <div class="image-card-footer">
                  <time datetime={image.createdAt}>{formatCreatedAt(image.createdAt)}</time>
                  <form
                    action={`/api/admin/images/${encodeURIComponent(image.id)}/delete`}
                    method="post"
                    onsubmit="return confirm('确定删除这张图片及其 R2 对象？此操作不可恢复。')"
                  >
                    <button
                      class="image-delete"
                      type="submit"
                      disabled={image.referenceCount > 0}
                      title={image.referenceCount > 0 ? "图片仍有引用，不能删除" : "删除图片"}
                    >删除</button>
                  </form>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}

    {library.pageCount > 1 && (
      <nav class="image-pagination" aria-label="图片分页">
        <a class:list={["button secondary", library.page <= 1 && "is-disabled"]} href={library.page > 1 ? pageHref(library.page - 1) : undefined}>上一页</a>
        <span>第 {library.page} / {library.pageCount} 页</span>
        <a class:list={["button secondary", library.page >= library.pageCount && "is-disabled"]} href={library.page < library.pageCount ? pageHref(library.page + 1) : undefined}>下一页</a>
      </nav>
    )}
  </section>
</AdminLayout>

<script>
  const uploadForm = document.querySelector<HTMLFormElement>("#image-upload-form");
  const fileInput = document.querySelector<HTMLInputElement>("#image-files");
  const uploadButton = document.querySelector<HTMLButtonElement>("#image-upload-button");
  const clearButton = document.querySelector<HTMLButtonElement>("#image-clear-button");
  const uploadStatus = document.querySelector<HTMLElement>("#image-upload-status");
  const uploadQueue = document.querySelector<HTMLElement>("#image-upload-queue");

  const maxDimension = 1600;
  const webpQuality = 0.82;
  let selectedFiles: File[] = [];
  const previewUrls = new Map<File, string>();

  type DecodedImage = {
    source: CanvasImageSource;
    width: number;
    height: number;
    release: () => void;
  };

  function releasePreviews(): void {
    for (const url of previewUrls.values()) URL.revokeObjectURL(url);
    previewUrls.clear();
  }

  function formatLocalBytes(value: number): string {
    if (value < 1024 * 1024) return `${(value / 1024).toFixed(1)} KB`;
    return `${(value / (1024 * 1024)).toFixed(2)} MB`;
  }

  function renderUploadQueue(): void {
    if (!uploadQueue || !uploadButton || !clearButton || !uploadStatus) return;
    uploadQueue.replaceChildren();
    uploadQueue.hidden = selectedFiles.length === 0;
    uploadButton.disabled = selectedFiles.length === 0;
    clearButton.disabled = selectedFiles.length === 0;
    uploadStatus.textContent = selectedFiles.length > 0 ? `待上传 ${selectedFiles.length} 张图片` : "尚未选择图片";

    selectedFiles.forEach((file, index) => {
      const previewUrl = previewUrls.get(file) ?? URL.createObjectURL(file);
      previewUrls.set(file, previewUrl);
      const item = document.createElement("article");
      item.className = "upload-queue-item";

      const image = document.createElement("img");
      image.src = previewUrl;
      image.alt = file.name;

      const body = document.createElement("div");
      const name = document.createElement("strong");
      name.textContent = file.name;
      const size = document.createElement("span");
      size.textContent = formatLocalBytes(file.size);
      body.append(name, size);

      const remove = document.createElement("button");
      remove.type = "button";
      remove.className = "upload-remove";
      remove.textContent = "移除";
      remove.setAttribute("aria-label", `移除 ${file.name}`);
      remove.addEventListener("click", () => {
        const url = previewUrls.get(file);
        if (url) URL.revokeObjectURL(url);
        previewUrls.delete(file);
        selectedFiles.splice(index, 1);
        renderUploadQueue();
      });

      item.append(image, body, remove);
      uploadQueue.append(item);
    });
  }

  async function decodeImage(file: File): Promise<DecodedImage> {
    if ("createImageBitmap" in window) {
      const bitmap = await createImageBitmap(file);
      return {
        source: bitmap,
        width: bitmap.width,
        height: bitmap.height,
        release: () => bitmap.close(),
      };
    }

    const objectUrl = URL.createObjectURL(file);
    const image = new Image();
    image.decoding = "async";
    image.src = objectUrl;
    await image.decode();
    return {
      source: image,
      width: image.naturalWidth,
      height: image.naturalHeight,
      release: () => URL.revokeObjectURL(objectUrl),
    };
  }

  function canvasToBlob(canvas: HTMLCanvasElement): Promise<Blob> {
    return new Promise((resolve, reject) => {
      canvas.toBlob((blob) => blob ? resolve(blob) : reject(new Error("浏览器无法生成 WebP。")), "image/webp", webpQuality);
    });
  }

  async function compressImage(file: File): Promise<File> {
    const decoded = await decodeImage(file);
    try {
      const scale = Math.min(1, maxDimension / Math.max(decoded.width, decoded.height));
      const width = Math.max(1, Math.round(decoded.width * scale));
      const height = Math.max(1, Math.round(decoded.height * scale));
      const canvas = document.createElement("canvas");
      canvas.width = width;
      canvas.height = height;
      const context = canvas.getContext("2d", { alpha: true });
      if (!context) throw new Error("浏览器无法创建图片画布。");
      context.drawImage(decoded.source, 0, 0, width, height);
      const blob = await canvasToBlob(canvas);
      const baseName = file.name.replace(/\.[^.]+$/u, "").trim() || "image";
      return new File([blob], `${baseName}.webp`, { type: "image/webp", lastModified: Date.now() });
    } finally {
      decoded.release();
    }
  }

  function uploadErrorMessage(code: string): string {
    const messages: Record<string, string> = {
      file: "图片文件无效",
      "too-large": "压缩后仍超过 8 MB",
      format: "图片格式或文件内容无效",
      read: "服务端读取图片失败",
      storage: "R2 或 D1 写入失败",
    };
    return messages[code] ?? "上传失败";
  }

  fileInput?.addEventListener("change", () => {
    releasePreviews();
    selectedFiles = Array.from(fileInput.files ?? []);
    renderUploadQueue();
  });

  clearButton?.addEventListener("click", () => {
    releasePreviews();
    selectedFiles = [];
    if (fileInput) fileInput.value = "";
    renderUploadQueue();
  });

  uploadForm?.addEventListener("submit", async (event) => {
    const files = [...selectedFiles];
    if (files.length === 0 || !uploadButton || !uploadStatus) return;

    event.preventDefault();
    uploadButton.disabled = true;
    if (clearButton) clearButton.disabled = true;
    let uploaded = 0;
    const failed: string[] = [];

    for (const [index, file] of files.entries()) {
      try {
        uploadStatus.textContent = `正在压缩 ${index + 1}/${files.length}：${file.name}`;
        const compressed = await compressImage(file);
        const body = new FormData();
        body.set("file", compressed);
        body.set("originalName", file.name);

        uploadStatus.textContent = `正在上传 ${index + 1}/${files.length}：${file.name}`;
        const response = await fetch(uploadForm.action, {
          method: "POST",
          headers: { Accept: "application/json" },
          body,
          credentials: "same-origin",
        });
        const payload = await response.json().catch(() => ({ ok: false, error: "unknown" })) as { ok?: boolean; error?: string };
        if (!response.ok || !payload.ok) throw new Error(uploadErrorMessage(payload.error ?? "unknown"));
        uploaded += 1;
      } catch (error) {
        failed.push(`${file.name}：${error instanceof Error ? error.message : "上传失败"}`);
      }
    }

    if (failed.length === 0) {
      releasePreviews();
      const target = new URL("/admin/images", window.location.href);
      target.searchParams.set("saved", "uploaded");
      target.searchParams.set("count", String(uploaded));
      window.location.assign(target);
      return;
    }

    uploadStatus.textContent = `成功 ${uploaded} 张，失败 ${failed.length} 张：${failed.join("；")}`;
    uploadButton.disabled = false;
    if (clearButton) clearButton.disabled = false;
  });

  window.addEventListener("pagehide", releasePreviews, { once: true });

  const selectUnusedButton = document.querySelector<HTMLButtonElement>("#select-unused-button");
  const bulkDeleteButton = document.querySelector<HTMLButtonElement>("#bulk-delete-button");
  const bulkCheckboxes = Array.from(document.querySelectorAll<HTMLInputElement>(".bulk-image-checkbox"));

  function updateBulkState(): void {
    if (!bulkDeleteButton || !selectUnusedButton) return;
    const checked = bulkCheckboxes.filter((checkbox) => checkbox.checked).length;
    bulkDeleteButton.disabled = checked === 0;
    bulkDeleteButton.textContent = checked > 0 ? `删除已选（${checked}）` : "删除已选";
    selectUnusedButton.textContent = checked === bulkCheckboxes.length && checked > 0 ? "取消全选" : "选择本页未引用";
  }

  bulkCheckboxes.forEach((checkbox) => checkbox.addEventListener("change", updateBulkState));
  selectUnusedButton?.addEventListener("click", () => {
    const shouldSelect = !bulkCheckboxes.every((checkbox) => checkbox.checked);
    bulkCheckboxes.forEach((checkbox) => { checkbox.checked = shouldSelect; });
    updateBulkState();
  });
  updateBulkState();
</script>

<style>
  .upload-card { margin-bottom: .8rem; }
  .upload-card .admin-section-bar { align-items: center; }
  .image-limit { color: #d8b477; font-size: .7rem; white-space: nowrap; }
  .upload-form { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: .65rem; align-items: end; }
  .upload-drop {
    display: grid;
    min-height: 5.25rem;
    place-content: center;
    gap: .25rem;
    padding: .75rem;
    border: 1px dashed #45404c;
    border-radius: .45rem;
    color: #a8a1ae;
    background: #0d0c10;
    cursor: pointer;
    text-align: center;
  }
  .upload-drop:hover { border-color: #9d7942; background: #111014; }
  .upload-drop strong { color: var(--text); font-size: .86rem; }
  .upload-drop span { font-size: .7rem; }
  .upload-drop input { max-width: 26rem; margin-top: .35rem; font-size: .72rem; }
  .upload-actions { display: grid; min-width: 10.5rem; gap: .4rem; }
  .upload-actions .button { width: 100%; }
  .upload-actions .admin-section-note { max-width: 18rem; line-height: 1.45; }
  .upload-queue { grid-column: 1 / -1; display: grid; grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr)); gap: .4rem; padding-top: .1rem; }
  .upload-queue[hidden] { display: none; }
  .upload-queue-item { display: grid; grid-template-columns: 3.5rem minmax(0, 1fr) auto; gap: .4rem; align-items: center; overflow: hidden; border: 1px solid #302d36; border-radius: .4rem; padding: .35rem; background: #0d0c10; }
  .upload-queue-item img { width: 3.5rem; height: 3.5rem; border-radius: .3rem; object-fit: cover; background: #070709; }
  .upload-queue-item > div { display: grid; min-width: 0; gap: .15rem; }
  .upload-queue-item strong { overflow: hidden; font-size: .7rem; text-overflow: ellipsis; white-space: nowrap; }
  .upload-queue-item span { color: #7f7985; font-size: .62rem; }
  .upload-remove { border: 0; color: #e28b8b; background: transparent; cursor: pointer; font-size: .65rem; }

  .library-card { overflow: hidden; }
  .library-toolbar { align-items: center; }
  .library-maintenance { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: .4rem; }
  .library-maintenance form { margin: 0; }
  .image-search { display: grid; grid-template-columns: minmax(12rem, 1fr) 8rem auto auto; gap: .4rem; padding: .55rem; border-bottom: 1px solid #242129; }
  .image-search input,
  .image-search select { min-height: 2.05rem; border: 1px solid #302d36; border-radius: .3rem; padding: .35rem .5rem; color: var(--text); background: #0d0c10; }

  .image-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(11.5rem, 1fr)); gap: .55rem; padding: .55rem; }
  .image-card { position: relative; min-width: 0; overflow: hidden; border: 1px solid #29262e; border-radius: .45rem; background: #0d0c10; }
  .image-card:has(.bulk-image-checkbox:checked) { border-color: #b78748; box-shadow: 0 0 0 2px rgba(231,189,121,.1); }
  .image-select { position: absolute; z-index: 4; top: .38rem; left: .38rem; display: grid; width: 1.5rem; height: 1.5rem; place-items: center; border: 1px solid rgba(255,255,255,.2); border-radius: .35rem; background: rgba(8,7,10,.82); backdrop-filter: blur(8px); }
  .image-select input { width: 1rem; height: 1rem; margin: 0; accent-color: #c08a4c; }
  .image-preview { display: block; aspect-ratio: 4 / 3; overflow: hidden; background: #070709; }
  .image-preview img { width: 100%; height: 100%; object-fit: cover; transition: transform .18s ease; }
  .image-preview:hover img { transform: scale(1.025); }
  .image-card-body { display: grid; gap: .32rem; padding: .48rem; }
  .image-card-body strong { overflow: hidden; font-size: .75rem; text-overflow: ellipsis; white-space: nowrap; }
  .image-card-body code { overflow: hidden; color: #77717e; font-size: .61rem; text-overflow: ellipsis; white-space: nowrap; }
  .image-meta { display: flex; flex-wrap: wrap; gap: .25rem .45rem; color: #99929f; font-size: .63rem; }
  .image-usage { overflow: hidden; color: #817b87; font-size: .64rem; text-overflow: ellipsis; white-space: nowrap; }
  .image-usage.is-used { color: #65d99c; }
  .image-card-footer { display: flex; align-items: center; justify-content: space-between; gap: .5rem; padding-top: .15rem; }
  .image-card-footer time { color: #66606c; font-size: .6rem; }
