---
import "@/styles/global.css";
export const prerender = false;
const failed = Astro.url.searchParams.get("error") === "1";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="color-scheme" content="light" />
    <title>后台登录</title>
  </head>
  <body class="admin-login-body">
    <main class="admin-login-shell">
      <section class="admin-login-card">
        <header class="admin-login-header">
          <span class="admin-login-mark" aria-hidden="true">◆</span>
          <div>
            <strong>管理后台</strong>
            <span>管理员登录</span>
          </div>
        </header>
        {failed && <p class="error" role="alert">密码错误，请重新输入。</p>}
        <form action="/api/admin/login" method="post">
          <div class="field">
            <label for="password">管理员密码</label>
            <input id="password" name="password" type="password" required autocomplete="current-password" autofocus />
          </div>
          <button class="button full" type="submit">登录</button>
        </form>
      </section>
    </main>
  </body>
</html>

<style>
  .admin-login-body { min-height: 100vh; color-scheme: light; color: #0f172a; background: #f4f7fb; }
  .admin-login-shell { display: grid; min-height: 100vh; place-items: center; padding: 1rem; }
  .admin-login-card { width: min(100%, 22rem); border: 1px solid #dbe3ed; border-radius: .7rem; padding: 1rem; background: #fff; box-shadow: 0 8px 28px rgba(15,23,42,.08); }
  .admin-login-header { display: flex; align-items: center; gap: .65rem; margin-bottom: .85rem; }
  .admin-login-header > div { display: grid; gap: .08rem; }
  .admin-login-header strong { font-size: .95rem; }
  .admin-login-header span { color: #64748b; font-size: .75rem; }
  .admin-login-mark { display: grid; width: 2rem; height: 2rem; place-items: center; border-radius: .45rem; color: #fff !important; background: #2563eb; }
  .admin-login-card .field { margin: .6rem 0; }
  .admin-login-card .field label { color: #334155; font-size: .75rem; font-weight: 680; }
  .admin-login-card .field input { border-color: #cbd5e1; color: #0f172a; background: #fff; }
  .admin-login-card .button { min-height: 2.35rem; border-radius: .42rem; color: #fff; background: #2563eb; }
</style>
