---
import "@/styles/global.css";
export const prerender = false;
const failed = Astro.url.searchParams.get("error") === "1";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>后台登录</title>
  </head>
  <body>
    <main class="admin-shell">
      <section class="form-card panel">
        <a class="brand" href="/"><span class="brand-mark">S</span><span>管理后台</span></a>
        <h1 style="font-size:2rem; margin-top:2rem">管理员登录</h1>
        <p>请输入 GitHub Secret 中配置的后台管理员密码。</p>
        {failed && <p class="error" role="alert">密码错误，请重新输入。</p>}
        <form action="/api/admin/login" method="post">
          <div class="field">
            <label for="password">管理员密码</label>
            <input id="password" name="password" type="password" required autocomplete="current-password" autofocus />
          </div>
          <button class="button full" type="submit">登录</button>
        </form>
      </section>
    </main>
  </body>
</html>
