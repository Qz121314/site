---
import AdminLayout from "@/layouts/AdminLayout.astro";
import DirectImageUpload from "@/components/admin/DirectImageUpload.astro";
import { loadAdminChannels, loadAdminSiteSettings } from "@/lib/db/site";

export const prerender = false;

const [settings, channels] = await Promise.all([
  loadAdminSiteSettings(),
  loadAdminChannels(),
]);

const saved = Astro.url.searchParams.get("saved");
const error = Astro.url.searchParams.get("error");
const formId = "site-settings-form";

const errorMessages: Record<string, string> = {
  "site-name": "网站名称不能为空，且不能超过 80 个字符。",
  description: "网站描述不能超过 300 个字符。",
  "default-channel": "默认分区不存在，请重新选择。",
  image: "Logo 或 Favicon 图片记录无效，请重新上传。",
  "r2-url": "R2 公开域名必须是完整的 HTTPS 域名，不能包含路径、参数或账号信息。",
  ga4: "GA4 Measurement ID 格式无效，例如 G-XXXXXXXXXX。",
  meta: "Meta Pixel ID 只能包含 5 至 30 位数字。",
  privacy: "隐私政策内容不能超过 20000 个字符。",
  disclaimer: "免责声明内容不能超过 20000 个字符。",
  database: "数据库保存失败，请稍后重试。",
};
---

<AdminLayout title="站点设置">
  <button slot="actions" class="button" type="submit" form={formId}>保存设置</button>

  {saved === "1" && (
    <p class="notice" role="status">
      站点设置已保存。公共页面缓存最长约 30 秒；当前后台浏览器打开前台预览时不使用公共缓存。
    </p>
  )}
  {error && errorMessages[error] && <p class="error" role="alert">{errorMessages[error]}</p>}
  {!settings.databaseReady && <p class="error" role="alert">D1 数据暂时不可用，当前显示的是默认值。</p>}

  <form id={formId} class="admin-stack settings-form" action="/api/admin/settings/update" method="post">
    <section class="admin-card">
      <div class="admin-section-bar">
        <h2>基础设置</h2>
        <span class="admin-section-note">全站级低频配置</span>
      </div>
      <div class="admin-card-body admin-form-grid">
        <div class="admin-field admin-span-3">
          <label for="site-name">网站名称</label>
          <input id="site-name" name="siteName" maxlength="80" required value={settings.siteName} />
        </div>

        <div class="admin-field admin-span-5">
          <label for="site-description">网站描述</label>
          <input id="site-description" name="siteDescription" maxlength="300" value={settings.siteDescription} />
        </div>

        <div class="admin-field admin-span-4">
          <label for="default-channel">默认分区</label>
          <select id="default-channel" name="defaultChannelId">
            <option value="">未设置</option>
            {channels.map((channel) => (
              <option value={channel.id} selected={settings.defaultChannelId === channel.id}>{channel.name}</option>
            ))}
          </select>
        </div>

        <div class="admin-field admin-span-8">
          <label for="r2-public-base-url">R2 图片公开域名</label>
          <input
            id="r2-public-base-url"
            name="r2PublicBaseUrl"
            type="url"
            maxlength="240"
            inputmode="url"
            placeholder="https://media.example.com"
            value={settings.r2PublicBaseUrl}
          />
          <small>先在 Cloudflare R2 绑定自定义域名，再录入此处；数据库只保存图片 Object Key。</small>
        </div>

        <div class="admin-field admin-span-2">
          <label for="ga4-id">GA4 ID</label>
          <input id="ga4-id" name="ga4Id" maxlength="24" autocomplete="off" placeholder="G-XXXXXXXXXX" value={settings.ga4Id} />
        </div>

        <div class="admin-field admin-span-2">
          <label for="meta-pixel-id">Meta Pixel ID</label>
          <input id="meta-pixel-id" name="metaPixelId" maxlength="30" inputmode="numeric" autocomplete="off" value={settings.metaPixelId} />
        </div>
      </div>
    </section>

    <section class="admin-card settings-assets">
      <div class="admin-section-bar">
        <div>
          <h2>Logo 与 Favicon</h2>
          <span class="admin-section-note">图片在站点设置中直接上传，不经过图片库录入</span>
        </div>
      </div>
      <div class="admin-card-body settings-asset-grid">
        <DirectImageUpload
          id="site-logo-upload"
          name="logoAssetId"
          label="Logo"
          form={formId}
          value={settings.logoAssetId}
          help="未上传时前台只显示网站名称；建议使用横向或方形透明图片。"
        />
        <DirectImageUpload
          id="site-favicon-upload"
          name="faviconAssetId"
          label="Favicon"
          form={formId}
          value={settings.faviconAssetId}
          help="建议使用方形图片，浏览器会自动缩放。"
        />
      </div>
    </section>

    <section class="admin-card legal-settings">
      <div class="admin-section-bar">
        <div>
          <h2>法律与访问控制</h2>
          <span class="admin-section-note">管理年龄提示、隐私政策和免责声明；公开页面固定允许搜索引擎收录</span>
        </div>
      </div>
      <div class="admin-card-body admin-form-grid">
        <div class="admin-field admin-span-12">
          <label>访问控制</label>
          <div class="settings-checks">
            <label class="admin-check" title="首次进入前台时显示 18+ 确认">
              <input type="checkbox" name="adultGateEnabled" value="1" checked={settings.adultGateEnabled} />
              <span>开启 18+ 年龄提示</span>
            </label>
          </div>
          <small>启用后，访客首次进入时需要确认已达到所在地区的法定年龄。</small>
        </div>

        <div class="admin-field admin-span-6">
          <label for="privacy-content">Privacy 隐私政策</label>
          <textarea
            id="privacy-content"
            name="privacyContent"
            maxlength="20000"
            rows="4"
            data-auto-grow
            placeholder="填写网站如何使用 Cookie、GA4、Meta Pixel 以及第三方服务等信息。"
          >{settings.privacyContent}</textarea>
          <small>保存后显示在前台 /privacy 页面。</small>
        </div>

        <div class="admin-field admin-span-6">
          <label for="disclaimer-content">Disclaimer 免责声明</label>
          <textarea
            id="disclaimer-content"
            name="disclaimerContent"
            maxlength="20000"
            rows="4"
            data-auto-grow
            placeholder="填写第三方服务、外部链接、年龄限制和责任边界等说明。"
          >{settings.disclaimerContent}</textarea>
          <small>保存后显示在前台 /disclaimer 页面。</small>
        </div>
      </div>
    </section>
  </form>
</AdminLayout>

<style>
  .settings-form { width: min(100%, 64rem); margin: 0 auto; }
  .settings-checks { display: flex; min-height: 2.15rem; align-items: center; gap: .65rem; white-space: nowrap; }
  .legal-settings textarea { min-height: 6rem; line-height: 1.5; }
  .settings-asset-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .55rem; }
  @media (max-width: 767px) { .settings-asset-grid { grid-template-columns: 1fr; } }
  @media (max-width: 959px) { .settings-checks { flex-wrap: wrap; gap: .25rem .65rem; } }
</style>