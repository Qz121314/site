---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { loadAdminCounts } from "@/lib/db/site";

export const prerender = false;
const counts = await loadAdminCounts();
const metrics = [
  ["分区", counts.channels],
  ["分类", counts.categories],
  ["产品", counts.products],
  ["图片资产", counts.images],
] as const;
---

<AdminLayout title="概览">
  <section class="grid metrics">
    {metrics.map(([label, value]) => <article class="metric panel"><span>{label}</span><strong>{value}</strong></article>)}
  </section>

  <section class="admin-card" style="margin-top:.55rem">
    <div class="admin-section-bar">
      <h2>系统状态</h2>
      <span class:list={["badge", counts.databaseReady ? "ok" : "warn"]}>{counts.databaseReady ? "数据库正常" : "数据库异常"}</span>
    </div>
    <div class="admin-card-body">
      <p>{counts.databaseReady ? "D1 数据库连接正常。后台采用分区独立管理，新增分区后会立即显示在左侧菜单。" : "Worker 已运行，但 D1 数据表不可用，请检查 GitHub Actions 和数据库迁移日志。"}</p>
    </div>
  </section>
</AdminLayout>
