---
import PublicLayout from "@/layouts/PublicLayout.astro";
import ProductGallery from "@/components/public/ProductGallery.astro";
import { loadPublicProductDetail, loadPublicSiteShell } from "@/lib/db/public";
import { productDescription } from "@/lib/public/seo";

export const prerender = false;

const channelSlug = Astro.params.channel ?? "";
const productSlug = Astro.params.product ?? "";
const site = await loadPublicSiteShell();
const product = await loadPublicProductDetail(channelSlug, productSlug, site.r2PublicBaseUrl);

if (!product) Astro.response.status = 404;

const canonical = product
  ? new URL(
      `/${encodeURIComponent(product.channelSlug)}/product/${encodeURIComponent(product.slug)}`,
      Astro.url.origin,
    ).href
  : null;
const primaryImage = product?.coverUrl ?? product?.gallery[0]?.imageUrl ?? site.logoUrl;
const galleryImagesWithDuplicates = product
  ? [
      ...(primaryImage
        ? [{
            imageUrl: primaryImage,
            responsiveImageUrl: product.coverUrl === primaryImage ? product.coverResponsiveUrl : (product.gallery[0]?.responsiveImageUrl ?? null),
            alt: product.title,
            width: product.coverUrl === primaryImage ? product.coverWidth : (product.gallery[0]?.width ?? null),
            height: product.coverUrl === primaryImage ? product.coverHeight : (product.gallery[0]?.height ?? null),
            responsiveWidth: product.coverUrl === primaryImage ? product.coverResponsiveWidth : (product.gallery[0]?.responsiveWidth ?? null),
            responsiveHeight: product.coverUrl === primaryImage ? product.coverResponsiveHeight : (product.gallery[0]?.responsiveHeight ?? null),
          }]
        : []),
      ...product.gallery.map((image) => ({
        imageUrl: image.imageUrl,
        responsiveImageUrl: image.responsiveImageUrl,
        alt: image.originalName || product.title,
        width: image.width,
        height: image.height,
        responsiveWidth: image.responsiveWidth,
        responsiveHeight: image.responsiveHeight,
      })),
    ]
  : [];
const galleryImages = Array.from(
  new Map(galleryImagesWithDuplicates.map((image) => [image.imageUrl, image])).values(),
);
const contactResolveUrl = product
  ? `/go/${encodeURIComponent(product.slug)}?channel=${encodeURIComponent(product.channelSlug)}`
  : "";
const returnUrl = product?.categorySlug
  ? product.hasCategoryNavigation
    ? `/${encodeURIComponent(product.channelSlug)}/category/${encodeURIComponent(product.categorySlug)}`
    : `/${encodeURIComponent(product.channelSlug)}?category=${encodeURIComponent(product.categorySlug)}`
  : product
    ? `/${encodeURIComponent(product.channelSlug)}`
    : `/${encodeURIComponent(channelSlug)}`;
const description = product
  ? productDescription({
      title: product.title,
      bodyHtml: product.bodyHtml,
      tags: product.tags,
      siteDescription: site.siteDescription,
    })
  : "The requested product could not be found.";
const channelUrl = product
  ? new URL(`/${encodeURIComponent(product.channelSlug)}`, Astro.url.origin).href
  : null;
const categoryUrl = product?.categorySlug
  ? new URL(
      product.hasCategoryNavigation
        ? `/${encodeURIComponent(product.channelSlug)}/category/${encodeURIComponent(product.categorySlug)}`
        : `/${encodeURIComponent(product.channelSlug)}?category=${encodeURIComponent(product.categorySlug)}`,
      Astro.url.origin,
    ).href
  : null;
const breadcrumbItems = product && canonical && channelUrl
  ? [
      {
        "@type": "ListItem",
        position: 1,
        name: product.channelName,
        item: channelUrl,
      },
      ...(product.categoryName && categoryUrl
        ? [{
            "@type": "ListItem",
            position: 2,
            name: product.categoryName,
            item: categoryUrl,
          }]
        : []),
      {
        "@type": "ListItem",
        position: product.categoryName && categoryUrl ? 3 : 2,
        name: product.title,
        item: canonical,
      },
    ]
  : [];
const structuredData = product && canonical
  ? {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Product",
          "@id": `${canonical}#product`,
          name: product.title,
          description,
          url: canonical,
          category: product.categoryName ?? product.channelName,
          brand: {
            "@type": "Brand",
            name: site.siteName,
          },
          ...(galleryImages.length > 0
            ? { image: galleryImages.map((image) => image.imageUrl) }
            : {}),
        },
        {
          "@type": "BreadcrumbList",
          itemListElement: breadcrumbItems,
        },
      ],
    }
  : null;
---

<PublicLayout
  site={site}
  title={product?.title ?? "Page not found"}
  description={description}
  canonical={canonical}
  robots={product ? undefined : "noindex,follow"}
  ogImage={primaryImage}
  ogImageAlt={product?.title ?? null}
  ogImageWidth={product?.coverUrl === primaryImage ? product.coverWidth : (product?.gallery[0]?.width ?? null)}
  ogImageHeight={product?.coverUrl === primaryImage ? product.coverHeight : (product?.gallery[0]?.height ?? null)}
  ogType="product"
  activeChannel={product?.channelSlug ?? channelSlug}
  backHref={product ? returnUrl : null}
  showChannelNavigation={false}
  structuredData={structuredData}
>
  {product ? (
    <article class="product-detail">
      <header class="product-detail-title">
        <h1>{product.title}</h1>
      </header>

      <div class="product-detail-media">
        <ProductGallery images={galleryImages} />
      </div>

      <div class="product-detail-information">
        {product.bodyHtml && (
          <section class="product-copy-section">
            <div class="product-body markdown-body" set:html={product.bodyHtml}></div>
          </section>
        )}

        {product.hasConversion && (
          <div class="product-cta-bar" data-contact-box>
            <a
              class="public-button product-cta-button"
              href={contactResolveUrl}
              rel="nofollow sponsored"
              data-contact-cta
              data-resolve-url={contactResolveUrl}
            >
              <span class="product-cta-label" data-contact-label aria-live="polite">{product.ctaLabel}</span>
            </a>

            <div class="product-cta-resolved" data-contact-resolved hidden>
              <a class="product-cta-open" href={contactResolveUrl} rel="nofollow sponsored" data-contact-open>
                <span class="product-cta-action-kind" data-contact-sms-icon hidden aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M5 6.5h14v9H9l-4 3v-12Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
                    <path d="M8.5 10h7M8.5 13h4.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
                  </svg>
                </span>
                <span class="product-cta-action-kind" data-contact-link-icon hidden aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="m9.5 14.5 5-5M7.25 16.75l-1 1a3.18 3.18 0 0 1-4.5-4.5l3-3a3.18 3.18 0 0 1 4.5 0M16.75 7.25l1-1a3.18 3.18 0 1 1 4.5 4.5l-3 3a3.18 3.18 0 0 1-4.5 0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
                  </svg>
                </span>
                <span class="product-cta-resolved-value" data-contact-value></span>
                <svg class="product-cta-open-arrow" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M7 17 17 7M9 7h8v8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
                </svg>
              </a>

              <button class="product-cta-copy-button" type="button" data-contact-copy aria-label="Copy contact">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="8" y="8" width="10" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="1.7" />
                  <path d="M15 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h2" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.7" />
                </svg>
                <span data-contact-copy-label>Copy</span>
              </button>
            </div>
          </div>
        )}
      </div>
    </article>
  ) : (
    <section class="public-section">
      <div class="public-empty public-error-card">
        <div>
          <div class="empty-icon" aria-hidden="true">404</div>
          <h1>Product not found</h1>
          <a class="public-button secondary" href={`/${encodeURIComponent(channelSlug)}`}>Return</a>
        </div>
      </div>
    </section>
  )}
</PublicLayout>

{product?.hasConversion && <script>import "@/scripts/public-product-cta";</script>}

<style>
  .product-detail-title {
    display: grid;
    justify-items: center;
    padding-inline: 1rem;
    text-align: center;
  }

  .product-detail-title h1 {
    max-width: min(100%, 38rem);
    margin-inline: auto;
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  .product-detail-media,
  .product-detail-information {
    display: grid;
    min-width: 0;
    gap: 1rem;
  }

  .product-cta-bar {
    display: block;
    padding: .42rem;
  }

  .product-cta-button {
    position: relative;
    isolation: isolate;
    display: flex;
    min-height: 3.65rem;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: .8rem 1rem;
    border-radius: 1rem;
    transform-origin: center;
  }

  .product-cta-button::before,
  .product-cta-resolved::before {
    position: absolute;
    z-index: -1;
    inset: 0;
    content: "";
    background: linear-gradient(112deg, rgba(255, 255, 255, .2), transparent 34%, transparent 67%, rgba(255, 255, 255, .09));
    pointer-events: none;
  }

  .product-cta-label {
    min-width: 0;
    overflow: hidden;
    font-variant-numeric: tabular-nums;
    font-weight: 800;
    letter-spacing: .075em;
    text-align: center;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .product-cta-button[aria-busy="true"] {
    cursor: progress;
    filter: saturate(.82) brightness(.98);
  }

  .product-cta-button[hidden],
  .product-cta-resolved[hidden],
  .product-cta-action-kind[hidden] {
    display: none;
  }

  .product-cta-resolved {
    position: relative;
    isolation: isolate;
    display: grid;
    min-height: 3.65rem;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: stretch;
    overflow: hidden;
    border: 1px solid var(--brand-line);
    border-radius: 1rem;
    color: #fff;
    background: var(--brand-soft);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, .24),
      0 12px 30px rgba(0, 0, 0, .24);
    transform-origin: center;
  }

  .product-cta-open {
    display: grid;
    min-width: 0;
    grid-template-columns: 1.15rem minmax(0, 1fr) 1.05rem;
    align-items: center;
    gap: .62rem;
    padding: .72rem .9rem;
    color: inherit;
    text-decoration: none;
  }

  .product-cta-action-kind,
  .product-cta-action-kind svg,
  .product-cta-open-arrow,
  .product-cta-copy-button svg {
    width: 1.05rem;
    height: 1.05rem;
    flex: 0 0 auto;
  }

  .product-cta-resolved-value {
    min-width: 0;
    overflow: hidden;
    font-size: .84rem;
    font-variant-numeric: tabular-nums;
    font-weight: 800;
    letter-spacing: .02em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .product-cta-open-arrow {
    opacity: .82;
  }

  .product-cta-copy-button {
    display: flex;
    min-width: 5.75rem;
    align-items: center;
    justify-content: center;
    gap: .42rem;
    border: 0;
    border-left: 1px solid rgba(255, 255, 255, .18);
    padding: .7rem .82rem;
    color: #fff;
    background: rgba(255, 255, 255, .075);
    cursor: pointer;
    font: inherit;
    font-size: .73rem;
    font-weight: 800;
    letter-spacing: .035em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .product-cta-open:hover,
  .product-cta-copy-button:hover {
    background: rgba(255, 255, 255, .075);
  }

  .product-cta-open:active,
  .product-cta-copy-button:active {
    background: rgba(255, 255, 255, .12);
  }

  .product-cta-resolved.is-resolved {
    animation: product-cta-grow 220ms cubic-bezier(.2, .8, .25, 1);
  }

  @keyframes product-cta-grow {
    0% { transform: scale(.985); opacity: .72; }
    60% { transform: scale(1.01); opacity: 1; }
    100% { transform: scale(1); opacity: 1; }
  }

  @media (max-width: 420px) {
    .product-cta-button {
      padding-inline: .8rem;
      font-size: .9rem;
    }

    .product-cta-open {
      gap: .48rem;
      padding-inline: .72rem;
    }

    .product-cta-resolved-value {
      font-size: .78rem;
    }

    .product-cta-copy-button {
      min-width: 5rem;
      gap: .32rem;
      padding-inline: .62rem;
      font-size: .68rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-cta-resolved.is-resolved { animation: none; }
  }
</style>
