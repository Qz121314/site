---
import PublicLayout from "@/layouts/PublicLayout.astro";
import ProductGallery from "@/components/public/ProductGallery.astro";
import PublicPageHeader from "@/components/public/PublicPageHeader.astro";
import { loadPublicProductDetail, loadPublicSiteShell } from "@/lib/db/public";
import { publicProductHasEnabledConversion } from "@/lib/db/public-availability";

export const prerender = false;

const channelSlug = Astro.params.channel ?? "";
const productSlug = Astro.params.product ?? "";
const site = await loadPublicSiteShell();
const product = await loadPublicProductDetail(channelSlug, productSlug, site.r2PublicBaseUrl);
const hasConversion = product ? await publicProductHasEnabledConversion(product.id) : false;

if (!product) Astro.response.status = 404;

const canonical = product
  ? new URL(
      `/${encodeURIComponent(product.channelSlug)}/product/${encodeURIComponent(product.slug)}`,
      Astro.url.origin,
    ).href
  : null;
const primaryImage = product?.coverUrl ?? product?.gallery[0]?.imageUrl ?? site.logoUrl;
const galleryImages = product
  ? [
      ...(primaryImage ? [{ imageUrl: primaryImage, alt: product.title }] : []),
      ...product.gallery.map((image) => ({
        imageUrl: image.imageUrl,
        alt: image.originalName || product.title,
        width: image.width,
        height: image.height,
      })),
    ]
  : [];
const contactResolveUrl = product
  ? `/go/${encodeURIComponent(product.slug)}?channel=${encodeURIComponent(product.channelSlug)}`
  : "";
const returnUrl = product?.categorySlug
  ? `/${encodeURIComponent(product.channelSlug)}/category/${encodeURIComponent(product.categorySlug)}`
  : product
    ? `/${encodeURIComponent(product.channelSlug)}`
    : `/${encodeURIComponent(channelSlug)}`;
---

<PublicLayout
  site={site}
  title={product?.title ?? "Page not found"}
  description={product ? `${product.title}${product.tags.length > 0 ? ` — ${product.tags.slice(0, 3).join(", ")}` : ""}` : "The requested product could not be found."}
  canonical={canonical}
  robots={product ? undefined : "noindex,follow"}
  ogImage={primaryImage}
  activeChannel={product?.channelSlug ?? channelSlug}
>
  {product ? (
    <article class="product-detail">
      <PublicPageHeader
        href={returnUrl}
        title={product.title}
        className="product-detail-header"
      />

      {product.tags.length > 0 && (
        <div class="product-tags" aria-label="Tags">
          {product.tags.map((tag) => <span class="visual-tag">{tag}</span>)}
        </div>
      )}

      <ProductGallery images={galleryImages} />

      {product.bodyHtml && (
        <section class="product-copy-section">
          <div class="product-body markdown-body" set:html={product.bodyHtml}></div>
        </section>
      )}

      {hasConversion && (
        <div class="product-cta-bar" data-contact-box>
          <a
            class="public-button product-cta-button"
            href={contactResolveUrl}
            rel="nofollow sponsored"
            data-contact-cta
            data-resolve-url={contactResolveUrl}
          >
            <svg class="product-cta-leading-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 6.5h14v9H9l-4 3v-12Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
              <path d="M8.5 10h7M8.5 13h4.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
            </svg>
            <span class="product-cta-label" data-contact-label aria-live="polite">{product.ctaLabel}</span>
            <svg class="product-cta-action-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14 5h5v5M19 5l-8 8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
              <path d="M18 13v5a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
            </svg>
          </a>
        </div>
      )}
    </article>
  ) : (
    <section class="public-section">
      <div class="public-empty public-error-card">
        <div>
          <div class="empty-icon" aria-hidden="true">404</div>
          <h1>Product not found</h1>
          <a class="public-button secondary" href={`/${encodeURIComponent(channelSlug)}`}>Return</a>
        </div>
      </div>
    </section>
  )}
</PublicLayout>

<script is:inline>
  (() => {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    document.querySelectorAll('[data-contact-cta]').forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) return;
      const resolveUrl = link.dataset.resolveUrl || link.href;
      const label = link.querySelector('[data-contact-label]');
      const defaultLabel = label?.textContent?.trim() || 'View Details';

      link.addEventListener('click', async (event) => {
        event.preventDefault();
        if (link.dataset.loading === '1') return;

        link.dataset.loading = '1';
        link.setAttribute('aria-busy', 'true');
        link.classList.remove('is-resolved');
        if (label) label.textContent = 'Connecting…';

        try {
          const response = await fetch(resolveUrl, {
            headers: { Accept: 'application/json' },
            credentials: 'same-origin',
          });
          const result = await response.json();
          if (!response.ok || !result?.ok || !result.contact?.target) throw new Error('unavailable');

          const target = String(result.contact.target);
          const type = result.contact.type === 'sms' ? 'sms' : 'link';
          const rawDisplay = String(result.contact.display || target).trim();
          const display = type === 'sms' ? rawDisplay.replace(/^sms:/iu, '') : rawDisplay;

          link.href = target;
          link.dataset.contactType = type;
          if (label) label.textContent = type === 'sms' ? `SMS · ${display}` : `OPEN · ${display || defaultLabel}`;

          void link.offsetWidth;
          link.classList.add('is-resolved');
          if (!reducedMotion.matches) {
            await new Promise((resolve) => window.setTimeout(resolve, 220));
          }
          window.location.assign(target);
        } catch (error) {
          console.error(error);
          link.classList.remove('is-resolved');
          if (label) {
            label.textContent = 'Temporarily unavailable';
            window.setTimeout(() => {
              if (link.dataset.loading !== '1') label.textContent = defaultLabel;
            }, 1600);
          }
        } finally {
          delete link.dataset.loading;
          link.removeAttribute('aria-busy');
        }
      });
    });
  })();
</script>

<style>
  .product-cta-bar {
    display: block;
    padding: .45rem;
  }

  .product-cta-button {
    position: relative;
    isolation: isolate;
    display: grid;
    min-height: 3.55rem;
    grid-template-columns: 1.2rem minmax(0, 1fr) 1.15rem;
    align-items: center;
    gap: .65rem;
    overflow: hidden;
    padding: .72rem .92rem;
    border-radius: .9rem;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, .42),
      0 14px 34px rgba(154, 95, 28, .26);
    transform-origin: center;
  }

  .product-cta-button::before {
    position: absolute;
    z-index: -1;
    inset: 0;
    content: "";
    background: linear-gradient(112deg, rgba(255, 255, 255, .22), transparent 32%, transparent 68%, rgba(255, 255, 255, .12));
    pointer-events: none;
  }

  .product-cta-leading-icon,
  .product-cta-action-icon {
    width: 1.1rem;
    height: 1.1rem;
    flex: 0 0 auto;
  }

  .product-cta-label {
    min-width: 0;
    overflow: hidden;
    font-variant-numeric: tabular-nums;
    font-weight: 850;
    letter-spacing: .015em;
    text-align: center;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .product-cta-button[aria-busy="true"] {
    cursor: progress;
    filter: saturate(.82) brightness(.98);
  }

  .product-cta-button.is-resolved {
    animation: product-cta-grow 220ms cubic-bezier(.2, .8, .25, 1);
  }

  @keyframes product-cta-grow {
    0% { transform: scale(1); }
    55% { transform: scale(1.018); box-shadow: inset 0 1px 0 rgba(255, 255, 255, .48), 0 18px 42px rgba(186, 119, 38, .34); }
    100% { transform: scale(1); }
  }

  @media (max-width: 420px) {
    .product-cta-button {
      gap: .48rem;
      padding-inline: .72rem;
      font-size: .82rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-cta-button.is-resolved { animation: none; }
  }
</style>
