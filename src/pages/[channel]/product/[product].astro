---
import PublicLayout from "@/layouts/PublicLayout.astro";
import { loadPublicProductDetail, loadPublicSiteShell } from "@/lib/db/public";

export const prerender = false;

const channelSlug = Astro.params.channel ?? "";
const productSlug = Astro.params.product ?? "";
const site = await loadPublicSiteShell();
const product = await loadPublicProductDetail(channelSlug, productSlug, site.r2PublicBaseUrl);

if (!product) Astro.response.status = 404;

const canonical = new URL(
  `/${encodeURIComponent(channelSlug)}/product/${encodeURIComponent(productSlug)}`,
  Astro.url.origin,
).href;
const primaryImage = product?.coverUrl ?? product?.gallery[0]?.imageUrl ?? site.logoUrl;
const remainingGallery = product
  ? product.gallery.filter((image) => image.imageUrl !== primaryImage)
  : [];
const contactResolveUrl = product
  ? `/go/${encodeURIComponent(product.slug)}?channel=${encodeURIComponent(product.channelSlug)}`
  : "";
const returnUrl = product?.categorySlug
  ? `/${encodeURIComponent(product.channelSlug)}/category/${encodeURIComponent(product.categorySlug)}`
  : product
    ? `/${encodeURIComponent(product.channelSlug)}`
    : `/${encodeURIComponent(channelSlug)}`;
const returnLabel = product?.categoryName ?? product?.channelName ?? "channel";
---

<PublicLayout
  site={site}
  title={product?.title ?? "Page not found"}
  description={product ? `${product.title}${product.tags.length > 0 ? ` — ${product.tags.slice(0, 3).join(", ")}` : ""}` : "The requested product could not be found."}
  canonical={canonical}
  ogImage={primaryImage}
  activeChannel={product?.channelSlug ?? channelSlug}
>
  {product ? (
    <article class="product-detail">
      <a class="public-back-link" href={returnUrl}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m15 18-6-6 6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
        </svg>
        <span>Back to {returnLabel}</span>
      </a>

      <header class="product-detail-header">
        <div class="eyebrow">{product.categoryName ?? product.channelName}</div>
        <h1>{product.title}</h1>
        {product.tags.length > 0 && (
          <div class="product-tags" aria-label="Tags">
            {product.tags.map((tag) => <span class="visual-tag">{tag}</span>)}
          </div>
        )}
      </header>

      {primaryImage && (
        <div class="product-cover">
          <img src={primaryImage} alt={product.title} fetchpriority="high" />
        </div>
      )}

      {product.bodyHtml && (
        <section class="product-copy-section" aria-labelledby="about-heading">
          <div class="public-section-heading public-section-heading-accent">
            <h2 id="about-heading">About</h2>
          </div>
          <div class="product-body markdown-body" set:html={product.bodyHtml}></div>
        </section>
      )}

      {remainingGallery.length > 0 && (
        <section class="product-gallery-section" aria-labelledby="gallery-heading">
          <div class="public-section-heading public-section-heading-accent">
            <h2 id="gallery-heading">Gallery</h2>
            <span class="public-count">{remainingGallery.length} photos</span>
          </div>
          <div class="product-gallery">
            {remainingGallery.map((image) => (
              <a href={image.imageUrl} target="_blank" rel="noopener noreferrer" aria-label={`Open ${image.originalName}`}>
                <img
                  src={image.imageUrl}
                  alt={image.originalName}
                  width={image.width}
                  height={image.height}
                  loading="lazy"
                />
              </a>
            ))}
          </div>
        </section>
      )}

      {product.hasConversion && (
        <div class="product-cta-bar" data-contact-box>
          <div class="contact-reveal" data-contact-value hidden></div>
          <a
            class="public-button product-cta-button"
            href={contactResolveUrl}
            rel="nofollow sponsored"
            data-contact-cta
            data-resolve-url={contactResolveUrl}
          >
            <span data-contact-label>{product.ctaLabel}</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14 5h5v5M19 5l-8 8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
              <path d="M18 13v5a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
            </svg>
          </a>
        </div>
      )}
    </article>
  ) : (
    <section class="public-section">
      <div class="public-empty public-error-card">
        <div>
          <div class="empty-icon" aria-hidden="true">404</div>
          <h1>Product not found</h1>
          <p>This product is unavailable or has not been published.</p>
          <a class="public-button secondary" href={`/${encodeURIComponent(channelSlug)}`}>Return to channel</a>
        </div>
      </div>
    </section>
  )}
</PublicLayout>

<script is:inline>
  (() => {
    document.querySelectorAll('[data-contact-cta]').forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) return;
      const resolveUrl = link.dataset.resolveUrl || link.href;
      const box = link.closest('[data-contact-box]');
      const value = box?.querySelector('[data-contact-value]');
      const label = link.querySelector('[data-contact-label]');
      let resolved = false;

      link.addEventListener('click', async (event) => {
        if (resolved) return;
        event.preventDefault();
        if (link.dataset.loading === '1') return;

        link.dataset.loading = '1';
        link.setAttribute('aria-busy', 'true');
        if (label) label.textContent = 'Loading…';

        try {
          const response = await fetch(resolveUrl, {
            headers: { Accept: 'application/json' },
            credentials: 'same-origin',
          });
          const result = await response.json();
          if (!response.ok || !result?.ok || !result.contact?.target) throw new Error('unavailable');

          resolved = true;
          link.href = result.contact.target;
          box?.setAttribute('data-contact-type', result.contact.type || 'link');
          if (value) {
            value.textContent = result.contact.display || result.contact.target;
            value.hidden = false;
          }
          if (label) label.textContent = result.contact.type === 'sms' ? 'Send Message' : 'Open Link';
        } catch (error) {
          console.error(error);
          if (value) {
            value.textContent = 'Contact is temporarily unavailable.';
            value.hidden = false;
          }
          if (label) label.textContent = 'Try Again';
        } finally {
          delete link.dataset.loading;
          link.removeAttribute('aria-busy');
        }
      });
    });
  })();
</script>
