---
import PublicLayout from "@/layouts/PublicLayout.astro";
import AffiliateAds from "@/components/public/AffiliateAds.astro";
import CategoryCard from "@/components/public/CategoryCard.astro";
import DesktopCatalogRow from "@/components/public/DesktopCatalogRow.astro";
import DesktopCatalogSidebar from "@/components/public/DesktopCatalogSidebar.astro";
import ProductDirectory from "@/components/public/ProductDirectory.astro";
import {
  findPublicChannel,
  loadPublicCategories,
  loadPublicCategoryFilters,
  loadPublicProducts,
  loadPublicSiteShell,
  type PublicCategoryFilter,
} from "@/lib/db/public";
import {
  loadPublicDesktopFilterMap,
  loadPublicProductPreview,
} from "@/lib/db/public-desktop";
import { buildEffectiveCategoryGroups } from "@/lib/public/category-navigation";
import { readPublicPage } from "@/lib/public/pagination";

export const prerender = false;

const channelSlug = Astro.params.channel ?? "";
const pageInput = readPublicPage(Astro.url.searchParams.get("page"));
const requestedCategorySlug = (Astro.url.searchParams.get("category") ?? "").trim().slice(0, 96);
const site = await loadPublicSiteShell();
const channel = findPublicChannel(site, channelSlug);
const canLoadPage = Boolean(channel && pageInput.valid);

const [filters, loadedCategories, filtersByChannel] = canLoadPage && channel
  ? await Promise.all([
      loadPublicCategoryFilters(channel.id),
      loadPublicCategories(channel.id),
      loadPublicDesktopFilterMap(site.channels.map((item) => item.id)),
    ])
  : [[], [], {}];
const categories = loadedCategories;
const categoryGroups = buildEffectiveCategoryGroups(filters, categories);
const activeFilters = categoryGroups.map(({ filter }) => filter);
const hasCategoryNavigation = categoryGroups.length > 0;
const categoryFilterColumns = Math.min(Math.max(activeFilters.length, 1), 4);
const categoryFilterStyle = `--category-filter-columns: ${categoryFilterColumns}`;
const selectedCategory = !hasCategoryNavigation && requestedCategorySlug
  ? categories.find((category) => category.slug === requestedCategorySlug) ?? null
  : null;
const categorySelectionValid = hasCategoryNavigation || !requestedCategorySlug || Boolean(selectedCategory);
const ungroupedCategories = categories.filter((category) => category.filterIds.length === 0);
const productPage = canLoadPage && channel && !hasCategoryNavigation && categorySelectionValid
  ? await loadPublicProducts({
      channelId: channel.id,
      baseUrl: site.r2PublicBaseUrl,
      page: pageInput.page,
      categoryId: selectedCategory?.id ?? null,
    })
  : { products: [], page: pageInput.page, hasMore: false };

const desktopGroupInputs = hasCategoryNavigation && pageInput.page === 1
  ? [
      ...categoryGroups,
      ...(ungroupedCategories.length > 0
        ? [{
            filter: {
              id: "desktop-ungrouped",
              name: "Categories",
              slug: "categories",
            } satisfies PublicCategoryFilter,
            categories: ungroupedCategories,
          }]
        : []),
    ]
  : [];
const desktopGroups = channel
  ? await Promise.all(desktopGroupInputs.map(async ({ filter, categories: groupedCategories }) => ({
      filter,
      categories: groupedCategories,
      products: await loadPublicProductPreview({
        channelId: channel.id,
        categoryIds: groupedCategories.map((category) => category.id),
        baseUrl: site.r2PublicBaseUrl,
        limit: 8,
      }),
    })))
  : [];

const pageOutOfRange = canLoadPage && (
  hasCategoryNavigation
    ? pageInput.page > 1
    : pageInput.page > 1 && productPage.products.length === 0
);
const pageAvailable = canLoadPage && categorySelectionValid && !pageOutOfRange;

if (!pageAvailable) Astro.response.status = 404;

const canonical = pageAvailable && channel
  ? (() => {
      const value = new URL(`/${encodeURIComponent(channel.slug)}`, Astro.url.origin);
      if (selectedCategory) value.searchParams.set("category", selectedCategory.slug);
      if (pageInput.page > 1) value.searchParams.set("page", String(pageInput.page));
      return value.href;
    })()
  : null;
const directoryTitle = selectedCategory?.name ?? channel?.name;
const pageTitle = directoryTitle
  ? pageInput.page > 1 ? `${directoryTitle} — Page ${pageInput.page}` : directoryTitle
  : "Page not found";
const adSurface = hasCategoryNavigation
  ? "channel"
  : pageInput.page === 1 && !selectedCategory
    ? "channel-catalog"
    : "catalog";
---

<PublicLayout
  site={site}
  title={pageTitle}
  description={pageAvailable && channel ? site.siteDescription || `${channel.name} recommendations and listings.` : "The requested channel page could not be found."}
  canonical={canonical}
  robots={pageAvailable ? undefined : "noindex,follow"}
  activeChannel={pageAvailable ? channel?.slug ?? null : null}
>
  {pageAvailable && channel ? (
    <>
      <AffiliateAds channelSlug={channel.slug} surface={adSurface} />

      {pageInput.page === 1 && !hasCategoryNavigation && categories.length > 0 && (
        <section class="public-section channel-category-section">
          <nav class="filter-strip channel-category-filters" aria-label="Product categories">
            {categories.map((category) => {
              const active = selectedCategory?.id === category.id;
              const channelHref = `/${encodeURIComponent(channel.slug)}`;
              return (
                <a
                  class="filter-button"
                  href={active ? channelHref : `${channelHref}?category=${encodeURIComponent(category.slug)}`}
                  aria-current={active ? "page" : undefined}
                >
                  {category.name}
                </a>
              );
            })}
          </nav>
        </section>
      )}

      {pageInput.page === 1 && hasCategoryNavigation && (
        <section class="public-section category-section channel-category-navigation" data-category-section>
          <div class="category-mobile-directory" data-category-mobile>
            {activeFilters.length > 0 && (
              <nav
                class="category-filter-bar"
                aria-label="Category filters"
                style={categoryFilterStyle}
              >
                {activeFilters.map((filter) => (
                  <button
                    class="category-filter-button"
                    type="button"
                    data-category-filter={filter.id}
                    aria-pressed="false"
                  >
                    <span>{filter.name}</span>
                  </button>
                ))}
              </nav>
            )}

            <div class="category-grid" data-category-grid>
              {categories.map((category) => <CategoryCard category={category} channelSlug={channel.slug} />)}
            </div>
            <div class="public-empty" data-category-empty hidden>No matching categories.</div>
          </div>

          <div class="category-grouped-directory" aria-label="Categories by filter">
            {activeFilters.length > 0 && (
              <nav
                class="category-filter-bar category-filter-bar-desktop"
                aria-label="Category filters"
                style={categoryFilterStyle}
              >
                {activeFilters.map((filter) => (
                  <button
                    class="category-filter-button"
                    type="button"
                    data-category-group-filter={filter.id}
                    aria-pressed="false"
                  >
                    <span>{filter.name}</span>
                  </button>
                ))}
              </nav>
            )}

            <div class="category-group-list">
              {categoryGroups.map(({ filter, categories: groupedCategories }) => (
                <section class="category-group-row" data-category-group-row={filter.id} aria-labelledby={`category-group-${filter.id}`}>
                  <h2 class="category-group-heading" id={`category-group-${filter.id}`}>{filter.name}</h2>
                  <div class="category-group-items">
                    {groupedCategories.map((category) => (
                      <CategoryCard category={category} channelSlug={channel.slug} />
                    ))}
                  </div>
                </section>
              ))}

              {ungroupedCategories.length > 0 && (
                <section class="category-group-row" data-category-group-row="" aria-labelledby="category-group-other">
                  <h2 class="category-group-heading" id="category-group-other">Categories</h2>
                  <div class="category-group-items">
                    {ungroupedCategories.map((category) => (
                      <CategoryCard category={category} channelSlug={channel.slug} />
                    ))}
                  </div>
                </section>
              )}
            </div>
          </div>
        </section>
      )}

      {hasCategoryNavigation && pageInput.page === 1 && (
        <section
          class="desktop-density-workspace desktop-channel-catalog"
          aria-label={`${channel.name} catalog`}
          data-desktop-density-workspace
        >
          <DesktopCatalogSidebar
            site={site}
            channel={channel}
            filtersByChannel={filtersByChannel}
          />
          <div class="desktop-density-content">
            {desktopGroups.map(({ filter, categories: groupedCategories, products }, index) => (
              <DesktopCatalogRow
                filter={filter}
                categories={groupedCategories}
                products={products}
                channelSlug={channel.slug}
                priorityCount={index === 0 ? 4 : 0}
              />
            ))}
          </div>
        </section>
      )}

      {!hasCategoryNavigation && (
        <section class="public-section channel-products-section">
          <ProductDirectory
            channelSlug={channel.slug}
            categorySlug={selectedCategory?.slug ?? null}
            preserveCategoryQuery={Boolean(selectedCategory)}
            page={productPage}
            priorityCount={2}
            emptyMessage={selectedCategory
              ? `No published products are available in ${selectedCategory.name}.`
              : "No published products are available in this channel."}
          />
        </section>
      )}
    </>
  ) : (
    <section class="public-section">
      <div class="public-empty public-error-card">
        <div>
          <div class="empty-icon" aria-hidden="true">404</div>
          <h1>Page not found</h1>
          <a class="public-button secondary" href={channel ? `/${encodeURIComponent(channel.slug)}` : "/"}>Return</a>
        </div>
      </div>
    </section>
  )}
</PublicLayout>

<script>import "@/scripts/public-category-filters";</script>
<script>import "@/scripts/public-desktop-workspace";</script>
