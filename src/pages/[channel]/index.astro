---
import PublicLayout from "@/layouts/PublicLayout.astro";
import HeroCarousel from "@/components/public/HeroCarousel.astro";
import CategoryCard from "@/components/public/CategoryCard.astro";
import ProductDirectory from "@/components/public/ProductDirectory.astro";
import PublicSearchForm from "@/components/public/PublicSearchForm.astro";
import {
  findPublicChannel,
  loadPublicCategories,
  loadPublicCategoryFilters,
  loadPublicHeroAdvertisements,
  loadPublicProducts,
  loadPublicSiteShell,
} from "@/lib/db/public";
import { publicPageCanonical, readPublicPage } from "@/lib/public/pagination";

export const prerender = false;

const channelSlug = Astro.params.channel ?? "";
const pageInput = readPublicPage(Astro.url.searchParams.get("page"));
const site = await loadPublicSiteShell();
const channel = findPublicChannel(site, channelSlug);
const canLoadPage = Boolean(channel && pageInput.valid);

const [hero, filters, loadedCategories] = canLoadPage && channel
  ? await Promise.all([
      pageInput.page === 1 ? loadPublicHeroAdvertisements(channel.id, site.r2PublicBaseUrl) : Promise.resolve([]),
      pageInput.page === 1 ? loadPublicCategoryFilters(channel.id) : Promise.resolve([]),
      loadPublicCategories(channel.id),
    ])
  : [[], [], []];
const categories = loadedCategories;
const hasCategoryNavigation = categories.length > 0 || filters.length > 0;
const categoryGroups = filters.map((filter) => ({
  filter,
  categories: categories.filter((category) => category.filterIds.includes(filter.id)),
}));
const ungroupedCategories = categories.filter((category) => category.filterIds.length === 0);
const productPage = canLoadPage && channel && !hasCategoryNavigation
  ? await loadPublicProducts({
      channelId: channel.id,
      baseUrl: site.r2PublicBaseUrl,
      page: pageInput.page,
    })
  : { products: [], page: pageInput.page, hasMore: false };
const pageOutOfRange = canLoadPage && pageInput.page > 1 && productPage.products.length === 0;
const pageAvailable = canLoadPage && !pageOutOfRange;

if (!pageAvailable) Astro.response.status = 404;

const canonical = pageAvailable && channel
  ? publicPageCanonical(
      new URL(`/${encodeURIComponent(channel.slug)}`, Astro.url.origin),
      pageInput.page,
    )
  : null;
const pageTitle = channel
  ? pageInput.page > 1 ? `${channel.name} — Page ${pageInput.page}` : channel.name
  : "Page not found";
---

<PublicLayout
  site={site}
  title={pageTitle}
  description={pageAvailable && channel ? site.siteDescription || `${channel.name} recommendations and listings.` : "The requested channel page could not be found."}
  canonical={canonical}
  robots={pageAvailable ? undefined : "noindex,follow"}
  activeChannel={pageAvailable ? channel?.slug ?? null : null}
>
  {pageAvailable && channel ? (
    <>
      {pageInput.page === 1 && <HeroCarousel advertisements={hero} />}

      {pageInput.page === 1 && (
        <section class="public-section channel-search-section">
          <PublicSearchForm
            action={`/${encodeURIComponent(channel.slug)}/search`}
            ariaLabel={`Search ${channel.name}`}
          />
        </section>
      )}

      {pageInput.page === 1 && hasCategoryNavigation && (
        <section class="public-section category-section" data-category-section>
          <div class="category-mobile-directory" data-category-mobile>
            {filters.length > 0 && (
              <div class="filter-strip" aria-label="Category filters">
                {filters.map((filter) => (
                  <button class="filter-button" type="button" data-category-filter={filter.id} aria-pressed="false">
                    {filter.name}
                  </button>
                ))}
              </div>
            )}

            <div class="category-grid" data-category-grid>
              {categories.map((category) => <CategoryCard category={category} channelSlug={channel.slug} />)}
            </div>
            <div class="public-empty" data-category-empty hidden>No matching categories.</div>
          </div>

          <div class="category-grouped-directory" aria-label="Categories by filter">
            {categoryGroups.map(({ filter, categories: groupedCategories }) => (
              <section class="category-group-row" data-category-group-row={filter.id} aria-labelledby={`category-group-${filter.id}`}>
                <button
                  class="filter-button category-group-label category-group-filter"
                  id={`category-group-${filter.id}`}
                  type="button"
                  data-category-group-filter={filter.id}
                  aria-pressed="false"
                >
                  {filter.name}
                </button>
                <div class="category-group-items">
                  {groupedCategories.map((category) => (
                    <CategoryCard category={category} channelSlug={channel.slug} />
                  ))}
                </div>
              </section>
            ))}

            {ungroupedCategories.length > 0 && (
              <section class="category-group-row" data-category-group-row="" aria-labelledby="category-group-other">
                <h2 class="category-group-label category-group-label-static" id="category-group-other">Categories</h2>
                <div class="category-group-items">
                  {ungroupedCategories.map((category) => (
                    <CategoryCard category={category} channelSlug={channel.slug} />
                  ))}
                </div>
              </section>
            )}
          </div>
        </section>
      )}

      {!hasCategoryNavigation && (
        <section class="public-section channel-products-section">
          <ProductDirectory channelSlug={channel.slug} page={productPage} />
        </section>
      )}
    </>
  ) : (
    <section class="public-section">
      <div class="public-empty public-error-card">
        <div>
          <div class="empty-icon" aria-hidden="true">404</div>
          <h1>Page not found</h1>
          <a class="public-button secondary" href={channel ? `/${encodeURIComponent(channel.slug)}` : "/"}>Return</a>
        </div>
      </div>
    </section>
  )}
</PublicLayout>

<script>import "@/scripts/public-category-filters";</script>
