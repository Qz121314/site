---
import PublicLayout from "@/layouts/PublicLayout.astro";
import HeroCarousel from "@/components/public/HeroCarousel.astro";
import CategoryCard from "@/components/public/CategoryCard.astro";
import ProductDirectory from "@/components/public/ProductDirectory.astro";
import PublicSearchForm from "@/components/public/PublicSearchForm.astro";
import {
  findPublicChannel,
  loadPublicCategories,
  loadPublicCategoryFilters,
  loadPublicHeroAdvertisements,
  loadPublicProducts,
  loadPublicSiteShell,
} from "@/lib/db/public";
import { loadPublicUncategorizedProducts } from "@/lib/db/public-availability";

export const prerender = false;

const channelSlug = Astro.params.channel ?? "";
const site = await loadPublicSiteShell();
const channel = findPublicChannel(site, channelSlug);

if (!channel) Astro.response.status = 404;

const [hero, filters, loadedCategories] = channel
  ? await Promise.all([
      loadPublicHeroAdvertisements(channel.id, site.r2PublicBaseUrl),
      loadPublicCategoryFilters(channel.id),
      loadPublicCategories(channel.id, site.r2PublicBaseUrl),
    ])
  : [[], [], []];
const categories = loadedCategories.filter((category) => category.productCount > 0);
const productPage = channel
  ? categories.length > 0
    ? await loadPublicUncategorizedProducts({ channelId: channel.id, baseUrl: site.r2PublicBaseUrl })
    : await loadPublicProducts({ channelId: channel.id, baseUrl: site.r2PublicBaseUrl })
  : { products: [], page: 1, hasMore: false };

const canonical = channel
  ? new URL(`/${encodeURIComponent(channel.slug)}`, Astro.url.origin).href
  : null;
---

<PublicLayout
  site={site}
  title={channel?.name ?? "Page not found"}
  description={channel ? `${channel.name} recommendations and listings.` : "The requested channel could not be found."}
  canonical={canonical}
  robots={channel ? undefined : "noindex,follow"}
  activeChannel={channel?.slug ?? null}
>
  {channel ? (
    <>
      <HeroCarousel advertisements={hero} />

      <section class="public-section channel-search-section">
        <PublicSearchForm
          action={`/${encodeURIComponent(channel.slug)}/search`}
          ariaLabel={`Search ${channel.name}`}
        />
      </section>

      {categories.length > 0 ? (
        <>
          <section class="public-section category-section" data-category-section>
            {filters.length > 0 && (
              <div class="filter-strip" aria-label="Category filters">
                {filters.map((filter) => (
                  <button class="filter-button" type="button" data-category-filter={filter.id} aria-pressed="false">
                    {filter.name}
                  </button>
                ))}
              </div>
            )}

            <div class="category-grid" data-category-grid>
              {categories.map((category) => <CategoryCard category={category} channelSlug={channel.slug} />)}
            </div>
            <div class="public-empty" data-category-empty hidden>No matching categories.</div>
          </section>

          {productPage.products.length > 0 && (
            <section class="public-section">
              <div class="public-section-heading"><h2>More products</h2></div>
              <ProductDirectory channelSlug={channel.slug} page={productPage} uncategorizedOnly />
            </section>
          )}
        </>
      ) : (
        <section class="public-section">
          <ProductDirectory channelSlug={channel.slug} page={productPage} />
        </section>
      )}
    </>
  ) : (
    <section class="public-section">
      <div class="public-empty public-error-card">
        <div>
          <div class="empty-icon" aria-hidden="true">404</div>
          <h1>Page not found</h1>
          <a class="public-button secondary" href="/">Return home</a>
        </div>
      </div>
    </section>
  )}
</PublicLayout>

<script is:inline>
  (() => {
    const section = document.querySelector('[data-category-section]');
    if (!section) return;

    const buttons = Array.from(section.querySelectorAll('[data-category-filter]'));
    const cards = Array.from(section.querySelectorAll('[data-category-card]'));
    const empty = section.querySelector('[data-category-empty]');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filterId = button.dataset.categoryFilter || '';
        const shouldClear = button.getAttribute('aria-pressed') === 'true';
        let visible = 0;

        buttons.forEach((item) => item.setAttribute('aria-pressed', 'false'));
        if (!shouldClear) button.setAttribute('aria-pressed', 'true');

        cards.forEach((card) => {
          const filterIds = (card.dataset.filterIds || '').split(',').filter(Boolean);
          const show = shouldClear || filterIds.includes(filterId);
          card.hidden = !show;
          if (show) visible += 1;
        });

        if (empty) empty.hidden = visible > 0;
      });
    });
  })();
</script>
