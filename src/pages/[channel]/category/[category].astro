---
import PublicLayout from "@/layouts/PublicLayout.astro";
import ProductDirectory from "@/components/public/ProductDirectory.astro";
import {
  findPublicChannel,
  loadPublicCategory,
  loadPublicProducts,
  loadPublicSiteShell,
} from "@/lib/db/public";

export const prerender = false;

const channelSlug = Astro.params.channel ?? "";
const categorySlug = Astro.params.category ?? "";
const site = await loadPublicSiteShell();
const channel = findPublicChannel(site, channelSlug);
const category = channel
  ? await loadPublicCategory(channel.id, categorySlug, site.r2PublicBaseUrl)
  : null;

if (!channel || !category) Astro.response.status = 404;

const productPage = channel && category
  ? await loadPublicProducts({
      channelId: channel.id,
      categoryId: category.id,
      baseUrl: site.r2PublicBaseUrl,
    })
  : { products: [], page: 1, hasMore: false };

const canonical = new URL(
  `/${encodeURIComponent(channelSlug)}/category/${encodeURIComponent(categorySlug)}`,
  Astro.url.origin,
).href;
---

<PublicLayout
  site={site}
  title={category?.name ?? "Page not found"}
  description={category ? `Browse ${category.name} in ${channel?.name ?? site.siteName}.` : "The requested category could not be found."}
  canonical={canonical}
  ogImage={category?.imageUrl ?? site.logoUrl}
  activeChannel={channel?.slug ?? null}
>
  {channel && category ? (
    <>
      <header class="directory-page-header">
        <a class="public-back-link" href={`/${encodeURIComponent(channel.slug)}`}>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m15 18-6-6 6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
          </svg>
          <span>Back to {channel.name}</span>
        </a>
        <div class="directory-title-row">
          <div>
            <div class="eyebrow">{channel.name}</div>
            <h1>{category.name}</h1>
            <p>{category.productCount} {category.productCount === 1 ? "listing" : "listings"}</p>
          </div>
        </div>
      </header>

      <section class="public-section">
        <form class="public-search-form" action={`/${encodeURIComponent(channel.slug)}/search`} method="get" role="search">
          <span class="public-search-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="1.7" />
              <path d="m16 16 4 4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.7" />
            </svg>
          </span>
          <input name="q" type="search" maxlength="100" placeholder={`Search in ${category.name}`} aria-label={`Search ${channel.name}`} />
          <button class="public-search-submit" type="submit" aria-label="Search">
            <span>Search</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m9 18 6-6-6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
            </svg>
          </button>
        </form>
      </section>

      <section class="public-section directory-list-section">
        <ProductDirectory
          channelSlug={channel.slug}
          categorySlug={category.slug}
          page={productPage}
          emptyMessage="No published products are available in this category."
        />
      </section>
    </>
  ) : (
    <section class="public-section">
      <div class="public-empty public-error-card">
        <div>
          <div class="empty-icon" aria-hidden="true">404</div>
          <h1>Category not found</h1>
          <p>This category is unavailable or has not been published.</p>
          <a class="public-button secondary" href={channel ? `/${encodeURIComponent(channel.slug)}` : "/"}>Return</a>
        </div>
      </div>
    </section>
  )}
</PublicLayout>
