---
import PublicLayout from "@/layouts/PublicLayout.astro";
import ProductDirectory from "@/components/public/ProductDirectory.astro";
import PublicBackLink from "@/components/public/PublicBackLink.astro";
import PublicSearchForm from "@/components/public/PublicSearchForm.astro";
import {
  findPublicChannel,
  loadPublicCategory,
  loadPublicProducts,
  loadPublicSiteShell,
} from "@/lib/db/public";

export const prerender = false;

const channelSlug = Astro.params.channel ?? "";
const categorySlug = Astro.params.category ?? "";
const site = await loadPublicSiteShell();
const channel = findPublicChannel(site, channelSlug);
const category = channel
  ? await loadPublicCategory(channel.id, categorySlug, site.r2PublicBaseUrl)
  : null;

if (!channel || !category) Astro.response.status = 404;

const productPage = channel && category
  ? await loadPublicProducts({
      channelId: channel.id,
      categoryId: category.id,
      baseUrl: site.r2PublicBaseUrl,
    })
  : { products: [], page: 1, hasMore: false };

const canonical = new URL(
  `/${encodeURIComponent(channelSlug)}/category/${encodeURIComponent(categorySlug)}`,
  Astro.url.origin,
).href;
---

<PublicLayout
  site={site}
  title={category?.name ?? "Page not found"}
  description={category ? `Browse ${category.name} in ${channel?.name ?? site.siteName}.` : "The requested category could not be found."}
  canonical={canonical}
  ogImage={category?.imageUrl ?? site.logoUrl}
  activeChannel={channel?.slug ?? null}
>
  {channel && category ? (
    <>
      <header class="directory-page-header">
        <PublicBackLink href={`/${encodeURIComponent(channel.slug)}`} />
        <div class="directory-heading">
          <h1>{category.name}</h1>
          <span class="directory-count">
            {category.productCount} {category.productCount === 1 ? "listing" : "listings"}
          </span>
        </div>
      </header>

      <section class="public-section">
        <PublicSearchForm
          action={`/${encodeURIComponent(channel.slug)}/search`}
          ariaLabel={`Search ${category.name}`}
          placeholder={`Search ${category.name}`}
        />
      </section>

      <section class="public-section directory-list-section">
        <ProductDirectory
          channelSlug={channel.slug}
          categorySlug={category.slug}
          page={productPage}
          emptyMessage="No published products are available in this category."
        />
      </section>
    </>
  ) : (
    <section class="public-section">
      <div class="public-empty public-error-card">
        <div>
          <div class="empty-icon" aria-hidden="true">404</div>
          <h1>Category not found</h1>
          <a class="public-button secondary" href={channel ? `/${encodeURIComponent(channel.slug)}` : "/"}>Return</a>
        </div>
      </div>
    </section>
  )}
</PublicLayout>
