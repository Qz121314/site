---
import PublicLayout from "@/layouts/PublicLayout.astro";
import AffiliateAds from "@/components/public/AffiliateAds.astro";
import CategoryCard from "@/components/public/CategoryCard.astro";
import DesktopCatalogSidebar from "@/components/public/DesktopCatalogSidebar.astro";
import ProductDirectory from "@/components/public/ProductDirectory.astro";
import {
  findPublicChannel,
  loadPublicCategories,
  loadPublicCategoryFilters,
  loadPublicProducts,
  loadPublicSiteShell,
  PUBLIC_PRODUCT_PAGE_SIZE,
} from "@/lib/db/public";
import { loadPublicDesktopFilterMap } from "@/lib/db/public-desktop";
import { buildEffectiveCategoryGroups } from "@/lib/public/category-navigation";
import { publicPageCanonical, readPublicPage } from "@/lib/public/pagination";

export const prerender = false;

const channelSlug = Astro.params.channel ?? "";
const categorySlug = Astro.params.category ?? "";
const pageInput = readPublicPage(Astro.url.searchParams.get("page"));
const site = await loadPublicSiteShell();
const channel = findPublicChannel(site, channelSlug);
const [filters, categories, filtersByChannel] = channel && pageInput.valid
  ? await Promise.all([
      loadPublicCategoryFilters(channel.id),
      loadPublicCategories(channel.id),
      loadPublicDesktopFilterMap(site.channels.map((item) => item.id)),
    ])
  : [[], [], {}];
const category = categories.find((item) => item.slug === categorySlug) ?? null;
const categoryGroups = buildEffectiveCategoryGroups(filters, categories);
const hasCategoryNavigation = categoryGroups.length > 0;
const activeGroup = category
  ? categoryGroups.find(({ categories: groupedCategories }) => groupedCategories.some((item) => item.id === category.id)) ?? null
  : null;
const focusCategories = activeGroup?.categories ?? categories;
const focusFilterName = activeGroup?.filter.name ?? "Categories";
const focusFilterSlug = activeGroup?.filter.slug ?? "categories";

if (channel && category && !hasCategoryNavigation) {
  const target = new URL(`/${encodeURIComponent(channel.slug)}`, Astro.url.origin);
  target.searchParams.set("category", category.slug);
  if (pageInput.page > 1) target.searchParams.set("page", String(pageInput.page));
  return Astro.redirect(`${target.pathname}${target.search}`, 301);
}

const productPage = channel && category
  ? await loadPublicProducts({
      channelId: channel.id,
      categoryId: category.id,
      baseUrl: site.r2PublicBaseUrl,
      page: pageInput.page,
    })
  : { products: [], page: pageInput.page, hasMore: false };
const pageOutOfRange = Boolean(channel && category && pageInput.page > 1 && productPage.products.length === 0);
const pageAvailable = Boolean(channel && category && pageInput.valid && !pageOutOfRange);

if (!pageAvailable) Astro.response.status = 404;

const canonical = pageAvailable && channel && category
  ? publicPageCanonical(
      new URL(
        `/${encodeURIComponent(channel.slug)}/category/${encodeURIComponent(category.slug)}`,
        Astro.url.origin,
      ),
      pageInput.page,
    )
  : null;
const pageTitle = category
  ? pageInput.page > 1 ? `${category.name} — Page ${pageInput.page}` : category.name
  : "Page not found";
const description = pageAvailable && category
  ? `Browse ${category.name} in ${channel?.name ?? site.siteName}${pageInput.page > 1 ? ` — page ${pageInput.page}` : ""}.`
  : "The requested category page could not be found.";
const channelUrl = pageAvailable && channel
  ? new URL(`/${encodeURIComponent(channel.slug)}`, Astro.url.origin).href
  : null;
const structuredData = pageAvailable && channel && category && canonical && channelUrl
  ? {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ItemList",
          name: pageTitle,
          url: canonical,
          numberOfItems: productPage.products.length,
          itemListOrder: "https://schema.org/ItemListOrderAscending",
          itemListElement: productPage.products.map((product, index) => ({
            "@type": "ListItem",
            position: (pageInput.page - 1) * PUBLIC_PRODUCT_PAGE_SIZE + index + 1,
            name: product.title,
            url: new URL(
              `/${encodeURIComponent(channel.slug)}/product/${encodeURIComponent(product.slug)}`,
              Astro.url.origin,
            ).href,
            ...(product.coverUrl ? { image: product.coverUrl } : {}),
          })),
        },
        {
          "@type": "BreadcrumbList",
          itemListElement: [
            {
              "@type": "ListItem",
              position: 1,
              name: channel.name,
              item: channelUrl,
            },
            {
              "@type": "ListItem",
              position: 2,
              name: category.name,
              item: canonical,
            },
          ],
        },
      ],
    }
  : null;
const returnUrl = pageAvailable && channel ? `/${encodeURIComponent(channel.slug)}` : null;
---

<PublicLayout
  site={site}
  title={pageTitle}
  description={description}
  canonical={canonical}
  robots={pageAvailable ? undefined : "noindex,follow"}
  ogImage={site.logoUrl}
  activeChannel={pageAvailable ? channel?.slug ?? null : null}
  backHref={returnUrl}
  structuredData={structuredData}
>
  {pageAvailable && channel && category ? (
    <>
      <AffiliateAds channelSlug={channel.slug} surface="catalog" />

      <div
        class="directory-page-layout catalog-workspace category-catalog-workspace desktop-density-workspace"
        data-desktop-density-workspace
      >
        <DesktopCatalogSidebar
          site={site}
          channel={channel}
          filtersByChannel={filtersByChannel}
        />

        <div class="desktop-density-content">
          <section
            class="desktop-density-row desktop-density-row-focus"
            id={`filter-${focusFilterSlug}`}
            data-desktop-filter-row={focusFilterSlug}
            aria-labelledby={`desktop-focus-filter-${category.id}`}
          >
            <div class="desktop-density-category-panel">
              <h2 id={`desktop-focus-filter-${category.id}`}>{focusFilterName}</h2>
              <div class="desktop-density-category-grid">
                {focusCategories.map((item) => (
                  <CategoryCard
                    category={item}
                    channelSlug={channel.slug}
                    active={item.id === category.id}
                  />
                ))}
              </div>
            </div>

            <div class="desktop-density-product-panel">
              <header class="directory-page-title desktop-directory-title">
                <h1>{category.name}</h1>
                {pageInput.page > 1 && <span class="directory-page-count">Page {pageInput.page}</span>}
              </header>

              <section class="public-section directory-list-section" aria-label={category.name}>
                <ProductDirectory
                  channelSlug={channel.slug}
                  categorySlug={category.slug}
                  page={productPage}
                  priorityCount={4}
                  emptyMessage="No published products are available in this category."
                />
              </section>
            </div>
          </section>
        </div>
      </div>
    </>
  ) : (
    <section class="public-section">
      <div class="public-empty public-error-card">
        <div>
          <div class="empty-icon" aria-hidden="true">404</div>
          <h1>Category page not found</h1>
          <a class="public-button secondary" href={channel ? `/${encodeURIComponent(channel.slug)}` : "/"}>Return</a>
        </div>
      </div>
    </section>
  )}
</PublicLayout>

<script>import "@/scripts/public-desktop-workspace";</script>

<style>
  .directory-page-layout,
  .desktop-density-content {
    display: grid;
    min-width: 0;
    gap: .9rem;
  }
</style>
