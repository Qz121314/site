---
import PublicLayout from "@/layouts/PublicLayout.astro";
import CategoryCard from "@/components/public/CategoryCard.astro";
import ProductCard from "@/components/public/ProductCard.astro";
import PublicPageHeader from "@/components/public/PublicPageHeader.astro";
import PublicSearchForm from "@/components/public/PublicSearchForm.astro";
import {
  findPublicChannel,
  loadPublicSiteShell,
  searchPublicCatalog,
} from "@/lib/db/public";
import { normalizePublicSearchQuery } from "@/lib/search/query";
import { rankSearchResults } from "@/lib/search/ranking";

export const prerender = false;

const channelSlug = Astro.params.channel ?? "";
const query = normalizePublicSearchQuery(Astro.url.searchParams.get("q") ?? "");
const site = await loadPublicSiteShell();
const channel = findPublicChannel(site, channelSlug);

if (!channel) Astro.response.status = 404;
const rawResults = channel && query
  ? await searchPublicCatalog(channel.id, query, site.r2PublicBaseUrl)
  : { categories: [], products: [] };
const results = {
  categories: rankSearchResults(rawResults.categories, query, (category) => [category.name]),
  products: rankSearchResults(rawResults.products, query, (product) => [product.title, ...product.tags]),
};
const categories = results.categories;
---

<PublicLayout
  site={site}
  title={query ? `Search: ${query}` : "Search"}
  description={channel ? `Search categories, products, and tags in ${channel.name}.` : "Search the public catalog."}
  canonical={null}
  robots="noindex,follow"
  activeChannel={channel?.slug ?? null}
>
  {channel ? (
    <>
      <PublicPageHeader
        href={`/${encodeURIComponent(channel.slug)}`}
        title={query || "Search"}
        className="search-page-header"
      />

      <section class="public-section">
        <PublicSearchForm
          action={`/${encodeURIComponent(channel.slug)}/search`}
          ariaLabel={`Search ${channel.name}`}
          value={query}
          required
          autofocus={!query}
        />
      </section>

      {!query ? (
        <div class="public-empty">
          <div>
            <div class="empty-icon" aria-hidden="true">⌕</div>
            <h2>Search</h2>
          </div>
        </div>
      ) : categories.length === 0 && results.products.length === 0 ? (
        <div class="public-empty">
          <div>
            <div class="empty-icon" aria-hidden="true">0</div>
            <h2>No results</h2>
          </div>
        </div>
      ) : (
        <>
          {categories.length > 0 && (
            <section class="public-section search-results-section">
              <div class="public-section-heading">
                <h2>Categories</h2>
                <span class="public-count">{categories.length}</span>
              </div>
              <div class="category-grid">
                {categories.map((category) => <CategoryCard category={category} channelSlug={channel.slug} />)}
              </div>
            </section>
          )}

          {results.products.length > 0 && (
            <section class="public-section search-results-section">
              <div class="public-section-heading">
                <h2>Products</h2>
                <span class="public-count">{results.products.length}</span>
              </div>
              <div class="product-grid">
                {results.products.map((product, index) => (
                  <ProductCard product={product} channelSlug={channel.slug} priority={index < 2} />
                ))}
              </div>
            </section>
          )}
        </>
      )}
    </>
  ) : (
    <div class="public-empty public-error-card">
      <div>
        <div class="empty-icon" aria-hidden="true">404</div>
        <h1>Channel unavailable</h1>
      </div>
    </div>
  )}
</PublicLayout>
