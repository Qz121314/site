---
import PublicLayout from "@/layouts/PublicLayout.astro";
import { loadPublicSiteShell } from "@/lib/db/public";

export const prerender = false;
const site = await loadPublicSiteShell({ includeLegalContent: true });
const hasContent = site.disclaimerContent.trim().length > 0;
const canonical = hasContent ? new URL("/disclaimer", Astro.url.origin).href : null;
---

<PublicLayout
  site={site}
  title="Disclaimer"
  description={`Disclaimer for ${site.siteName}.`}
  canonical={canonical}
  robots={hasContent ? undefined : "noindex,follow"}
>
  <section class="public-section">
    <div class="public-section-heading">
      <div>
        <div class="eyebrow">Information</div>
        <h1>Disclaimer</h1>
      </div>
    </div>
    <div class="policy-card">{site.disclaimerContent || "No disclaimer has been published yet."}</div>
  </section>
</PublicLayout>
