---
import PublicLayout from "@/layouts/PublicLayout.astro";
import { loadPublicSiteShell } from "@/lib/db/public";

export const prerender = false;
const site = await loadPublicSiteShell();
const entryChannelSlug = site.defaultChannelSlug ?? site.channels[0]?.slug;
if (entryChannelSlug) {
  return Astro.redirect(`/${encodeURIComponent(entryChannelSlug)}`, 302);
}
---

<PublicLayout
  site={site}
  title={site.siteName}
  description={site.siteDescription}
  canonical={null}
  robots="noindex,follow"
  showChannelNavigation={false}
>
  <section class="public-section">
    <div class="public-empty">No published channels are available yet.</div>
  </section>
</PublicLayout>
