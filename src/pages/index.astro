---
import PublicLayout from "@/layouts/PublicLayout.astro";
import { loadPublicSiteShell } from "@/lib/db/public";

export const prerender = false;
const site = await loadPublicSiteShell();
if (site.defaultChannelSlug) {
  return Astro.redirect(`/${encodeURIComponent(site.defaultChannelSlug)}`, 302);
}
const canonical = new URL("/", Astro.url.origin).href;
---

<PublicLayout site={site} title={site.siteName} description={site.siteDescription} canonical={canonical}>
  <section class="public-section">
    <div class="public-section-heading">
      <div>
        <div class="eyebrow">Explore</div>
        <h1>{site.siteName}</h1>
        <p>{site.siteDescription}</p>
      </div>
    </div>

    {site.channels.length > 0 ? (
      <div class="category-grid">
        {site.channels.map((channel) => (
          <a class="visual-card" href={`/${encodeURIComponent(channel.slug)}`}>
            <span class="visual-card-placeholder" aria-hidden="true">{channel.icon.trim() || channel.name.trim().slice(0, 1)}</span>
            <span class="visual-card-overlay">
              <span class="visual-card-title">{channel.name}</span>
              <span class="visual-card-meta">Browse channel</span>
            </span>
          </a>
        ))}
      </div>
    ) : (
      <div class="public-empty">No published channels are available yet.</div>
    )}
  </section>
</PublicLayout>
