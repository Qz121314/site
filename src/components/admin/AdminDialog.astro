---
interface Props {
  id: string;
  title: string;
  size?: "small" | "medium" | "large";
}

const { id, title, size = "medium" } = Astro.props;
---

<dialog id={id} class:list={["admin-dialog", `is-${size}`]} data-admin-dialog aria-labelledby={`${id}-title`}>
  <header class="admin-dialog-header">
    <h2 id={`${id}-title`}>{title}</h2>
    <button class="admin-dialog-close" type="button" data-dialog-close aria-label="关闭弹窗">×</button>
  </header>
  <div class="admin-dialog-body">
    <slot />
  </div>
</dialog>

<style>
  .admin-dialog {
    position: fixed;
    inset: 0;
    width: min(calc(100vw - 2rem), 34rem);
    max-height: min(86vh, 52rem);
    margin: auto;
    overflow: hidden;
    border: 1px solid #cbd5e1;
    border-radius: .8rem;
    padding: 0;
    color: #0f172a;
    background: #ffffff;
    box-shadow: 0 28px 90px rgba(15, 23, 42, .28);
    overscroll-behavior: contain;
  }

  .admin-dialog.is-small { width: min(calc(100vw - 2rem), 28rem); }
  .admin-dialog.is-large { width: min(calc(100vw - 2rem), 46rem); }

  .admin-dialog::backdrop {
    background: rgba(15, 23, 42, .46);
    backdrop-filter: blur(3px);
  }

  .admin-dialog-header {
    display: flex;
    min-height: 3.2rem;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    border-bottom: 1px solid #e2e8f0;
    padding: .65rem .75rem;
    background: #f8fafc;
  }

  .admin-dialog-header h2 {
    margin: 0;
    font-size: .95rem;
  }

  .admin-dialog-close {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid #cbd5e1;
    border-radius: .5rem;
    padding: 0;
    color: #475569;
    background: #ffffff;
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
  }

  .admin-dialog-close:hover {
    color: #0f172a;
    background: #f1f5f9;
  }

  .admin-dialog-body {
    max-height: calc(min(86vh, 52rem) - 3.2rem);
    overflow: auto;
    padding: .75rem;
  }

  @media (max-width: 639px) {
    .admin-dialog,
    .admin-dialog.is-small,
    .admin-dialog.is-large {
      width: calc(100vw - 1rem);
      max-height: calc(100vh - 1rem);
      border-radius: .7rem;
    }

    .admin-dialog-body {
      max-height: calc(100vh - 4.2rem);
    }
  }
</style>
