---
import ProductGalleryUpload from "@/components/admin/ProductGalleryUpload.astro";
import type { AdminProduct, AdminProductOptions } from "@/lib/db/products";

type GalleryValue = {
  id: string;
  previewUrl?: string;
  name?: string;
  meta?: string;
};

interface Props {
  formId: string;
  channelId: string;
  options: AdminProductOptions;
  product?: AdminProduct;
  gallery?: GalleryValue[];
}

const { formId, channelId, options, product, gallery = [] } = Astro.props;
const selectedCategory = product?.categoryId
  ? options.categories.find((category) => category.id === product.categoryId) ?? null
  : null;
const selectedFilterIds = new Set(selectedCategory?.filterIds ?? []);
---

<section class="admin-card product-basic-card" data-product-editor>
  <div class="admin-section-bar">
    <h2>{product ? product.title : "基础信息"}</h2>
    {product && <span class="admin-section-note">/{product.slug}</span>}
  </div>

  <div class="admin-card-body product-basic-grid">
    <div class="admin-field product-field-title">
      <label for="product-title">产品名称</label>
      <input id="product-title" name="title" maxlength="160" required autocomplete="off" value={product?.title ?? ""} autofocus />
    </div>

    <input type="hidden" name="categoryId" value="" />
    <div class="admin-field product-field-category">
      <label for="product-category-name">产品分类</label>
      <input
        id="product-category-name"
        name="categoryName"
        maxlength="80"
        list="product-category-options"
        autocomplete="off"
        value={product?.categoryName ?? ""}
        data-category-name
      />
      <datalist id="product-category-options">
        {options.categories.map((category) => (
          <option value={category.name} data-filter-ids={category.filterIds.join(",")}></option>
        ))}
      </datalist>
    </div>

    <div class="admin-field product-field-filters">
      <label>分类筛选</label>
      {options.filters.length > 0 ? (
        <div class="filter-choice-grid" data-category-filter-list>
          {options.filters.map((filter) => {
            const enabled = filter.status === "enabled";
            return (
              <label
                class:list={["filter-choice", !enabled && "is-disabled"]}
                title={enabled ? undefined : "该筛选已停用，不能再绑定"}
              >
                <input
                  type="checkbox"
                  name="filterIds"
                  value={filter.id}
                  checked={selectedFilterIds.has(filter.id)}
                  disabled={!enabled}
                  data-category-filter
                />
                <span>{filter.name}{!enabled ? "（已停用）" : ""}</span>
              </label>
            );
          })}
        </div>
      ) : (
        <a class="empty-control-link" href={`/admin/channels/${encodeURIComponent(channelId)}/filters`}>设置分类筛选</a>
      )}
    </div>

    <div class="admin-field product-field-tags">
      <label for="product-tags">产品标签</label>
      <input
        id="product-tags"
        name="tags"
        maxlength="1000"
        value={product?.tags.join(", ") ?? ""}
        placeholder="tag-one, tag-two"
      />
    </div>

    <div class="admin-field product-field-conversion">
      <label for="product-conversion">转化组</label>
      <select id="product-conversion" name="conversionGroupId">
        <option value="">暂不绑定</option>
        {options.conversionGroups.map((group) => (
          <option value={group.id} selected={product?.conversionGroupId === group.id}>{group.name} · {group.enabledResourceCount}</option>
        ))}
      </select>
    </div>

    <div class="admin-field product-field-cta">
      <label for="product-cta">CTA 文案</label>
      <input id="product-cta" name="ctaLabel" maxlength="80" required value={product?.ctaLabel ?? "View Details"} />
    </div>

    <div class="admin-field product-field-status">
      <label for="product-status">发布状态</label>
      <select id="product-status" name="status">
        <option value="draft" selected={!product || product.status === "draft"}>草稿</option>
        <option value="published" selected={product?.status === "published"}>发布</option>
        <option value="disabled" selected={product?.status === "disabled"}>停用</option>
      </select>
    </div>

    <div class="admin-field product-field-sort">
      <label for="product-sort">排序</label>
      <input id="product-sort" name="sortOrder" type="number" min="-999999" max="999999" step="1" value={product?.sortOrder ?? 0} />
    </div>

    <div class="admin-field product-field-featured">
      <label>推荐</label>
      <label class="compact-check"><input type="checkbox" name="featured" value="1" checked={product?.featured ?? false} /> 置顶</label>
    </div>
  </div>
</section>

<div class="product-workspace">
  <section class="admin-card product-image-card">
    <div class="admin-section-bar"><h2>产品图片</h2></div>
    <div class="admin-card-body"><ProductGalleryUpload form={formId} values={gallery} /></div>
  </section>

  <section class="admin-card product-body-card">
    <div class="admin-section-bar"><h2>产品正文</h2></div>
    <div class="admin-card-body">
      <div class="admin-field">
        <label for="product-body">正文内容（支持 Markdown）</label>
        <textarea id="product-body" name="bodySource" maxlength="30000" rows="2" spellcheck="true" data-auto-grow>{product?.bodySource ?? ""}</textarea>
        <small>普通文本、换行、连续空格和表情会保留；也支持标题、列表、引用、粗体、斜体、链接和代码。</small>
      </div>
    </div>
  </section>
</div>

{product?.bodyHtml && (
  <details class="admin-card body-preview">
    <summary>正文预览</summary>
    <article class="markdown-body" set:html={product.bodyHtml}></article>
  </details>
)}
