---
export type ExistingUploadImage = {
  id: string;
  previewUrl?: string;
  name?: string;
  meta?: string;
};

interface Props {
  name: string;
  label: string;
  id?: string;
  form?: string;
  multiple?: boolean;
  required?: boolean;
  compact?: boolean;
  maxFiles?: number;
  directoryThumbnail?: boolean;
  heroResponsive?: boolean;
  assetVariant?: "logo" | "favicon";
  value?: string | null;
  values?: ExistingUploadImage[];
  help?: string;
}

const {
  name,
  label,
  id = `direct-upload-${name.replace(/[^a-z0-9_-]/giu, "-")}`,
  form,
  multiple = false,
  required = false,
  compact = false,
  maxFiles = multiple ? 30 : 1,
  directoryThumbnail = false,
  heroResponsive = false,
  assetVariant,
  value = null,
  values = [],
  help,
} = Astro.props;

const initialImages: ExistingUploadImage[] = multiple
  ? values
  : value
    ? [{ id: value, previewUrl: `/api/admin/images/${encodeURIComponent(value)}/content`, name: "当前图片" }]
    : [];
---

<div
  class:list={["direct-image-upload", compact && "is-compact"]}
  data-direct-image-upload
  data-field-name={name}
  data-multiple={multiple ? "1" : "0"}
  data-required={required ? "1" : "0"}
  data-max-files={String(maxFiles)}
  data-directory-thumbnail={directoryThumbnail ? "1" : "0"}
  data-hero-responsive={heroResponsive ? "1" : "0"}
  data-asset-variant={assetVariant ?? ""}
  data-form-id={form ?? ""}
>
  <div class="direct-upload-heading">
    <label for={id}>{label}</label>
    <span data-upload-status>{initialImages.length > 0 ? `已绑定 ${initialImages.length} 张` : "尚未选择"}</span>
  </div>

  <div class="direct-upload-input-row">
    <input
      id={id}
      class="direct-upload-file"
      type="file"
      accept="image/jpeg,image/png,image/webp"
      multiple={multiple}
      data-upload-input
    />
    <label class="button secondary direct-upload-button" for={id} data-upload-button>
      {multiple ? "选择多张图片" : "选择图片"}
    </label>
    <span class="direct-upload-limit">JPEG / PNG / WebP · 浏览器压缩 · 保存时上传</span>
  </div>

  <div class="direct-upload-values" data-upload-values>
    {!multiple && (
      <input
        type="hidden"
        name={name}
        value={initialImages[0]?.id ?? ""}
        form={form}
        data-upload-hidden
        data-image-id={initialImages[0]?.id ?? ""}
      />
    )}
    {multiple && initialImages.map((image, index) => (
      <input
        type="hidden"
        name={name}
        value={image.id}
        form={form}
        data-upload-hidden
        data-image-id={image.id}
        data-upload-order={index}
      />
    ))}
  </div>

  <div class="direct-upload-preview" data-upload-preview hidden={initialImages.length === 0}>
    {initialImages.map((image, index) => (
      <article class="direct-upload-item" data-upload-item data-image-id={image.id} data-upload-order={index}>
        <img
          src={image.previewUrl ?? `/api/admin/images/${encodeURIComponent(image.id)}/content`}
          alt={image.name ?? "已上传图片"}
          loading="lazy"
        />
        <div>
          <strong title={image.name ?? "已上传图片"}>{image.name ?? "已上传图片"}</strong>
          <span>{image.meta ?? "已绑定到当前内容"}</span>
        </div>
        <button class="direct-upload-remove" type="button" data-upload-remove aria-label="移除图片">×</button>
      </article>
    ))}
  </div>

  {help && <small class="direct-upload-help">{help}</small>}
</div>

<script>import "@/scripts/admin-direct-image-upload";</script>

<style>
  .direct-image-upload { display: grid; min-width: 0; gap: .35rem; }
  .direct-upload-heading { display: flex; align-items: center; justify-content: space-between; gap: .75rem; }
  .direct-upload-heading label { color: #b9b3bf; font-size: .72rem; font-weight: 650; }
  .direct-upload-heading span,
  .direct-upload-limit,
  .direct-upload-help { color: #827c88; font-size: .68rem; }
  .direct-upload-input-row { display: flex; flex-wrap: wrap; align-items: center; gap: .4rem; }
  .direct-upload-file { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }
  .direct-upload-button { cursor: pointer; }
  .direct-upload-button[aria-disabled="true"] { opacity: .55; pointer-events: none; }
  .direct-upload-preview { display: grid; grid-template-columns: repeat(auto-fill, minmax(9rem, 1fr)); gap: .4rem; }
  .direct-upload-preview[hidden] { display: none; }
  .direct-upload-item { position: relative; display: grid; grid-template-columns: 3.2rem minmax(0, 1fr) 1.6rem; gap: .4rem; align-items: center; overflow: hidden; border: 1px solid #302d36; border-radius: .38rem; padding: .3rem; background: #0d0c10; }
  .direct-upload-item[data-upload-pending] { border-color: rgba(37, 99, 235, .55); }
  .direct-upload-item img { width: 3.2rem; height: 3.2rem; border-radius: .25rem; object-fit: cover; background: #070608; }
  .direct-upload-item > div { display: grid; min-width: 0; gap: .12rem; }
  .direct-upload-item strong,
  .direct-upload-item span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .direct-upload-item strong { font-size: .7rem; }
  .direct-upload-item span { color: #817b87; font-size: .64rem; }
  .direct-upload-remove { width: 1.45rem; height: 1.45rem; border: 0; border-radius: 999px; padding: 0; color: #ffc3cf; background: rgba(255,109,139,.12); cursor: pointer; }
  .direct-upload-remove:disabled { opacity: .45; cursor: wait; }
  .direct-image-upload.is-compact .direct-upload-preview { grid-template-columns: minmax(10rem, 1fr); }
  .direct-image-upload.is-compact .direct-upload-item { grid-template-columns: 2.4rem minmax(0, 1fr) 1.5rem; }
  .direct-image-upload.is-compact .direct-upload-item img { width: 2.4rem; height: 2.4rem; }
</style>
