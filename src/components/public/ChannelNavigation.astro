---
import type { PublicSiteShell } from "@/lib/db/public";

interface Props {
  channels: PublicSiteShell["channels"];
  activeChannel?: string | null;
}

const { channels, activeChannel = null } = Astro.props;
---

{channels.length > 0 && (
  <nav class="public-bottom-nav" aria-label="Channels">
    <div class="public-bottom-nav-track">
      {channels.map((channel) => (
        <a
          class="public-nav-item"
          href={`/${encodeURIComponent(channel.slug)}`}
          aria-current={activeChannel === channel.slug ? "page" : undefined}
        >
          <span class="public-nav-icon" aria-hidden="true">
            {channel.icon ? (
              channel.icon
            ) : (
              <svg viewBox="0 0 24 24">
                <rect x="4" y="4" width="6" height="6" rx="1.5" fill="currentColor" />
                <rect x="14" y="4" width="6" height="6" rx="1.5" fill="currentColor" />
                <rect x="4" y="14" width="6" height="6" rx="1.5" fill="currentColor" />
                <rect x="14" y="14" width="6" height="6" rx="1.5" fill="currentColor" />
              </svg>
            )}
          </span>
          <span class="public-nav-label">{channel.name}</span>
        </a>
      ))}
    </div>
  </nav>
)}
