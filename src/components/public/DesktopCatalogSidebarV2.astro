---
import type {
  PublicCategoryFilter,
  PublicChannel,
  PublicSiteShell,
} from "@/lib/db/public";

interface Props {
  site: PublicSiteShell;
  channel: PublicChannel;
  filters: PublicCategoryFilter[];
  activeFilterSlug?: string | null;
}

const {
  site,
  channel,
  filters,
  activeFilterSlug = filters[0]?.slug ?? null,
} = Astro.props;
const longestNavigationLabel = [...site.channels.map((item) => item.name), ...filters.map((item) => item.name)]
  .reduce((longest, label) => Math.max(longest, Array.from(label.trim()).length), 0);
const navigationCharacterWidth = Math.min(Math.max(longestNavigationLabel + 5, 13), 24);
const navigationStyle = `--desktop-nav-fit: ${navigationCharacterWidth}ch`;
const searchHref = `/${encodeURIComponent(channel.slug)}/search`;
---

<aside class="desktop-nav-rail" aria-label="Site and section navigation" style={navigationStyle}>
  <a class="desktop-nav-brand" href="/" aria-label={`${site.siteName} home`}>
    {site.logoUrl ? (
      <img class="desktop-nav-brand-logo" src={site.logoUrl} alt="" decoding="async" />
    ) : (
      <span class="desktop-nav-brand-name">{site.siteName}</span>
    )}
  </a>

  <nav class="desktop-nav-menu" aria-label="Sections">
    {site.channels.map((item, index) => {
      const active = item.id === channel.id;
      const expanded = active && filters.length > 0;
      return (
        <section class={`desktop-nav-section desktop-nav-section-${(index % 4) + 1}`}>
          <a
            class="desktop-nav-section-link"
            href={`/${encodeURIComponent(item.slug)}`}
            aria-current={active ? "page" : undefined}
            aria-expanded={expanded ? "true" : undefined}
          >
            <span class="desktop-nav-section-label">{item.name}</span>
          </a>

          {expanded && (
            <div class="desktop-nav-filter-list" aria-label={`${item.name} filters`}>
              {filters.map((filter) => (
                <a
                  class={`desktop-nav-filter-link${activeFilterSlug === filter.slug ? " is-active" : ""}`}
                  href={`/${encodeURIComponent(item.slug)}#filter-${encodeURIComponent(filter.slug)}`}
                  data-desktop-filter-link={filter.slug}
                  aria-current={activeFilterSlug === filter.slug ? "location" : undefined}
                >
                  <span class="desktop-nav-filter-label">{filter.name}</span>
                </a>
              ))}
            </div>
          )}
        </section>
      );
    })}
  </nav>

  <nav class="desktop-nav-tools" aria-label="Site tools">
    <a class="desktop-nav-tool-link desktop-nav-search-link" href={searchHref}>Search</a>
    <a class="desktop-nav-tool-link" href="/privacy">Privacy</a>
    <a class="desktop-nav-tool-link" href="/disclaimer">Disclaimer</a>
  </nav>
</aside>
