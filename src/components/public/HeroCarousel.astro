---
import type { PublicHeroAdvertisement } from "@/lib/db/public";

interface Props {
  advertisements: PublicHeroAdvertisement[];
}

const { advertisements } = Astro.props;
const carouselId = `hero-${crypto.randomUUID()}`;
---

{advertisements.length > 0 && (
  <section
    class="hero-carousel"
    id={carouselId}
    data-hero-carousel
    aria-label="Featured promotions"
    aria-roledescription="carousel"
  >
    <div class="hero-track" data-hero-track>
      {advertisements.map((advertisement, index) => (
        <a
          class="hero-slide"
          href={advertisement.targetUrl}
          target={advertisement.openMode === "new" ? "_blank" : undefined}
          rel={advertisement.openMode === "new" ? "noopener noreferrer" : undefined}
          data-hero-slide
          aria-label={`Promotion ${index + 1} of ${advertisements.length}`}
        >
          <img
            src={advertisement.imageUrl}
            alt=""
            loading={index === 0 ? "eager" : "lazy"}
            fetchpriority={index === 0 ? "high" : "auto"}
          />
        </a>
      ))}
    </div>

    {advertisements.length > 1 && (
      <div class="hero-dots" aria-label="Promotion pages">
        {advertisements.map((_, index) => (
          <button
            class="hero-dot"
            type="button"
            data-hero-dot={index}
            aria-label={`Show promotion ${index + 1}`}
            aria-current={index === 0 ? "true" : "false"}
          ></button>
        ))}
      </div>
    )}
  </section>
)}

<script is:inline>
  (() => {
    const initialize = (root) => {
      if (root.dataset.ready === '1') return;
      root.dataset.ready = '1';

      const track = root.querySelector('[data-hero-track]');
      const slides = Array.from(root.querySelectorAll('[data-hero-slide]'));
      const dots = Array.from(root.querySelectorAll('[data-hero-dot]'));
      if (!track || slides.length < 2) return;

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      let active = 0;
      let timer = 0;
      let pointerStart = 0;
      let scrollStart = 0;
      let dragged = false;

      const updateDots = () => {
        dots.forEach((dot, index) => dot.setAttribute('aria-current', index === active ? 'true' : 'false'));
      };

      const goTo = (index, behavior = 'smooth') => {
        active = (index + slides.length) % slides.length;
        track.scrollTo({ left: active * track.clientWidth, behavior });
        updateDots();
      };

      const stop = () => {
        if (timer) window.clearInterval(timer);
        timer = 0;
      };

      const shouldPause = () => (
        document.hidden
        || reducedMotion.matches
        || root.matches(':hover')
        || root.contains(document.activeElement)
      );

      const start = () => {
        stop();
        if (shouldPause()) return;
        timer = window.setInterval(() => goTo(active + 1), 5000);
      };

      dots.forEach((dot, index) => dot.addEventListener('click', () => {
        goTo(index);
        start();
      }));

      let scrollTimer = 0;
      track.addEventListener('scroll', () => {
        window.clearTimeout(scrollTimer);
        scrollTimer = window.setTimeout(() => {
          active = Math.max(0, Math.min(slides.length - 1, Math.round(track.scrollLeft / Math.max(track.clientWidth, 1))));
          updateDots();
        }, 80);
      }, { passive: true });

      track.addEventListener('pointerdown', (event) => {
        pointerStart = event.clientX;
        scrollStart = track.scrollLeft;
        dragged = false;
        track.classList.add('is-dragging');
        track.setPointerCapture(event.pointerId);
        stop();
      });

      track.addEventListener('pointermove', (event) => {
        if (!track.hasPointerCapture(event.pointerId)) return;
        const distance = event.clientX - pointerStart;
        if (Math.abs(distance) > 5) dragged = true;
        track.scrollLeft = scrollStart - distance;
      });

      const release = (event) => {
        if (track.hasPointerCapture(event.pointerId)) track.releasePointerCapture(event.pointerId);
        track.classList.remove('is-dragging');
        goTo(Math.round(track.scrollLeft / Math.max(track.clientWidth, 1)));
        start();
      };

      track.addEventListener('pointerup', release);
      track.addEventListener('pointercancel', release);
      track.addEventListener('click', (event) => {
        if (!dragged) return;
        event.preventDefault();
        dragged = false;
      });

      root.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
        event.preventDefault();
        goTo(active + (event.key === 'ArrowRight' ? 1 : -1));
      });
      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', start);
      root.addEventListener('focusin', stop);
      root.addEventListener('focusout', (event) => {
        if (event.relatedTarget instanceof Node && root.contains(event.relatedTarget)) return;
        start();
      });
      document.addEventListener('visibilitychange', start);
      reducedMotion.addEventListener('change', start);
      window.addEventListener('resize', () => goTo(active, 'auto'));
      start();
    };

    document.querySelectorAll('[data-hero-carousel]').forEach(initialize);
  })();
</script>

<style>
  .hero-dots {
    position: absolute;
    z-index: 5;
    left: 50%;
    bottom: .45rem;
    display: flex;
    align-items: center;
    gap: .08rem;
    border: 1px solid rgba(216, 173, 97, .2);
    border-radius: 999px;
    padding: .08rem .18rem;
    background: rgba(6, 6, 5, .58);
    box-shadow: 0 8px 24px rgba(0, 0, 0, .25);
    backdrop-filter: blur(10px);
    transform: translateX(-50%);
  }

  .hero-dot,
  .hero-dot[aria-current="true"] {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border: 0;
    padding: 0;
    background: transparent;
    touch-action: manipulation;
  }

  .hero-dot::before {
    width: .36rem;
    height: .36rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, .5);
    content: "";
    transition: width .16s ease, background .16s ease;
  }

  .hero-dot[aria-current="true"]::before {
    width: 1.05rem;
    background: var(--public-gold-bright);
  }
</style>
