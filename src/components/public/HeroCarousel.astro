---
import type { PublicHeroAdvertisement } from "@/lib/db/public";

interface Props {
  advertisements: PublicHeroAdvertisement[];
}

const { advertisements } = Astro.props;
const carouselId = `hero-${crypto.randomUUID()}`;
---

{advertisements.length > 0 && (
  <section
    class="hero-carousel"
    id={carouselId}
    data-hero-carousel
    aria-label="Featured promotions"
    aria-roledescription="carousel"
  >
    <div class="hero-track" data-hero-track>
      {advertisements.map((advertisement, index) => (
        <a
          class="hero-slide"
          href={advertisement.targetUrl}
          target={advertisement.openMode === "new" ? "_blank" : undefined}
          rel={advertisement.openMode === "new" ? "noopener noreferrer" : undefined}
          data-hero-slide
          data-load-surface
          aria-label={`Promotion ${index + 1} of ${advertisements.length}`}
          aria-busy="true"
          draggable="false"
        >
          <img
            src={advertisement.imageUrl}
            alt=""
            width={advertisement.width ?? undefined}
            height={advertisement.height ?? undefined}
            loading="lazy"
            decoding="async"
            fetchpriority="low"
            data-load-reveal
            draggable="false"
            onload="this.classList.add('is-loaded');this.closest('[data-load-surface]')?.classList.add('is-loaded');this.closest('[data-load-surface]')?.removeAttribute('aria-busy')"
            onerror="this.classList.add('is-load-error');this.closest('[data-load-surface]')?.classList.add('is-load-error');this.closest('[data-load-surface]')?.removeAttribute('aria-busy')"
          />
        </a>
      ))}
    </div>

    {advertisements.length > 1 && (
      <div class="hero-dots" aria-label="Promotion pages">
        {advertisements.map((_, index) => (
          <button
            class="hero-dot"
            type="button"
            data-hero-dot={index}
            aria-label={`Show promotion ${index + 1}`}
            aria-current={index === 0 ? "true" : "false"}
          ></button>
        ))}
      </div>
    )}
  </section>
)}

<script>import "@/scripts/public-hero-carousel";</script>

<style>
  .hero-dots {
    position: absolute;
    z-index: 5;
    left: 50%;
    bottom: .45rem;
    display: flex;
    align-items: center;
    gap: .08rem;
    border: 1px solid rgba(216, 173, 97, .2);
    border-radius: 999px;
    padding: .08rem .18rem;
    background: rgba(6, 6, 5, .58);
    box-shadow: 0 8px 24px rgba(0, 0, 0, .25);
    backdrop-filter: blur(10px);
    transform: translateX(-50%);
  }

  .hero-dot,
  .hero-dot[aria-current="true"] {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border: 0;
    padding: 0;
    background: transparent;
    touch-action: manipulation;
  }

  .hero-dot::before {
    width: .36rem;
    height: .36rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, .5);
    content: "";
    transition: width .16s ease, background .16s ease;
  }

  .hero-dot[aria-current="true"]::before {
    width: 1.05rem;
    background: var(--public-gold-bright);
  }
</style>
