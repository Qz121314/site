---
import type { PublicHeroAdvertisement } from "@/lib/db/public";

interface Props {
  advertisements: PublicHeroAdvertisement[];
}

const { advertisements } = Astro.props;
const carouselId = `hero-${crypto.randomUUID()}`;

function sourceSet(advertisement: PublicHeroAdvertisement): string | undefined {
  if (!advertisement.responsiveImageUrl || !advertisement.responsiveWidth || !advertisement.width) return undefined;
  return `${advertisement.responsiveImageUrl} ${advertisement.responsiveWidth}w, ${advertisement.imageUrl} ${advertisement.width}w`;
}
---

{advertisements.length > 0 && (
  <section
    class="hero-carousel"
    id={carouselId}
    data-hero-carousel
    aria-label="Featured promotions"
    aria-roledescription="carousel"
  >
    <div class="hero-track" data-hero-track>
      {advertisements.map((advertisement, index) => (
        <a
          class="hero-slide"
          href={advertisement.targetUrl}
          target={advertisement.openMode === "new" ? "_blank" : undefined}
          rel={advertisement.openMode === "new" ? "noopener noreferrer" : undefined}
          data-hero-slide
          data-load-surface={index === 0 ? undefined : ""}
          aria-label={`Promotion ${index + 1} of ${advertisements.length}`}
          aria-busy={index === 0 ? undefined : "true"}
          draggable="false"
        >
          <img
            src={advertisement.responsiveImageUrl ?? advertisement.imageUrl}
            srcset={sourceSet(advertisement)}
            sizes="(min-width: 1100px) 1344px, (min-width: 768px) calc(100vw - 3rem), calc(100vw - 2rem)"
            alt=""
            width={advertisement.width ?? undefined}
            height={advertisement.height ?? undefined}
            loading={index === 0 ? "eager" : "lazy"}
            decoding="async"
            fetchpriority={index === 0 ? "high" : "low"}
            data-load-reveal={index === 0 ? undefined : ""}
            draggable="false"
            onload="this.classList.add('is-loaded');this.closest('[data-load-surface]')?.classList.add('is-loaded');this.closest('[data-load-surface]')?.removeAttribute('aria-busy')"
            onerror="this.classList.add('is-load-error');this.closest('[data-load-surface]')?.classList.add('is-load-error');this.closest('[data-load-surface]')?.removeAttribute('aria-busy')"
          />
        </a>
      ))}
    </div>

    {advertisements.length > 1 && (
      <div class="hero-dots" aria-label="Promotion pages">
        {advertisements.map((_, index) => (
          <button
            class="hero-dot"
            type="button"
            data-hero-dot={index}
            aria-label={`Show promotion ${index + 1}`}
            aria-current={index === 0 ? "true" : "false"}
          ></button>
        ))}
      </div>
    )}
  </section>
)}

<script>import "@/scripts/public-hero-carousel";</script>

<style>
  .hero-dots {
    position: absolute;
    z-index: 5;
    left: 50%;
    bottom: .55rem;
    display: flex;
    align-items: center;
    gap: .12rem;
    border: 1px solid rgba(255, 255, 255, .64);
    border-radius: 999px;
    padding: .1rem .2rem;
    background: rgba(255, 255, 255, .9);
    box-shadow: 0 4px 14px rgba(0, 0, 0, .12);
    transform: translateX(-50%);
  }

  .hero-carousel.is-static .hero-dots {
    display: none;
  }

  .hero-dot,
  .hero-dot[aria-current="true"] {
    display: grid;
    width: 2.5rem;
    height: 2.5rem;
    place-items: center;
    border: 0;
    padding: 0;
    background: transparent;
    touch-action: manipulation;
  }

  .hero-dot::before {
    width: .34rem;
    height: .34rem;
    border-radius: 999px;
    background: #999999;
    content: "";
    transition: width .16s ease, background .16s ease;
  }

  .hero-dot[aria-current="true"]::before {
    width: 1rem;
    background: #111111;
  }
</style>
