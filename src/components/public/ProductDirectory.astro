---
import ProductCard from "@/components/public/ProductCard.astro";
import type { PublicProductPage } from "@/lib/db/public";
import { publicPageHref } from "@/lib/public/pagination";

interface Props {
  channelSlug: string;
  page: PublicProductPage;
  categorySlug?: string | null;
  preserveCategoryQuery?: boolean;
  emptyMessage?: string;
  priorityCount?: number;
}

const {
  channelSlug,
  page,
  categorySlug = null,
  preserveCategoryQuery = false,
  emptyMessage = "No products found.",
  priorityCount = 2,
} = Astro.props;

function directoryPageHref(pageNumber: number): string {
  const href = publicPageHref(Astro.url, pageNumber);
  if (!preserveCategoryQuery || !categorySlug) return href;

  const url = new URL(href, Astro.url.origin);
  url.searchParams.set("category", categorySlug);
  return `${url.pathname}${url.search}`;
}

const previousPageHref = page.page > 1 ? directoryPageHref(page.page - 1) : null;
const nextPageHref = page.hasMore ? directoryPageHref(page.page + 1) : null;
---

<div
  class="product-directory"
  data-product-directory
  data-channel={channelSlug}
  data-category={categorySlug ?? ""}
  data-preserve-category-query={preserveCategoryQuery ? "1" : "0"}
  data-next-page={page.page + 1}
>
  {page.products.length > 0 ? (
    <div class="product-grid" data-product-grid>
      {page.products.map((product, index) => (
        <ProductCard product={product} channelSlug={channelSlug} priority={index < priorityCount} />
      ))}
    </div>
  ) : (
    <div class="public-empty public-empty-products" data-product-empty>
      <span class="public-empty-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M7 8.5 12 5l5 3.5v7L12 19l-5-3.5z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.45" />
          <path d="m7 8.5 5 3.4 5-3.4M12 12v7" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.45" />
        </svg>
      </span>
      <p class="public-empty-title">{emptyMessage}</p>
      <p class="public-empty-note">New listings will appear here when they are published.</p>
    </div>
  )}

  {(previousPageHref || nextPageHref) && (
    <nav class="load-more-row product-pagination" data-load-more-row aria-label="Product pages">
      {previousPageHref && (
        <a class="public-button secondary product-page-link" href={previousPageHref} rel="prev">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m15 18-6-6 6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
          </svg>
          <span>Previous</span>
        </a>
      )}
      {nextPageHref && (
        <a class="public-button secondary load-more-button product-page-link" href={nextPageHref} rel="next" data-load-more>
          <span data-load-more-label>Load More</span>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6 9 6 6 6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
          </svg>
        </a>
      )}
    </nav>
  )}
</div>

<script>import "@/scripts/public-product-directory";</script>

<style>
  .product-pagination {
    flex-wrap: wrap;
    gap: .6rem;
  }

  .product-page-link {
    min-width: 9rem;
    flex: 0 1 19rem;
  }

  .product-page-link svg {
    width: 1rem;
    height: 1rem;
  }

  .product-page-link[aria-disabled="true"] {
    opacity: .5;
    pointer-events: none;
  }
</style>
