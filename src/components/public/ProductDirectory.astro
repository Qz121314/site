---
import ProductCard from "@/components/public/ProductCard.astro";
import type { PublicProductPage } from "@/lib/db/public";
import { publicPageHref } from "@/lib/public/pagination";

interface Props {
  channelSlug: string;
  page: PublicProductPage;
  categorySlug?: string | null;
  query?: string;
  uncategorizedOnly?: boolean;
  emptyMessage?: string;
}

const {
  channelSlug,
  page,
  categorySlug = null,
  query = "",
  uncategorizedOnly = false,
  emptyMessage = "No products found.",
} = Astro.props;
const previousPageHref = page.page > 1 ? publicPageHref(Astro.url, page.page - 1) : null;
const nextPageHref = page.hasMore ? publicPageHref(Astro.url, page.page + 1) : null;
---

<div
  class="product-directory"
  data-product-directory
  data-channel={channelSlug}
  data-category={categorySlug ?? ""}
  data-query={query}
  data-uncategorized={uncategorizedOnly ? "1" : "0"}
  data-next-page={page.page + 1}
>
  {page.products.length > 0 ? (
    <div class="product-grid" data-product-grid>
      {page.products.map((product) => <ProductCard product={product} channelSlug={channelSlug} />)}
    </div>
  ) : (
    <div class="public-empty" data-product-empty>{emptyMessage}</div>
  )}

  {(previousPageHref || nextPageHref) && (
    <nav class="load-more-row product-pagination" data-load-more-row aria-label="Product pages">
      {previousPageHref && (
        <a class="public-button secondary product-page-link" href={previousPageHref} rel="prev">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m15 18-6-6 6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
          </svg>
          <span>Previous</span>
        </a>
      )}
      {nextPageHref && (
        <a class="public-button secondary load-more-button product-page-link" href={nextPageHref} rel="next" data-load-more>
          <span data-load-more-label>Load More</span>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6 9 6 6 6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
          </svg>
        </a>
      )}
    </nav>
  )}
</div>

<script is:inline>
  (() => {
    const createProductCard = (product, channelSlug) => {
      const link = document.createElement('a');
      link.className = 'visual-card product-card';
      link.href = `/${encodeURIComponent(channelSlug)}/product/${encodeURIComponent(product.slug)}`;

      if (product.coverUrl) {
        const image = document.createElement('img');
        image.className = 'visual-card-media';
        image.src = product.coverUrl;
        image.alt = '';
        image.loading = 'lazy';
        link.append(image);
      } else {
        const placeholder = document.createElement('span');
        placeholder.className = 'visual-card-placeholder';
        placeholder.setAttribute('aria-hidden', 'true');
        placeholder.textContent = product.title.trim().slice(0, 1).toUpperCase() || 'P';
        link.append(placeholder);
      }


      const overlay = document.createElement('span');
      overlay.className = 'visual-card-overlay';
      const title = document.createElement('span');
      title.className = 'visual-card-title';
      title.textContent = product.title;
      overlay.append(title);

      if (Array.isArray(product.tags) && product.tags.length > 0) {
        const tags = document.createElement('span');
        tags.className = 'visual-card-meta';
        product.tags.slice(0, 3).forEach((tag) => {
          const item = document.createElement('span');
          item.className = 'visual-tag';
          item.textContent = tag;
          tags.append(item);
        });
        overlay.append(tags);
      }

      link.append(overlay);
      return link;
    };

    const pageHref = (page) => {
      const url = new URL(window.location.href);
      url.search = '';
      if (page > 1) url.searchParams.set('page', String(page));
      return `${url.pathname}${url.search}`;
    };

    const initialize = (root) => {
      if (root.dataset.ready === '1') return;
      root.dataset.ready = '1';
      const nextLink = root.querySelector('[data-load-more]');
      const label = root.querySelector('[data-load-more-label]');
      const row = root.querySelector('[data-load-more-row]');
      const grid = root.querySelector('[data-product-grid]');
      if (!nextLink || !label || !row || !grid) return;

      nextLink.addEventListener('click', async (event) => {
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
        event.preventDefault();
        if (nextLink.dataset.loading === '1') return;

        nextLink.dataset.loading = '1';
        nextLink.setAttribute('aria-busy', 'true');
        nextLink.setAttribute('aria-disabled', 'true');
        label.textContent = 'Loading…';
        const page = Number(root.dataset.nextPage || '2');
        const params = new URLSearchParams({ page: String(page) });
        if (root.dataset.category) params.set('category', root.dataset.category);
        if (root.dataset.query) params.set('q', root.dataset.query);
        if (root.dataset.uncategorized === '1') params.set('uncategorized', '1');

        try {
          const response = await fetch(`/api/public/channels/${encodeURIComponent(root.dataset.channel || '')}/products?${params}`, {
            headers: { Accept: 'application/json' },
          });
          if (!response.ok) throw new Error(`Request failed: ${response.status}`);
          const payload = await response.json();
          if (!Array.isArray(payload.products)) throw new Error('Invalid response');
          payload.products.forEach((product) => grid.append(createProductCard(product, root.dataset.channel || '')));
          root.dataset.nextPage = String(page + 1);

          if (!payload.hasMore) {
            nextLink.remove();
            const end = document.createElement('p');
            end.className = 'end-of-results';
            end.textContent = 'You’ve reached the end.';
            row.append(end);
          } else {
            nextLink.href = pageHref(page + 1);
            delete nextLink.dataset.loading;
            nextLink.removeAttribute('aria-busy');
            nextLink.removeAttribute('aria-disabled');
            label.textContent = 'Load More';
          }
        } catch (error) {
          console.error(error);
          delete nextLink.dataset.loading;
          nextLink.removeAttribute('aria-busy');
          nextLink.removeAttribute('aria-disabled');
          label.textContent = 'Try Again';
        }
      });
    };

    document.querySelectorAll('[data-product-directory]').forEach(initialize);
  })();
</script>

<style>
  .product-pagination {
    flex-wrap: wrap;
    gap: .6rem;
  }

  .product-page-link {
    min-width: 9rem;
    flex: 0 1 19rem;
  }

  .product-page-link svg {
    width: 1rem;
    height: 1rem;
  }

  .product-page-link[aria-disabled="true"] {
    opacity: .5;
    pointer-events: none;
  }
</style>
