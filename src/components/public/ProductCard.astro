---
import type { PublicProductCard } from "@/lib/db/public";

interface Props {
  product: PublicProductCard;
  channelSlug: string;
  priority?: boolean;
}

const { product, channelSlug, priority = false } = Astro.props;
---

<a
  class={`visual-card product-card${product.coverUrl ? "" : " is-loaded"}`}
  href={`/${encodeURIComponent(channelSlug)}/product/${encodeURIComponent(product.slug)}`}
  data-load-surface
  aria-busy={product.coverUrl ? "true" : undefined}
>
  {product.coverUrl ? (
    <img
      class="visual-card-media"
      src={product.coverUrl}
      alt=""
      width={product.coverWidth ?? undefined}
      height={product.coverHeight ?? undefined}
      loading={priority ? "eager" : "lazy"}
      decoding="async"
      fetchpriority={priority ? "high" : "auto"}
      draggable="false"
      data-load-reveal
      onload="this.classList.add('is-loaded');this.closest('[data-load-surface]')?.classList.add('is-loaded');this.closest('[data-load-surface]')?.removeAttribute('aria-busy')"
      onerror="this.classList.add('is-load-error');this.closest('[data-load-surface]')?.classList.add('is-load-error');this.closest('[data-load-surface]')?.removeAttribute('aria-busy')"
    />
  ) : (
    <span class="visual-card-placeholder" aria-hidden="true">{product.title.trim().slice(0, 1).toUpperCase() || "P"}</span>
  )}
  <span class="visual-card-overlay">
    <span class="visual-card-title">{product.title}</span>
  </span>
</a>
