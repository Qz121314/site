---
import CategoryCard from "@/components/public/CategoryCard.astro";
import type {
  PublicCategory,
  PublicCategoryFilter,
  PublicChannel,
  PublicSiteShell,
} from "@/lib/db/public";

interface CategoryGroup {
  filter: PublicCategoryFilter;
  categories: PublicCategory[];
}

interface Props {
  site: PublicSiteShell;
  channel: PublicChannel;
  categoryGroups: CategoryGroup[];
  ungroupedCategories: PublicCategory[];
  activeCategoryId?: string | null;
}

const {
  site,
  channel,
  categoryGroups,
  ungroupedCategories,
  activeCategoryId = null,
} = Astro.props;
const channelColumns = Math.min(Math.max(site.channels.length, 1), 4);
const filterColumns = Math.min(Math.max(categoryGroups.length, 1), 4);
---

<aside class="desktop-catalog-sidebar" aria-label={`${channel.name} navigation`} data-category-section>
  {site.channels.length > 1 && (
    <nav
      class="desktop-channel-switcher"
      aria-label="Sections"
      style={`--desktop-channel-columns: ${channelColumns}`}
    >
      {site.channels.map((item) => (
        <a
          class="desktop-channel-switcher-item"
          href={`/${encodeURIComponent(item.slug)}`}
          aria-current={item.slug === channel.slug ? "page" : undefined}
        >
          <span>{item.name}</span>
        </a>
      ))}
    </nav>
  )}

  {categoryGroups.length > 0 && (
    <nav
      class="category-filter-bar desktop-catalog-filter-bar"
      aria-label="Category filters"
      style={`--category-filter-columns: ${filterColumns}`}
    >
      {categoryGroups.map(({ filter }) => (
        <button
          class="category-filter-button"
          type="button"
          data-category-group-filter={filter.id}
          aria-pressed="false"
        >
          <span>{filter.name}</span>
        </button>
      ))}
    </nav>
  )}

  <div class="desktop-category-groups">
    {categoryGroups.map(({ filter, categories }) => (
      <section class="desktop-category-group" data-category-group-row={filter.id} aria-labelledby={`desktop-category-group-${filter.id}`}>
        <h2 class="desktop-category-group-title" id={`desktop-category-group-${filter.id}`}>{filter.name}</h2>
        <div class="desktop-category-grid">
          {categories.map((category) => (
            <CategoryCard
              category={category}
              channelSlug={channel.slug}
              active={category.id === activeCategoryId}
            />
          ))}
        </div>
      </section>
    ))}

    {ungroupedCategories.length > 0 && (
      <section class="desktop-category-group" data-category-group-row="" aria-labelledby="desktop-category-group-other">
        <h2 class="desktop-category-group-title" id="desktop-category-group-other">Categories</h2>
        <div class="desktop-category-grid">
          {ungroupedCategories.map((category) => (
            <CategoryCard
              category={category}
              channelSlug={channel.slug}
              active={category.id === activeCategoryId}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</aside>
