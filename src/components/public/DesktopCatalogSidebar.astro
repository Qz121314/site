---
import type {
  PublicCategoryFilter,
  PublicChannel,
  PublicSiteShell,
} from "@/lib/db/public";

interface Props {
  site: PublicSiteShell;
  channel: PublicChannel;
  filtersByChannel: Record<string, PublicCategoryFilter[]>;
}

const { site, channel, filtersByChannel } = Astro.props;
---

<aside class="desktop-density-sidebar" aria-label="Section and filter navigation">
  <nav class="desktop-density-navigation">
    {site.channels.map((item) => {
      const filters = filtersByChannel[item.id] ?? [];
      const active = item.id === channel.id;
      return (
        <section class="desktop-density-section-group" aria-labelledby={`desktop-section-${item.id}`}>
          <a
            class="desktop-density-section-link"
            id={`desktop-section-${item.id}`}
            href={`/${encodeURIComponent(item.slug)}`}
            aria-current={active ? "page" : undefined}
          >
            <span>{item.name}</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m9 18 6-6-6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
            </svg>
          </a>

          {filters.length > 0 && (
            <div class="desktop-density-filter-list">
              {filters.map((filter) => (
                <a
                  class="desktop-density-filter-link"
                  href={`/${encodeURIComponent(item.slug)}#filter-${encodeURIComponent(filter.slug)}`}
                  data-desktop-filter-link={active ? filter.slug : undefined}
                >
                  <span>{filter.name}</span>
                </a>
              ))}
            </div>
          )}
        </section>
      );
    })}
  </nav>
</aside>
