---
interface Props {
  href: string;
  label?: string;
}

const { href, label = "BACK" } = Astro.props;
---

<a class="public-back-link" href={href}>
  <span class="public-back-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24">
      <path d="m14.5 18-6-6 6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  </span>
  <span>{label}</span>
</a>
