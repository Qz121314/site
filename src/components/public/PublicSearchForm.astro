---
interface Props {
  action: string;
  ariaLabel: string;
  placeholder?: string;
  value?: string;
  required?: boolean;
  autofocus?: boolean;
}

const {
  action,
  ariaLabel,
  placeholder = "Search",
  value = "",
  required = false,
  autofocus = false,
} = Astro.props;
---

<form class="public-search-form" action={action} method="get" role="search">
  <span class="public-search-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24">
      <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="1.7" />
      <path d="m16 16 4 4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.7" />
    </svg>
  </span>
  <input
    name="q"
    type="search"
    maxlength="100"
    placeholder={placeholder}
    aria-label={ariaLabel}
    value={value}
    required={required || undefined}
    autofocus={autofocus || undefined}
  />
  <button class="public-search-submit" type="submit" aria-label="Search">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="m9 18 6-6-6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  </button>
</form>
