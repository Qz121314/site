---
import DesktopCatalogSidebarV2 from "@/components/public/DesktopCatalogSidebarV2.astro";
import type { PublicCategoryFilter, PublicSiteShell } from "@/lib/db/public";

interface ChannelSummary {
  id: string;
  name: string;
  slug: string;
}

interface Props {
  site: PublicSiteShell;
  channel: ChannelSummary;
  filters: PublicCategoryFilter[];
  activeFilterSlug?: string | null;
  ariaLabel: string;
  className?: string;
}

const {
  site,
  channel,
  filters,
  activeFilterSlug = filters[0]?.slug ?? null,
  ariaLabel,
  className = "",
} = Astro.props;
---

<section
  class:list={["desktop-portal-frame", "integrated-desktop-catalog", className]}
  aria-label={ariaLabel}
  data-desktop-portal-frame
>
  <DesktopCatalogSidebarV2
    site={site}
    channel={channel}
    filters={filters}
    activeFilterSlug={activeFilterSlug}
  />

  <div
    class="desktop-portal-banner-slot"
    data-affiliate-ad-banner-slot
    aria-label="Sponsored advertisement"
    hidden
  ></div>

  <div class="desktop-portal-screen" data-desktop-portal-screen>
    <slot />
  </div>

  <aside
    class="desktop-portal-ad-slot"
    data-affiliate-ad-vertical-slot
    aria-label="Sponsored advertisement"
    hidden
  ></aside>
</section>
