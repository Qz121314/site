{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "types": ["./worker-configuration.d.ts", "node"],
    "baseUrl": ".",
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["src/*"]
    },
    "noUncheckedIndexedAccess": true
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
